# Existing entries
node_modules/
.gws-sa-key.json

# Environment secrets — only .env.tpl (1Password-injectable) is committed;
# real .env files with actual team ids, tokens, and experiment ids must
# never land in git.
.env
.env.local
.env.*.local

# Temporary scripts and artifacts from live-OCS verification sessions.
# These contain exploration code and HTML dumps that shouldn't live in git.
scripts/tmp/

# Claude Code session-local settings (per-developer, not shared state)
.claude/settings.local.json
.gstack/

# Per-run test-audit artifacts from /canopy:test-audit. These are large
# (corpus.yaml is megabytes) and re-generatable; the audit-report.md /
# architecture-review.md content lives in the PR body.
.canopy/test-audits/
tsconfig.tsbuildinfo

# Phase 7 synthetic walkthrough artifacts. These are per-run rendered
# decks (HTML + JSON, 1-2MB each) and per-run spec YAMLs. Authoritative
# copies live in Drive under ACE/<opp>/runs/<run-id>/7-synthetic/; the
# local filesystem copy is a side-effect of the walkthrough renderer.
docs/walkthroughs/
screenshots/

# Phase 6 per-opp test recipes (generated by app-test-cases per run; not source palettes)
mcp/mobile/recipes/static/J[0-9]*.yaml
mcp/mobile/recipes/static/J[0-9]*[a-z].yaml

# ephemeral Claude Code worktrees
.claude/worktrees/
