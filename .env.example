# ── OCS Integration (see docs/superpowers/specs/2026-04-08-ace-ocs-chatbot-buildout-design.md) ──
#
# Copy this file to `.env` and fill in the values for your environment.
# `.env` is gitignored — never commit real team ids, tokens, or experiment ids.

# Base URL of the OCS instance
OCS_BASE_URL=https://chatbots.dimagi.com

# Team slug. Find by logging in to OCS and looking at the URL after
# the initial dashboard redirect (/a/<team_slug>/dashboard/).
OCS_TEAM_SLUG=

# REST backend: API token from OCS user settings (used by observation atoms)
OCS_API_TOKEN=

# Playwright backend: credentials for headless login (or use /ocs:login for SSO)
OCS_USERNAME=
OCS_PASSWORD=

# Integer experiment ID of the ACE golden template on this environment's OCS team.
# Bootstrap once per environment with:
#   npx tsx scripts/bootstrap-ocs-golden-template.ts
# The script prints the values to paste here after it runs.
OCS_GOLDEN_TEMPLATE_ID=
OCS_GOLDEN_TEMPLATE_PUBLIC_ID=
OCS_GOLDEN_TEMPLATE_EMBED_KEY=

# Bootstrap script inputs (only needed when running scripts/bootstrap-ocs-golden-template.ts):
# OCS_BOOTSTRAP_SOURCE_ID   Integer id of the chatbot to clone as the basis
#                          of the golden template. If unset, the script picks
#                          the first non-template chatbot on the team.
# OCS_GOLDEN_TEMPLATE_NAME  Defaults to "ACE Golden Template".
# OCS_BOOTSTRAP_FORCE=1     Archive the existing golden template before
#                          recreating it.

# Playwright session state (gitignored; established via /ocs:login)
ACE_SESSION_STATE_DIR=~/.ace
