#!/usr/bin/env bash
# ace-doctor — health checks for an ACE plugin install.
#
# By default audits the plugin copy this script ships with (i.e. $(dirname $0)/..).
# That's the right answer when launched via the /ace:doctor slash command, because
# Claude Code loads slash command bodies from the installed plugin copy, and the
# launcher execs bin/ace-doctor from that same copy.
#
# Overrides:
#   ACE_DIR=/path/to/ace      audit a specific plugin root
#   --here                    walk up from $PWD to find an ACE checkout (dev mode)
#   --installed               force use of the newest ~/.claude/plugins/cache/ace/ace/*
#
# Exit status: 0 always (check results go to stdout as PASS/WARN/FAIL lines).
set +e

SELF_DIR="$(cd "$(dirname "$0")/.." && pwd)"
MODE="self"
ROOT=""
SUBCOMMAND=""
SUB_OPP=""

# Sub-commands run before the standard check pipeline. Today only `verdicts <opp>`
# is supported — fetches ACE/<opp>/verdicts/ from Drive and validates each YAML
# against lib/verdict-schema.ts via parseVerdictYaml. Class-level preventer at
# the operator boundary (test/lib/real-verdict-validation.test.ts covers fixtures;
# this covers live opp output).
if [ "${1:-}" = "verdicts" ]; then
  SUBCOMMAND="verdicts"
  shift
  if [ -z "${1:-}" ]; then
    echo "usage: ace-doctor verdicts <opp-name>" >&2
    exit 2
  fi
  SUB_OPP="$1"
  shift
elif [ "${1:-}" = "state-yaml-lint" ]; then
  SUBCOMMAND="state-yaml-lint"
  shift
  if [ -z "${1:-}" ]; then
    echo "usage: ace-doctor state-yaml-lint <opp-name>" >&2
    exit 2
  fi
  SUB_OPP="$1"
  shift
elif [ "${1:-}" = "state-yaml-cruft" ]; then
  SUBCOMMAND="state-yaml-cruft"
  shift
  if [ -z "${1:-}" ]; then
    echo "usage: ace-doctor state-yaml-cruft <opp-name>" >&2
    exit 2
  fi
  SUB_OPP="$1"
  shift
elif [ "${1:-}" = "deep-qa-freshness" ]; then
  SUBCOMMAND="deep-qa-freshness"
  shift
  if [ -z "${1:-}" ]; then
    echo "usage: ace-doctor deep-qa-freshness <opp-name>" >&2
    exit 2
  fi
  SUB_OPP="$1"
  shift
fi

PREFLIGHT=0

while [ $# -gt 0 ]; do
  case "$1" in
    --here)       MODE="pwd" ;;
    --installed)  MODE="installed" ;;
    --root)       shift; ROOT="$1" ;;
    --preflight)  PREFLIGHT=1 ;;
    *)            echo "ace-doctor: unknown arg: $1" >&2; exit 2 ;;
  esac
  shift
done

# Root resolution
if [ -n "${ACE_DIR:-}" ]; then
  ROOT="$ACE_DIR"
elif [ -n "$ROOT" ]; then
  :  # already set via --root
elif [ "$MODE" = "pwd" ]; then
  D="$PWD"
  while [ "$D" != "/" ]; do
    if [ -f "$D/.claude-plugin/plugin.json" ] && grep -q '"name": "ace"' "$D/.claude-plugin/plugin.json" 2>/dev/null; then
      ROOT="$D"; break
    fi
    D="$(dirname "$D")"
  done
elif [ "$MODE" = "installed" ]; then
  # Prefer the authoritative install path Claude Code records in
  # ~/.claude/plugins/installed_plugins.json. Fall back to version-sorted
  # newest directory under the cache if that file is missing or unreadable.
  REG="$HOME/.claude/plugins/installed_plugins.json"
  if [ -f "$REG" ]; then
    ROOT="$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$REG','utf8')); const e=d['ace@ace']; if(Array.isArray(e)){for(const x of e){if(x&&x.installPath){console.log(x.installPath);break;}}} else if(e&&e.installPath){console.log(e.installPath);} } catch(_) {}" 2>/dev/null)"
  fi
  if [ -z "$ROOT" ] || [ ! -f "$ROOT/.claude-plugin/plugin.json" ]; then
    ROOT="$(ls -1d "$HOME"/.claude/plugins/cache/ace/ace/*/ 2>/dev/null | sed 's:/$::' | sort -V | tail -1)"
  fi
else
  # Default: self — audit the plugin copy this script lives in.
  ROOT="$SELF_DIR"
fi

if [ -z "$ROOT" ] || [ ! -f "$ROOT/.claude-plugin/plugin.json" ]; then
  echo "FAIL plugin_root_not_found: could not locate ACE plugin (mode=$MODE)"
  echo "  fix: run from an ACE checkout, or after /plugin install ace@ace, or pass --root /path"
  exit 0
fi

[ "$PREFLIGHT" = "1" ] || echo "INFO plugin_root=$ROOT (mode=$MODE)"

# Dispatch sub-commands. Sub-commands short-circuit the rest of the script.
if [ "$SUBCOMMAND" = "verdicts" ]; then
  if [ ! -f "$ROOT/scripts/validate-opp-verdicts.ts" ]; then
    echo "FAIL verdicts_subcommand: $ROOT/scripts/validate-opp-verdicts.ts not found"
    echo "  fix: run /ace:update to pull a version that ships the validator (>= 0.10.29)"
    exit 0
  fi
  cd "$ROOT" && exec npx tsx scripts/validate-opp-verdicts.ts "$SUB_OPP"
fi

if [ "$SUBCOMMAND" = "state-yaml-lint" ]; then
  if [ ! -f "$ROOT/scripts/lint-opp-state.ts" ]; then
    echo "FAIL state-yaml-lint_subcommand: $ROOT/scripts/lint-opp-state.ts not found"
    echo "  fix: run /ace:update to pull a version that ships the lint (>= 0.11.6)"
    exit 0
  fi
  cd "$ROOT" && exec npx tsx scripts/lint-opp-state.ts "$SUB_OPP"
fi

if [ "$SUBCOMMAND" = "state-yaml-cruft" ]; then
  if [ ! -f "$ROOT/scripts/lint-opp-cruft.ts" ]; then
    echo "FAIL state-yaml-cruft_subcommand: $ROOT/scripts/lint-opp-cruft.ts not found"
    echo "  fix: run /ace:update to pull a version that ships the lint (>= 0.11.7)"
    exit 0
  fi
  cd "$ROOT" && exec npx tsx scripts/lint-opp-cruft.ts "$SUB_OPP"
fi

# `deep-qa-freshness <opp>` — advisory check that mirrors the Phase 6
# llo-launch deep-QA verdict gate. Reads the newest run's verdicts/ folder,
# checks both deep verdicts exist + pass + (for apps) match the current
# build IDs in deployment-summary.md. WARN-level: the actual blocker is in
# the gate itself; this is the "see the wall before you hit it" preventer.
# Shipped with the shallow/deep QA split refactor.
if [ "$SUBCOMMAND" = "deep-qa-freshness" ]; then
  if [ ! -f "$ROOT/scripts/check-deep-qa-freshness.ts" ]; then
    echo "FAIL deep-qa-freshness_subcommand: $ROOT/scripts/check-deep-qa-freshness.ts not found"
    echo "  fix: run /ace:update to pull a version that ships the check (shallow/deep QA split refactor)"
    exit 0
  fi
  cd "$ROOT" && exec npx tsx scripts/check-deep-qa-freshness.ts "$SUB_OPP"
fi

# --preflight — emit a tight YAML snapshot of local state for the orchestrator's
# pre-flight checklist (agents/ace-orchestrator.md § Pre-flight Checklist Step 1).
# Skips human-facing PASS/WARN/FAIL noise, hygiene checks, and live auth probes.
# What it covers: env_file path, plugin version + install_path, git user.email,
# presence of the env vars Phase 1+ skills depend on. Sensitive values (passwords,
# tokens) are reported as `present`/`missing`; public IDs (Drive root, HQ domain,
# OCS team slug, etc.) are echoed verbatim because the orchestrator needs them
# to populate the inline-artifact prompts.
if [ "$PREFLIGHT" = "1" ]; then
  # env_file resolution (mirrors the runtime-readiness block ~line 484)
  ENV_FILE=""
  DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.claude/plugins/data/ace-ace}"
  if [ -f "$DATA_DIR/.env" ]; then
    ENV_FILE="$DATA_DIR/.env"
  elif [ -f "$ROOT/.env" ]; then
    ENV_FILE="$ROOT/.env"
  fi

  # Local copy of get_env — mirrors the runtime-readiness helper. Strips
  # quotes, treats unresolved 1Password refs as missing.
  pf_get_env() {
    [ -z "$ENV_FILE" ] && return
    local raw
    raw="$(grep -E "^[[:space:]]*$1=" "$ENV_FILE" 2>/dev/null | tail -1 | sed -E "s/^[[:space:]]*$1=//; s/^['\"]//; s/['\"]$//")"
    case "$raw" in
      op://*) return ;;
      *) printf '%s' "$raw" ;;
    esac
  }

  # Presence-only — never echo the actual value. Returns "present" or "missing".
  pf_presence() {
    local v
    v="$(pf_get_env "$1")"
    [ -n "$v" ] && echo present || echo missing
  }

  # Plugin metadata
  PLUGIN_VERSION=""
  if [ -f "$ROOT/VERSION" ]; then
    PLUGIN_VERSION="$(tr -d '[:space:]' < "$ROOT/VERSION")"
  fi
  GIT_EMAIL="$(git config user.email 2>/dev/null || true)"
  SA_KEY=""
  if [ -f "$DATA_DIR/gws-sa-key.json" ]; then
    SA_KEY="$DATA_DIR/gws-sa-key.json"
  elif [ -f "$ROOT/.gws-sa-key.json" ]; then
    SA_KEY="$ROOT/.gws-sa-key.json"
  fi

  # Public values orchestrator needs verbatim
  ACE_DRIVE_ROOT="$(pf_get_env ACE_DRIVE_ROOT_FOLDER_ID)"
  ACE_HQ_DOMAIN="$(pf_get_env ACE_HQ_DOMAIN)"
  OCS_BASE_URL="$(pf_get_env OCS_BASE_URL)"
  OCS_TEAM_SLUG="$(pf_get_env OCS_TEAM_SLUG)"
  OCS_GTID="$(pf_get_env OCS_GOLDEN_TEMPLATE_ID)"
  ACE_GMAIL_ACCOUNT="$(pf_get_env ACE_GMAIL_ACCOUNT)"

  # selector_map_currency — static structural check; mirrors the named
  # probe in the human-readable block below. Reads ACE_CONNECT_APK_VERSION
  # (env), falls back to newest connect-*.yaml on disk. Counts rows
  # referenced/known/unverified, lists unresolved selectors so the
  # orchestrator can decide whether Phase 5 is safe to enter.
  PF_SEL_DIR="$ROOT/mcp/mobile/selectors"
  PF_SEL_RECIPES_DIR="$ROOT/mcp/mobile/recipes/static"
  PF_SEL_APK="$(pf_get_env ACE_CONNECT_APK_VERSION)"
  if [ -z "$PF_SEL_APK" ]; then
    PF_SEL_APK="$(ls -1 "$PF_SEL_DIR"/connect-*.yaml 2>/dev/null \
      | sed -E 's|.*/connect-([^/]+)\.yaml$|\1|' \
      | sort -V | tail -1)"
  fi
  PF_SEL_MAP_REL="mcp/mobile/selectors/connect-${PF_SEL_APK}.yaml"
  PF_SEL_MAP_PATH="$ROOT/$PF_SEL_MAP_REL"
  PF_SEL_STATUS="fail"
  PF_SEL_ROWS_VERIFIED=0
  PF_SEL_ROWS_UNVERIFIED=0
  PF_SEL_RECIPES_SCANNED=0
  PF_SEL_UNRESOLVED_YAML="[]"
  PF_SEL_REMEDIATION="run /ace:step connect-baseline-screenshots"
  if [ -n "$PF_SEL_APK" ] && [ -f "$PF_SEL_MAP_PATH" ]; then
    PF_SEL_KNOWN="$(awk '
      /^selectors:[[:space:]]*$/ { in_sel=1; next }
      in_sel && /^[a-zA-Z_]/ { in_sel=0 }
      in_sel && /^  [a-z][a-z0-9-]*:[[:space:]]*$/ {
        gsub(/^  |:[[:space:]]*$/, "", $0); print $0
      }
    ' "$PF_SEL_MAP_PATH" 2>/dev/null)"
    PF_SEL_KNOWN_COUNT=$(printf '%s\n' "$PF_SEL_KNOWN" | grep -c . | tr -d '[:space:]')
    : "${PF_SEL_KNOWN_COUNT:=0}"
    PF_SEL_ROWS_UNVERIFIED=$(grep -cE '^[[:space:]]+unverified:[[:space:]]*true' "$PF_SEL_MAP_PATH" 2>/dev/null | tr -d '[:space:]')
    : "${PF_SEL_ROWS_UNVERIFIED:=0}"
    PF_SEL_ROWS_VERIFIED=$((PF_SEL_KNOWN_COUNT - PF_SEL_ROWS_UNVERIFIED))
    if [ "$PF_SEL_KNOWN_COUNT" -gt 0 ]; then
      PF_SEL_REFD=""
      if [ -d "$PF_SEL_RECIPES_DIR" ]; then
        PF_SEL_REFD="$(grep -h -oE '\$\{SELECTOR:[^}]+\}' "$PF_SEL_RECIPES_DIR"/*.yaml 2>/dev/null \
          | sed -E 's/^\$\{SELECTOR:([^}]+)\}$/\1/' | sort -u)"
        PF_SEL_RECIPES_SCANNED=$(ls -1 "$PF_SEL_RECIPES_DIR"/*.yaml 2>/dev/null | wc -l | tr -d '[:space:]')
      fi
      PF_SEL_UNRESOLVED="$(comm -23 \
        <(printf '%s\n' "$PF_SEL_REFD" | grep . | sort -u) \
        <(printf '%s\n' "$PF_SEL_KNOWN" | grep . | sort -u))"
      PF_SEL_UNRESOLVED_COUNT=$(printf '%s\n' "$PF_SEL_UNRESOLVED" | grep -c . | tr -d '[:space:]')
      : "${PF_SEL_UNRESOLVED_COUNT:=0}"
      if [ "$PF_SEL_UNRESOLVED_COUNT" -eq 0 ]; then
        PF_SEL_STATUS="pass"
        PF_SEL_REMEDIATION=""
        PF_SEL_UNRESOLVED_YAML="[]"
      else
        PF_SEL_STATUS="warn"
        PF_SEL_REMEDIATION="run /ace:step connect-baseline-screenshots to calibrate against the live APK"
        # Inline JSON-style list — YAML 1.1 accepts ["a","b"].
        PF_SEL_UNRESOLVED_YAML="[$(printf '%s\n' "$PF_SEL_UNRESOLVED" | grep . | sed 's/^/"/; s/$/"/' | tr '\n' ',' | sed 's/,$//')]"
      fi
    fi
  fi

  # Build the YAML body. Missing public values render as empty strings; the
  # orchestrator can decide how to react (some are required, some optional).
  cat <<EOF
status: ok
plugin:
  version: ${PLUGIN_VERSION:-unknown}
  install_path: $ROOT
  env_file: ${ENV_FILE:-MISSING}
  sa_key: ${SA_KEY:-MISSING}
git:
  user_email: ${GIT_EMAIL:-MISSING}
env:
  ace_drive_root_folder_id: ${ACE_DRIVE_ROOT:-}
  ace_hq_domain: ${ACE_HQ_DOMAIN:-}
  ocs_base_url: ${OCS_BASE_URL:-}
  ocs_team_slug: ${OCS_TEAM_SLUG:-}
  ocs_golden_template_id: ${OCS_GTID:-}
  ace_gmail_account: ${ACE_GMAIL_ACCOUNT:-}
  ace_hq_username: $(pf_presence ACE_HQ_USERNAME)
  ace_hq_password: $(pf_presence ACE_HQ_PASSWORD)
  ocs_username: $(pf_presence OCS_USERNAME)
  ocs_password: $(pf_presence OCS_PASSWORD)
  ace_web_pat_token: $(pf_presence ACE_WEB_PAT_TOKEN)
  ace_training_deck_template_id: $(pf_presence ACE_TRAINING_DECK_TEMPLATE_ID)
  labs_mcp_token: $(pf_presence LABS_MCP_TOKEN)
  ocs_shared_collection_id: $(pf_presence OCS_SHARED_COLLECTION_ID)
  ocs_llm_provider_id: $(pf_presence OCS_LLM_PROVIDER_ID)
  ocs_embedding_model_id: $(pf_presence OCS_EMBEDDING_MODEL_ID)
  content_generator_url: $(pf_presence CONTENT_GENERATOR_URL)
  content_generator_api_key: $(pf_presence CONTENT_GENERATOR_API_KEY)
selector_map_currency:
  status: ${PF_SEL_STATUS}
  apk_version: "${PF_SEL_APK:-}"
  map_path: "${PF_SEL_MAP_REL}"
  rows_verified: ${PF_SEL_ROWS_VERIFIED}
  rows_unverified: ${PF_SEL_ROWS_UNVERIFIED}
  recipes_scanned: ${PF_SEL_RECIPES_SCANNED}
  unresolved_selectors: ${PF_SEL_UNRESOLVED_YAML}
  remediation: "${PF_SEL_REMEDIATION}"
EOF
  exit 0
fi

# If the user is inside a dev worktree that differs from $ROOT, flag it so they
# know the doctor is auditing the installed copy rather than their checkout.
PWD_MATCH=""
D="$PWD"
while [ "$D" != "/" ]; do
  if [ -f "$D/.claude-plugin/plugin.json" ] && grep -q '"name": "ace"' "$D/.claude-plugin/plugin.json" 2>/dev/null; then
    PWD_MATCH="$D"; break
  fi
  D="$(dirname "$D")"
done
if [ -n "$PWD_MATCH" ] && [ "$PWD_MATCH" != "$ROOT" ]; then
  echo "INFO cwd_is_ace_checkout=$PWD_MATCH (pass --here to audit it instead)"
fi

pass() { printf 'PASS %s\n' "$1"; }
warn() { printf 'WARN %s\n' "$1"; [ -n "${2:-}" ] && printf '  fix: %s\n' "$2"; }
fail() { printf 'FAIL %s\n' "$1"; [ -n "${2:-}" ] && printf '  fix: %s\n' "$2"; }
# No _log() abstraction in this script; mirrors the pass/warn/fail printf pattern.
info() { printf 'INFO %s\n' "$1"; }

# --- Output capture for end-of-run summary table (added 0.13.129) ---
#
# Tee all stdout into a temp file so the trailing summary block can count
# PASS/WARN/FAIL items without re-running probes. Uses tee in a process
# substitution so output streams to the user's terminal in real time
# (unchanged behavior) AND lands in the log file for parsing.
#
# Why this matters: the doctor script emits ~40 lines on a healthy run;
# main agents and ad-hoc operators end up scrolling to find what's
# broken. The end-of-run table inverts that — verdict + WARN/FAIL names
# up front, body becomes the drill-down.
#
# Catches the doctor-drive-layout.ts subprocess output too (it writes
# its own PASS/WARN lines via the same shape).
DOCTOR_LOG="$(mktemp -t ace-doctor.XXXXXX 2>/dev/null || mktemp)"
trap 'rm -f "$DOCTOR_LOG"' EXIT
exec > >(tee "$DOCTOR_LOG")

# --- Version consistency ---
VER_FILE="$(tr -d '[:space:]' < "$ROOT/VERSION" 2>/dev/null || echo missing)"
VER_PLUGIN="$(node -e "console.log(require('$ROOT/.claude-plugin/plugin.json').version);" 2>/dev/null || echo missing)"
VER_MARKET="$(node -e "console.log(require('$ROOT/.claude-plugin/marketplace.json').plugins[0].version);" 2>/dev/null || echo missing)"
VER_PKG="$(node -e "console.log(require('$ROOT/package.json').version);" 2>/dev/null || echo missing)"

if [ "$VER_FILE" = "$VER_PLUGIN" ] && [ "$VER_PLUGIN" = "$VER_MARKET" ] && [ "$VER_MARKET" = "$VER_PKG" ]; then
  pass "version_consistency: all four sources agree on $VER_FILE"
else
  warn "version_consistency: VERSION=$VER_FILE plugin.json=$VER_PLUGIN marketplace.json=$VER_MARKET package.json=$VER_PKG" "bump all four in a single commit when releasing"
fi

# --- Running session vs installed registry ---
# After `/ace:update` lands a new cache dir, the running session keeps
# using the OLD plugin path until the session is reloaded. Slash commands
# get the new bodies on next invocation, but MCP servers only re-launch
# on `/reload-plugins` or a fresh session. The canonical symptom is "No
# such tool available: connect_<atom>" right after an update — the registry
# points at v0.10.21 but the MCP server is still running v0.10.20's binaries.
#
# Detect: compare $ROOT's VERSION against the version recorded in
# installed_plugins.json. They should match. If they don't, surface as a
# WARN with the actionable fix (`/reload-plugins` or restart the session).
REG_VER=""
REG_PATH=""
if [ -f "$HOME/.claude/plugins/installed_plugins.json" ]; then
  REG_VER="$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$HOME/.claude/plugins/installed_plugins.json','utf8')); const e=d['ace@ace']||(d.plugins&&d.plugins['ace@ace']); const v=Array.isArray(e)?e[0]:e; console.log(v&&v.version||''); } catch(_) {}" 2>/dev/null)"
  REG_PATH="$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$HOME/.claude/plugins/installed_plugins.json','utf8')); const e=d['ace@ace']||(d.plugins&&d.plugins['ace@ace']); const v=Array.isArray(e)?e[0]:e; console.log(v&&v.installPath||''); } catch(_) {}" 2>/dev/null)"
fi
if [ -n "$REG_VER" ] && [ "$VER_FILE" != "missing" ]; then
  if [ "$REG_VER" = "$VER_FILE" ]; then
    pass "session_freshness: running v$VER_FILE matches registry"
  else
    warn "session_freshness: running v$VER_FILE but registry has v$REG_VER at $REG_PATH" "MCP servers still use the running session's binaries — run /reload-plugins (or restart this Claude Code session) to pick up registry version. Symptom of stale state: 'No such tool available: connect_*' after /ace:update."
  fi
fi

# --- Node / npm ---
if command -v node >/dev/null 2>&1; then
  pass "node: $(node --version)"
else
  fail "node: not on PATH" "install Node.js v18+"
fi

if command -v npm >/dev/null 2>&1; then
  pass "npm: $(npm --version)"
else
  fail "npm: not on PATH" "install Node.js v18+ (bundles npm)"
fi

# --- node_modules + tsx ---
if [ -d "$ROOT/node_modules" ] && [ -x "$ROOT/node_modules/.bin/tsx" ]; then
  pass "deps: node_modules present, tsx=$("$ROOT/node_modules/.bin/tsx" --version 2>&1 | head -1)"
else
  fail "deps: node_modules missing or tsx not installed at $ROOT" "run /ace:setup (or 'npm install' in $ROOT)"
fi

# --- Playwright Chromium browser binary ---
# Every login/seeding flow that drives a browser (/ace:ocs-login,
# /ace:connect-login, /ace:labs-login, /ace:labs-token-mint,
# scripts/seed-connect-cookies.ts) needs the Chromium binary that
# `npx playwright install chromium` lands in an OS-specific cache dir.
# Without it the symptom is a vague "browser doesn't open" — surface it
# explicitly here so a new colleague gets the right fix command on day one.
if [ -d "$ROOT/node_modules/playwright" ]; then
  PW_PROBE="$(cd "$ROOT" && node -e "
    try {
      const { chromium } = require('playwright');
      const fs = require('fs');
      const p = chromium.executablePath();
      console.log(JSON.stringify({ path: p, exists: fs.existsSync(p) }));
    } catch (e) {
      console.log(JSON.stringify({ error: e.message }));
    }
  " 2>/dev/null)"
  PW_EXISTS="$(printf '%s' "$PW_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.exists?'1':'0'); } catch { console.log('?'); }" 2>/dev/null)"
  PW_PATH="$(printf '%s' "$PW_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.path||''); } catch { console.log(''); }" 2>/dev/null)"
  if [ "$PW_EXISTS" = "1" ]; then
    pass "playwright_chromium: $PW_PATH"
  elif [ -n "$PW_PATH" ]; then
    warn "playwright_chromium: expected at $PW_PATH but not present" "cd \"$ROOT\" && npx playwright install chromium"
  else
    warn "playwright_chromium: could not resolve expected path (playwright module unhappy)" "cd \"$ROOT\" && npm install && npx playwright install chromium"
  fi
fi

# --- Stale plugin cache dirs ---
# /ace:update creates ~/.claude/plugins/cache/ace/ace/<version>/ on every
# upgrade and does not purge old ones. Each cached version is ~150MB
# (most of which is node_modules). Surface the cleanup so colleagues
# don't accumulate gigabytes of stale cache silently.
CACHE_PARENT="$HOME/.claude/plugins/cache/ace/ace"
if [ -d "$CACHE_PARENT" ]; then
  CACHE_COUNT="$(ls -1d "$CACHE_PARENT"/*/ 2>/dev/null | wc -l | tr -d '[:space:]')"
  if [ "${CACHE_COUNT:-0}" -gt 3 ]; then
    KEEP=2
    DROP=$((CACHE_COUNT - KEEP))
    APPROX_MB=$((CACHE_COUNT * 150))
    warn "stale_cache: $CACHE_COUNT cached versions in $CACHE_PARENT (~${APPROX_MB}MB total at ~150MB each)" "ls -1d $CACHE_PARENT/*/ | sort -V | head -n $DROP | xargs rm -rf  # drops oldest $DROP, keeps newest $KEEP"
  else
    pass "stale_cache: $CACHE_COUNT cached version(s) in $CACHE_PARENT"
  fi
fi

# --- Google service-account key ---
# Canonical: $CLAUDE_PLUGIN_DATA/gws-sa-key.json — survives plugin updates.
# Legacy: $ROOT/.gws-sa-key.json — for pre-migration installs.
if [ -n "${CLAUDE_PLUGIN_DATA:-}" ]; then
  DATA_DIR="$CLAUDE_PLUGIN_DATA"
else
  DATA_DIR="$HOME/.claude/plugins/data/ace-ace"
fi
CANONICAL_KEY="$DATA_DIR/gws-sa-key.json"
LEGACY_KEY="$ROOT/.gws-sa-key.json"

KEY=""
KEY_LOC=""
if [ -f "$CANONICAL_KEY" ] && [ -r "$CANONICAL_KEY" ]; then
  KEY="$CANONICAL_KEY"; KEY_LOC="canonical"
elif [ -f "$LEGACY_KEY" ] && [ -r "$LEGACY_KEY" ]; then
  KEY="$LEGACY_KEY"; KEY_LOC="legacy"
fi

if [ -n "$KEY" ]; then
  CE="$(node -e "try { console.log(JSON.parse(require('fs').readFileSync('$KEY','utf8')).client_email); } catch(e) { console.log('unreadable'); }" 2>/dev/null || echo unreadable)"
  if [ "$CE" = "unreadable" ]; then
    fail "gws_key: $KEY is not valid JSON" "re-drop the service-account key"
  elif [ "$KEY_LOC" = "legacy" ]; then
    warn "gws_key: $CE at LEGACY path $LEGACY_KEY" "migrate to $CANONICAL_KEY so it survives plugin updates: mv \"$LEGACY_KEY\" \"$CANONICAL_KEY\" && chmod 600 \"$CANONICAL_KEY\""
  else
    pass "gws_key: $CE at $CANONICAL_KEY"
  fi
else
  fail "gws_key: missing (checked $CANONICAL_KEY and $LEGACY_KEY)" "mkdir -p \"$DATA_DIR\" && drop the service-account JSON at $CANONICAL_KEY (ask Jon for the ACE key)"
fi

# --- MCP manifest sanity ---
# As of 0.5.16 MCP servers live inline in plugin.json under "mcpServers",
# NOT in a separate .mcp.json at plugin root. See
# https://github.com/anthropics/claude-code/issues/9427 — Claude Code fails
# to expand ${CLAUDE_PLUGIN_ROOT}/${CLAUDE_PLUGIN_DATA} when a plugin declares
# its servers via plugin-root .mcp.json, but the expansion works correctly
# when declared inline in plugin.json.
PLUGIN_JSON="$ROOT/.claude-plugin/plugin.json"
if [ -f "$PLUGIN_JSON" ]; then
  MCP_NAMES="$(node -e "const m=require('$PLUGIN_JSON'); console.log(Object.keys(m.mcpServers||{}).join(','));" 2>/dev/null || echo parse_error)"
  if [ "$MCP_NAMES" = "parse_error" ]; then
    fail "mcp_manifest: plugin.json does not parse" "verify JSON syntax"
  elif [ -z "$MCP_NAMES" ]; then
    fail "mcp_manifest: plugin.json has no mcpServers block" "restore the mcpServers object with ace-gdrive and ace-ocs"
  else
    pass "mcp_manifest: servers=$MCP_NAMES (inline in plugin.json)"
    case "$MCP_NAMES" in
      *ace-gdrive*) ;;
      *) warn "mcp_manifest: ace-gdrive not declared" "restore the ace-gdrive entry in plugin.json mcpServers" ;;
    esac
  fi
else
  fail "mcp_manifest: .claude-plugin/plugin.json missing" "restore plugin.json at the plugin root"
fi

# --- Stale .mcp.json guard ---
# If both a plugin.json mcpServers block AND a .mcp.json exist, warn — the
# legacy .mcp.json hits the upstream substitution bug (9427) and will shadow
# silently on versions where Claude Code merges the two sources.
if [ -f "$ROOT/.mcp.json" ]; then
  warn "mcp_manifest: stale .mcp.json present at plugin root" "delete $ROOT/.mcp.json — MCP servers now live inline in plugin.json (see 9427)"
fi

# --- MCP env passthrough check ---
# Catch the class of silent-stall fixed in 0.5.7: an MCP server source that
# uses `dotenv` to load `$CLAUDE_PLUGIN_DATA/.env` but whose plugin.json
# mcpServers entry has no env block passing CLAUDE_PLUGIN_DATA through. The
# subprocess spawns with an empty process.env.CLAUDE_PLUGIN_DATA, dotenv
# silently falls back to ./.env (subprocess cwd), the real .env is never
# loaded, every secret reads as undefined, and downstream API calls get
# 401/403 with no clear signal that the env var was the root cause.
#
# This check is static: parse plugin.json, look at each server's args for a
# .ts/.js source path, read that source, check for the dotenv+CLAUDE_PLUGIN_DATA
# pattern, then verify the plugin.json env block includes CLAUDE_PLUGIN_DATA.
if [ -f "$PLUGIN_JSON" ] && [ "$MCP_NAMES" != "parse_error" ] && [ -n "$MCP_NAMES" ]; then
  MCP_ENV_ISSUES="$(node -e "
    const fs = require('fs');
    const path = require('path');
    const root = '$ROOT';
    const plugin = JSON.parse(fs.readFileSync(path.join(root, '.claude-plugin', 'plugin.json'), 'utf8'));
    const servers = plugin.mcpServers || {};
    const issues = [];
    for (const [name, cfg] of Object.entries(servers)) {
      if (!cfg || typeof cfg !== 'object') continue;
      // Resolve the source file: the last .ts or .js arg, with \${CLAUDE_PLUGIN_ROOT} expanded.
      const args = Array.isArray(cfg.args) ? cfg.args : [];
      const src = args.filter(a => typeof a === 'string' && /\\.(ts|js)$/.test(a)).pop();
      if (!src) continue;
      const resolved = src.replace(/\\\$\\{CLAUDE_PLUGIN_ROOT\\}/g, root);
      let body = '';
      try { body = fs.readFileSync(resolved, 'utf8'); } catch (_) { continue; }
      // Does this server read process.env.CLAUDE_PLUGIN_DATA to locate .env?
      const usesPluginData = /process\\.env\\.CLAUDE_PLUGIN_DATA/.test(body) && /dotenv|dotenvConfig|\\brequire\\s*\\(\\s*[\"']dotenv/.test(body);
      if (!usesPluginData) continue;
      // If it does, the plugin.json env block MUST pass CLAUDE_PLUGIN_DATA through.
      const env = (cfg.env && typeof cfg.env === 'object') ? cfg.env : {};
      if (!('CLAUDE_PLUGIN_DATA' in env)) {
        issues.push(name);
      }
    }
    if (issues.length) console.log(issues.join(','));
  " 2>/dev/null)"
  if [ -n "$MCP_ENV_ISSUES" ]; then
    warn "mcp_env_passthrough: servers loading \$CLAUDE_PLUGIN_DATA/.env without env passthrough: $MCP_ENV_ISSUES (silent 401/403 on every tool call)" "add \"CLAUDE_PLUGIN_DATA\": \"\\\${CLAUDE_PLUGIN_DATA}\" to each server's env block in plugin.json mcpServers"
  else
    pass "mcp_env_passthrough: every MCP server that needs CLAUDE_PLUGIN_DATA receives it"
  fi
fi

# --- ace-update-check binary ---
if [ -x "$ROOT/bin/ace-update-check" ]; then
  pass "update_check: bin/ace-update-check executable"
else
  warn "update_check: bin/ace-update-check missing or not executable" "chmod +x $ROOT/bin/ace-update-check"
fi

# --- Auto-update hook (hooks/hooks.json) ---
if [ -f "$ROOT/hooks/hooks.json" ]; then
  if grep -q "ace-update-check" "$ROOT/hooks/hooks.json" 2>/dev/null; then
    pass "auto_update: hooks/hooks.json declares SessionStart update check"
  else
    warn "auto_update: hooks/hooks.json exists but does not reference ace-update-check" "verify hooks/hooks.json content"
  fi
else
  warn "auto_update: hooks/hooks.json missing" "restore hooks/hooks.json at the plugin root"
fi

# --- Sibling plugin installs (Phase 2 dependency only) ---
# (ace-web is a sibling repo for browser-harness work but is NOT a runtime
# dependency of the plugin — intentionally not checked here.)
# Nova drives Phase 2 (commcare-setup): pdd-to-learn-app, pdd-to-deliver-app,
# app-deploy. Without Nova installed, those skills produce stub artifacts.
# This failure mode is silent — the skill runs, writes something, and the
# operator only notices days later. The signal we can check from here is
# simple and authoritative: is the plugin listed in
# ~/.claude/plugins/installed_plugins.json?
#
# (Phase 3's connect-labs dependency claim is gone in 0.13.33 — Phase 3
# skills moved off the connect-labs Claude Code plugin in 0.10.47 when
# ace-connect adopted commcare-connect's REST automation API. The labs
# MCP itself is still consumed but via the stdio proxy at
# mcp/connect-labs-server.ts, which is independently verified by
# `connect_labs_mcp_reachable` and `connect_labs_connect_oauth` below.
# The dropped check was actively misleading: its WARN ran on every
# install because no `connect-labs` Claude Code plugin actually exists
# in any known marketplace.)
PLUGIN_REG="$HOME/.claude/plugins/installed_plugins.json"

probe_plugin() {
  # probe_plugin <pattern> — print the matched plugin key (or empty).
  # Pattern matches against keys in installed_plugins.json (e.g., "nova@" or "connect-labs").
  [ -f "$PLUGIN_REG" ] || return
  node -e "
    try {
      const d = JSON.parse(require('fs').readFileSync('$PLUGIN_REG','utf8'));
      const plugins = d.plugins || d;
      const pat = '$1';
      for (const k of Object.keys(plugins)) {
        if (k.indexOf(pat) !== -1) { console.log(k); break; }
      }
    } catch(_) {}
  " 2>/dev/null
}

NOVA_KEY="$(probe_plugin nova)"
if [ -n "$NOVA_KEY" ]; then
  pass "nova_plugin: $NOVA_KEY installed"
else
  warn "nova_plugin: not installed (Phase 2 commcare-setup degrades to HITL stubs — pdd-to-learn-app, pdd-to-deliver-app, app-deploy will not produce real apps)" "/plugin install nova@nova-marketplace, then sign in via OAuth on first /nova:autobuild"
fi

# Local connect-labs checkout is still useful for development of the
# server-side labs app itself; keep as a soft hint, no warning.
if [ -d "$HOME/emdash-projects/connect-labs" ]; then
  pass "connect_labs_repo: local checkout detected (dev mode)"
fi

# --- Runtime readiness (things needed to actually run an opportunity) ---
# These are all WARN, not FAIL: a user who only wants idea-to-design runs
# doesn't need OCS/Gmail configured. But doctor-green should still tell
# them what's unset so they see the wall before they hit it at Phase 5.

# Prefer the plugin-data .env (persistent across updates). Fall back to a
# dev checkout's ./.env if that's where the user keeps their secrets.
ENV_FILE=""
if [ -f "$DATA_DIR/.env" ]; then
  ENV_FILE="$DATA_DIR/.env"
elif [ -f "$ROOT/.env" ]; then
  ENV_FILE="$ROOT/.env"
fi

if [ -n "$ENV_FILE" ]; then
  if [ -n "${CLAUDE_PLUGIN_DATA:-}" ]; then
    pass "env_file: $ENV_FILE (CLAUDE_PLUGIN_DATA set to $CLAUDE_PLUGIN_DATA)"
  else
    pass "env_file: $ENV_FILE (CLAUDE_PLUGIN_DATA unset; defaulted DATA_DIR to $DATA_DIR — agents that probe \${CLAUDE_PLUGIN_DATA}/.env directly will miss this path. Resolution order: \$CLAUDE_PLUGIN_DATA/.env → ~/.claude/plugins/data/ace-ace/.env → \$ROOT/.env)"
  fi
else
  warn "env_file: no .env found (checked $DATA_DIR/.env and $ROOT/.env; CLAUDE_PLUGIN_DATA=${CLAUDE_PLUGIN_DATA:-unset})" "op inject -i \"$ROOT/.env.tpl\" -o \"$DATA_DIR/.env\" --account dimagi.1password.com"
fi

# get_env KEY — prints the value of KEY from $ENV_FILE, or empty if absent/unresolved.
# Strips surrounding quotes and treats unresolved 1Password refs (op://...) as empty.
get_env() {
  [ -z "$ENV_FILE" ] && return
  local raw
  raw="$(grep -E "^[[:space:]]*$1=" "$ENV_FILE" 2>/dev/null | tail -1 | sed -E "s/^[[:space:]]*$1=//; s/^['\"]//; s/['\"]$//")"
  case "$raw" in
    op://*) return ;;  # unresolved 1Password reference — treat as missing
    *) printf '%s' "$raw" ;;
  esac
}

if [ -n "$ENV_FILE" ]; then
  OCS_BASE="$(get_env OCS_BASE_URL)"
  OCS_TEAM="$(get_env OCS_TEAM_SLUG)"
  OCS_GTID="$(get_env OCS_GOLDEN_TEMPLATE_ID)"
  GMAIL_ACCT="$(get_env ACE_GMAIL_ACCOUNT)"
  DRIVE_ROOT="$(get_env ACE_DRIVE_ROOT_FOLDER_ID)"
  SHARED_COLL="$(get_env OCS_SHARED_COLLECTION_ID)"
  LLM_PROV="$(get_env OCS_LLM_PROVIDER_ID)"
  EMBED_MODEL="$(get_env OCS_EMBEDDING_MODEL_ID)"

  if [ -n "$OCS_BASE" ] && [ -n "$OCS_TEAM" ] && [ -n "$OCS_GTID" ]; then
    pass "ocs_env: base=$OCS_BASE team=$OCS_TEAM golden_template=$OCS_GTID"
  else
    missing=""
    [ -z "$OCS_BASE" ] && missing="$missing OCS_BASE_URL"
    [ -z "$OCS_TEAM" ] && missing="$missing OCS_TEAM_SLUG"
    [ -z "$OCS_GTID" ] && missing="$missing OCS_GOLDEN_TEMPLATE_ID"
    hint="re-inject .env via 1Password, or run /ace:ocs-bootstrap-template (for OCS_GOLDEN_TEMPLATE_ID)"
    warn "ocs_env: missing or unresolved:$missing" "$hint"
  fi

  # Drive root folder — required by /ace:run's smart-default PDD picker
  # (agents/ace-orchestrator.md § Starting a New Opportunity). Without this,
  # the picker falls through to the inline-paste fallback with no signal
  # that the env var is the cause.
  if [ -n "$DRIVE_ROOT" ]; then
    pass "drive_root: ACE_DRIVE_ROOT_FOLDER_ID=$DRIVE_ROOT"
  else
    warn "drive_root: ACE_DRIVE_ROOT_FOLDER_ID not set (PDD auto-discovery disabled)" "re-inject .env via op inject (var added in 0.5.3)"
  fi

  # ACE_WEB_PAT_TOKEN is the per-human Personal Access Token for ace-web,
  # minted via /ace:ace-web-pat-mint (gh-style loopback flow). Replaces
  # the deployment-wide ACE_E2E_AUTH_TOKEN shared secret. The
  # upload-transcript skill (and any future ace-web automation) uses it
  # as a Bearer auth header. Local-only secret — preserved across op
  # inject by the marker block in $ENV_OUT.
  PAT_TOKEN="$(get_env ACE_WEB_PAT_TOKEN)"
  if [ -n "$PAT_TOKEN" ]; then
    pass "ace_web_pat_token: ACE_WEB_PAT_TOKEN is set (${#PAT_TOKEN} chars)"
  else
    warn "ace_web_pat_token: ACE_WEB_PAT_TOKEN not set" "run /ace:ace-web-pat-mint to mint a per-human PAT (one-time per machine; gh-style browser flow). Needed by skills/upload-transcript and /ace:run --ace-web-url."
  fi

  # ACE_TRAINING_DECK_TEMPLATE_ID gates the training-deck-build skill.
  # The skill is non-blocking (Phase 7 doesn't require the Slides deck), so
  # a missing template is WARN, not FAIL — but operators should know the
  # training-deck workflow won't produce a deck until they bootstrap it.
  TDID="$(get_env ACE_TRAINING_DECK_TEMPLATE_ID)"
  if [ -n "$TDID" ]; then
    pass "training_deck_template: ACE_TRAINING_DECK_TEMPLATE_ID=$TDID"
  else
    warn "training_deck_template: ACE_TRAINING_DECK_TEMPLATE_ID not set" "run 'npx tsx scripts/bootstrap-training-deck-template.ts' to create the template, then add the ID to 1Password and re-inject .env (training-deck-build skips silently without it)"
  fi

  # Content Generator API — gates the multimedia-generation skill family.
  # Passive present/non-empty check only; no live HTTP ping (image generation
  # is too slow and costly to run on every doctor invocation, and the API
  # contract is still being verified). Both keys are 1Password-backed.
  CG_URL="$(get_env CONTENT_GENERATOR_URL)"
  CG_KEY="$(get_env CONTENT_GENERATOR_API_KEY)"
  if [ -n "$CG_URL" ] && [ -n "$CG_KEY" ]; then
    pass "content_generator: CONTENT_GENERATOR_URL=$CG_URL CONTENT_GENERATOR_API_KEY set (${#CG_KEY} chars)"
  else
    cg_missing=""
    [ -z "$CG_URL" ] && cg_missing="$cg_missing CONTENT_GENERATOR_URL"
    [ -z "$CG_KEY" ] && cg_missing="$cg_missing CONTENT_GENERATOR_API_KEY"
    warn "content_generator: missing or unresolved:$cg_missing (multimedia generation will be unavailable)" "re-inject .env via op inject (vars added in 0.13.x)"
  fi

  # Shared-Drive canary: the configured root MUST live on a Google Shared Drive.
  # Service Accounts have zero My-Drive quota, so a My-Drive-parented root means
  # every artifact write fails with "user storage quota exceeded" on the FIRST
  # opportunity created. Files on a Shared Drive carry a non-empty `driveId`;
  # files in My Drive don't. One files.get probe catches the entire class.
  # (2026-04-27, after dogfood run #1 surfaced this as a silent My-Drive fallback.)
  if [ -n "$DRIVE_ROOT" ] && [ -n "$KEY" ] && [ -d "$ROOT/node_modules/@googleapis/drive" ]; then
    # cd "$ROOT" so the inline `import` from '@googleapis/drive' resolves
    # against the plugin's node_modules instead of doctor's CWD. Same fix as
    # gdrive_auth in the [Auth liveness] block (0.13.25); without it, doctor
    # invocations from outside the plugin dir silently fail the import (stderr
    # suppressed by 2>/dev/null) and the probe falls through with no output.
    DRIVE_ROOT_PROBE="$(cd "$ROOT" && GOOGLE_APPLICATION_CREDENTIALS="$KEY" node --input-type=module -e "
      import { drive as makeDrive } from '@googleapis/drive';
      import { GoogleAuth } from 'google-auth-library';
      const auth = new GoogleAuth({ keyFile: process.env.GOOGLE_APPLICATION_CREDENTIALS, scopes: ['https://www.googleapis.com/auth/drive'] });
      const drive = makeDrive({ version: 'v3', auth });
      try {
        const r = await drive.files.get({ fileId: '$DRIVE_ROOT', fields: 'name, driveId, mimeType', supportsAllDrives: true });
        const driveId = r.data.driveId || '';
        const name = r.data.name || '';
        const mt = r.data.mimeType || '';
        console.log(JSON.stringify({ ok: true, name, driveId, mimeType: mt }));
      } catch (e) {
        console.log(JSON.stringify({ ok: false, message: e.message }));
      }
    " 2>/dev/null)"
    PROBE_OK="$(printf '%s' "$DRIVE_ROOT_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.ok?'1':'0'); } catch { console.log('?'); }" 2>/dev/null)"
    PROBE_DRIVE_ID="$(printf '%s' "$DRIVE_ROOT_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.driveId||''); } catch { console.log(''); }" 2>/dev/null)"
    PROBE_NAME="$(printf '%s' "$DRIVE_ROOT_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.name||''); } catch { console.log(''); }" 2>/dev/null)"
    PROBE_MSG="$(printf '%s' "$DRIVE_ROOT_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.message||''); } catch { console.log(''); }" 2>/dev/null)"
    if [ "$PROBE_OK" = "1" ]; then
      if [ -n "$PROBE_DRIVE_ID" ]; then
        pass "drive_shared: \"$PROBE_NAME\" lives on Shared Drive ($PROBE_DRIVE_ID)"
      else
        fail "drive_shared: \"$PROBE_NAME\" is in My Drive (no driveId) — every artifact write will fail with 'user storage quota exceeded'" "move the folder onto a Shared Drive that the SA is a member of, or set ACE_DRIVE_ROOT_FOLDER_ID to a folder that already lives on one"
      fi
    elif [ -n "$PROBE_MSG" ]; then
      warn "drive_shared: could not probe ACE_DRIVE_ROOT_FOLDER_ID: $PROBE_MSG" "verify the SA has Editor access to the folder; re-inject .env if the ID is stale"
    fi
  fi

  # Multi-run layout sanity: at least one <opp>/inputs/pdd.md should
  # exist under the Drive root. Without one, /ace:run zero-arg fires
  # the new-layout setup error. INFO (not WARN) — first-time installs
  # legitimately have nothing yet.
  if [ -n "$DRIVE_ROOT" ] && [ -n "$KEY" ] && [ -d "$ROOT/node_modules/@googleapis/drive" ]; then
    # cd "$ROOT" — see DRIVE_ROOT_PROBE above for the explanation.
    INPUTS_PROBE="$(cd "$ROOT" && GOOGLE_APPLICATION_CREDENTIALS="$KEY" node --input-type=module -e "
      import { drive as makeDrive } from '@googleapis/drive';
      import { GoogleAuth } from 'google-auth-library';
      const auth = new GoogleAuth({ keyFile: process.env.GOOGLE_APPLICATION_CREDENTIALS, scopes: ['https://www.googleapis.com/auth/drive'] });
      const drive = makeDrive({ version: 'v3', auth });
      try {
        const root = '$DRIVE_ROOT';
        const opps = await drive.files.list({
          q: \`'\${root}' in parents and mimeType='application/vnd.google-apps.folder' and trashed=false\`,
          fields: 'files(id,name)', supportsAllDrives: true, includeItemsFromAllDrives: true, pageSize: 100,
        });
        let count = 0;
        for (const opp of opps.data.files || []) {
          const inputs = await drive.files.list({
            q: \`'\${opp.id}' in parents and name='inputs' and mimeType='application/vnd.google-apps.folder' and trashed=false\`,
            fields: 'files(id)', supportsAllDrives: true, includeItemsFromAllDrives: true,
          });
          const inputsFolders = inputs.data.files || [];
          if (inputsFolders.length === 0) continue;
          const inputsId = inputsFolders[0].id;
          const pddCheck = await drive.files.list({
            q: \`'\${inputsId}' in parents and trashed=false\`,
            fields: 'files(id,name)', supportsAllDrives: true, includeItemsFromAllDrives: true, pageSize: 50,
          });
          const hasPdd = (pddCheck.data.files || []).some(f =>
            f.name === 'pdd.md' || f.name === 'pdd.gdoc' || /pdd/i.test(f.name)
          );
          if (hasPdd) count += 1;
        }
        console.log(JSON.stringify({ ok: true, count }));
      } catch (e) { console.log(JSON.stringify({ ok: false, message: String(e.message || e) })); }
    " 2>/dev/null)"
    INPUTS_OK="$(printf '%s' "$INPUTS_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.ok?'1':'0'); } catch { console.log('?'); }" 2>/dev/null)"
    INPUTS_COUNT="$(printf '%s' "$INPUTS_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.count||0); } catch { console.log('0'); }" 2>/dev/null)"
    INPUTS_MSG="$(printf '%s' "$INPUTS_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.message||''); } catch { console.log(''); }" 2>/dev/null)"
    if [ "$INPUTS_OK" = "1" ]; then
      if [ "$INPUTS_COUNT" -gt 0 ] 2>/dev/null; then
        pass "input_packs: $INPUTS_COUNT opp(s) under \$ACE_DRIVE_ROOT_FOLDER_ID have an inputs/ subfolder"
      else
        info "input_packs: no opps with inputs/ found yet — first-time setup, see /ace:run for the new-layout howto"
      fi
    else
      warn "input_packs: could not probe ACE_DRIVE_ROOT_FOLDER_ID for inputs/: $INPUTS_MSG" "verify the SA has Editor access to the Drive root and re-run /ace:doctor"
    fi
  fi

  # Shared collection triple — required by ocs-agent-setup for per-opp bot
  # clones to inherit Connect knowledge. Without these, cloned bots publish
  # with empty RAG and silently answer from base LLM only.
  # (2026-04-20 run log P1 backlog; see learnings.md "Metadata files as hypotheses".)
  if [ -n "$SHARED_COLL" ] && [ -n "$LLM_PROV" ] && [ -n "$EMBED_MODEL" ]; then
    pass "ocs_shared_collection: id=$SHARED_COLL provider=$LLM_PROV embedding=$EMBED_MODEL"
  else
    sc_missing=""
    [ -z "$SHARED_COLL" ] && sc_missing="$sc_missing OCS_SHARED_COLLECTION_ID"
    [ -z "$LLM_PROV" ] && sc_missing="$sc_missing OCS_LLM_PROVIDER_ID"
    [ -z "$EMBED_MODEL" ] && sc_missing="$sc_missing OCS_EMBEDDING_MODEL_ID"
    warn "ocs_shared_collection: missing or unresolved:$sc_missing (per-opp bots will have empty RAG)" "re-inject .env via op inject (vars added in 0.5.1)"
  fi

  # Team-membership probe: confirm OCS_SHARED_COLLECTION_ID actually lives on
  # OCS_TEAM_SLUG. The check above only verifies the env var is set; it would
  # PASS even when the ID points at a different team's collection — which is
  # exactly what happened in the 2026-04-27 turmeric-dogfood run, where the
  # configured 350 belonged to "NM Bot" on a different team. Cloned per-opp
  # bots silently inherited the wrong domain's RAG. (canopy session-review
  # finding #5, 2026-04-28 cycle.)
  #
  # Probe: GET /a/$TEAM/documents/collections/$ID with the Playwright session
  # cookie. 200 = collection lives on this team. 404 = it doesn't. 302 = the
  # session is expired (already warned by the ocs_session check below; skip).
  if [ -n "$SHARED_COLL" ] && [ -n "$OCS_TEAM" ] && [ -n "$OCS_BASE" ]; then
    SC_SESS="$HOME/.ace/ocs-session-$OCS_TEAM.json"
    if [ -f "$SC_SESS" ]; then
      SC_COOKIES="$(node -e "
        try {
          const s = JSON.parse(require('fs').readFileSync('$SC_SESS','utf8'));
          const cs = (s.cookies || []).filter(c => c.name === 'sessionid' || c.name === 'csrftoken');
          process.stdout.write(cs.map(c => c.name + '=' + c.value).join('; '));
        } catch(_) {}
      " 2>/dev/null)"
      if [ -n "$SC_COOKIES" ]; then
        SC_STATUS="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 3 -b "$SC_COOKIES" "$OCS_BASE/a/$OCS_TEAM/documents/collections/$SHARED_COLL" 2>/dev/null)"
        case "$SC_STATUS" in
          200)
            pass "ocs_shared_collection_team: collection $SHARED_COLL exists on team $OCS_TEAM"
            ;;
          404)
            warn "ocs_shared_collection_team: collection $SHARED_COLL does NOT exist on team $OCS_TEAM (cloned per-opp bots will fail to attach RAG, or attach a different team's collection)" "open $OCS_BASE/a/$OCS_TEAM/documents/ in the OCS UI; pick a collection that belongs to this team and update OCS_SHARED_COLLECTION_ID in $ENV_FILE"
            ;;
          301|302)
            : # session expired — ocs_session check below already warns
            ;;
          000|"")
            : # network error — silent; not the probe's job to flag
            ;;
          *)
            warn "ocs_shared_collection_team: probe returned HTTP $SC_STATUS for collection $SHARED_COLL on team $OCS_TEAM" "verify $OCS_BASE reachable; refresh session via /ace:ocs-login"
            ;;
        esac
      fi
    fi
  fi

  if [ -n "$GMAIL_ACCT" ]; then
    pass "gmail_config: ACE_GMAIL_ACCOUNT=$GMAIL_ACCT"
  else
    warn "gmail_config: ACE_GMAIL_ACCOUNT not set" "re-inject .env via 1Password"
  fi

  # Catch-all: any future .env.tpl addition that the installed .env hasn't
  # picked up yet. Diff the KEY= sets; warn with a single line listing
  # whatever is missing. Informational — WARN, not FAIL (per learnings.md
  # "Runtime-health checks should be WARN, not FAIL").
  if [ -f "$ROOT/.env.tpl" ]; then
    TPL_KEYS="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ROOT/.env.tpl" 2>/dev/null | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
    ENV_KEYS="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ENV_FILE" 2>/dev/null | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
    ENV_DIFF="$(comm -23 <(printf '%s\n' "$TPL_KEYS") <(printf '%s\n' "$ENV_KEYS") | tr '\n' ' ' | sed 's/ *$//')"
    if [ -n "$ENV_DIFF" ]; then
      warn "env_drift: $ENV_FILE is missing keys from .env.tpl: $ENV_DIFF" "op inject -i \"$ROOT/.env.tpl\" -o \"$ENV_FILE\" --account dimagi.1password.com (preserves 1Password-backed values)"
    else
      pass "env_drift: $ENV_FILE has every key declared in .env.tpl"
    fi

    # Class-level preventer: any key declared in .env.tpl but with zero
    # consumers in actual code is dead ceremony — it gets injected, eats
    # a 1Password lookup, and adds a paste-this line nobody needs. Grep
    # every TPL_KEY against the code-bearing dirs; warn on any hit with
    # zero consumers. Docs (README/CHANGELOG/runs/playbook) don't count.
    # Added 0.5.7 after the bootstrap-output audit found three dead vars.
    UNUSED=""
    CODE_DIRS="mcp lib scripts skills bin hooks agents commands test"
    for key in $TPL_KEYS; do
      HITS="$(cd "$ROOT" && grep -rE "\\b$key\\b" $CODE_DIRS 2>/dev/null | head -1)"
      if [ -z "$HITS" ]; then
        UNUSED="$UNUSED $key"
      fi
    done
    UNUSED="$(printf '%s' "$UNUSED" | sed 's/^ //')"
    if [ -n "$UNUSED" ]; then
      warn "unused_env_keys: declared in .env.tpl but never read by code: $UNUSED" "drop them from .env.tpl, or wire them into a consumer (mcp/ lib/ scripts/ skills/ bin/ hooks/ agents/ commands/ test/)"
    else
      pass "unused_env_keys: every .env.tpl key has at least one consumer"
    fi
  fi

  # OCS Playwright session — keyed by team slug. The Playwright backend
  # auto-logs-in via OCS_USERNAME / OCS_PASSWORD when no saved session
  # exists, so a missing file is fine as long as creds are configured.
  # /ace:ocs-login is the manual fallback for SSO/MFA accounts.
  if [ -n "$OCS_TEAM" ]; then
    SESS="$HOME/.ace/ocs-session-$OCS_TEAM.json"
    OCS_USER="$(get_env OCS_USERNAME)"
    OCS_PASS="$(get_env OCS_PASSWORD)"
    HAS_CREDS=0
    [ -n "$OCS_USER" ] && [ -n "$OCS_PASS" ] && HAS_CREDS=1
    if [ -f "$SESS" ]; then
      # freshness check: 30-day cookie lifetime
      if find "$SESS" -mtime +30 2>/dev/null | grep -q .; then
        if [ "$HAS_CREDS" = "1" ]; then
          pass "ocs_session: $SESS >30 days old — auto-login will refresh on next call"
        else
          warn "ocs_session: $SESS is older than 30 days — may be expired" "/ace:ocs-login"
        fi
      else
        pass "ocs_session: $SESS present"
      fi
    else
      if [ "$HAS_CREDS" = "1" ]; then
        pass "ocs_session: not yet saved (auto-login on first call via OCS_USERNAME/OCS_PASSWORD)"
      else
        warn "ocs_session: $SESS missing and OCS_USERNAME/OCS_PASSWORD unset" "/ace:setup or /ace:ocs-login"
      fi
    fi
  else
    # No team slug — can't check for a session file. Already warned on ocs_env.
    :
  fi

  # ── Connect (ace-connect MCP) ───────────────────────────────────────
  CONNECT_BASE="$(get_env CONNECT_BASE_URL)"
  HQ_USER="$(get_env ACE_HQ_USERNAME)"
  HQ_PASS="$(get_env ACE_HQ_PASSWORD)"

  if [ -n "$CONNECT_BASE" ] && [ -n "$HQ_USER" ] && [ -n "$HQ_PASS" ]; then
    pass "connect_env: base=$CONNECT_BASE hq_user=$HQ_USER hq_password=<set>"
  else
    cm=""
    [ -z "$CONNECT_BASE" ] && cm="$cm CONNECT_BASE_URL"
    [ -z "$HQ_USER" ] && cm="$cm ACE_HQ_USERNAME"
    [ -z "$HQ_PASS" ] && cm="$cm ACE_HQ_PASSWORD"
    warn "connect_env: missing or unresolved:$cm" "re-inject .env via op inject (vars added in 0.8.0)"
  fi

  # ACE_HQ_DOMAIN — the CommCare HQ project space ace@dimagi-ai.com uploads
  # apps to. Default and only sanctioned value: connect-ace-prod. A different
  # value silently routes Nova uploads to the wrong project space; the apps
  # build but Phase 3 connect-setup can't bind them. Item 1 of the turmeric
  # run_time_followups (0.10.29).
  HQ_DOMAIN="$(get_env ACE_HQ_DOMAIN)"
  if [ -z "$HQ_DOMAIN" ]; then
    warn "hq_domain: ACE_HQ_DOMAIN not set (Nova app uploads will fall back; expected connect-ace-prod)" "add ACE_HQ_DOMAIN=connect-ace-prod to 1Password and re-inject .env"
  elif [ "$HQ_DOMAIN" = "connect-ace-prod" ]; then
    pass "hq_domain: ACE_HQ_DOMAIN=$HQ_DOMAIN"
  else
    warn "hq_domain: ACE_HQ_DOMAIN=$HQ_DOMAIN (expected connect-ace-prod)" "if intentional override, ignore; otherwise update .env to ACE_HQ_DOMAIN=connect-ace-prod"
  fi

  # Connect session file. Created by /ace:connect-login OR refreshed silently
  # by hq-oauth-login.ts when ACE_HQ_USERNAME/PASSWORD are set in .env.
  CONNECT_SESS="$HOME/.ace/connect-session.json"
  if [ -f "$CONNECT_SESS" ]; then
    AGE_S="$(($(date +%s) - $(stat -f %m "$CONNECT_SESS" 2>/dev/null || stat -c %Y "$CONNECT_SESS" 2>/dev/null || echo 0)))"
    AGE_H="$((AGE_S / 3600))"
    if [ "$AGE_H" -lt 24 ]; then
      pass "connect_session: $CONNECT_SESS (age ${AGE_H}h)"
    else
      warn "connect_session: $CONNECT_SESS is ${AGE_H}h old — may be stale" "automated re-login will run on first MCP call if HQ creds are set; otherwise /ace:connect-login"
    fi
  elif [ -n "$HQ_USER" ] && [ -n "$HQ_PASS" ]; then
    pass "connect_session: not present (will auto-login from .env on first call)"
  else
    warn "connect_session: $CONNECT_SESS missing and no HQ creds in .env" "/ace:connect-login OR set ACE_HQ_USERNAME/PASSWORD"
  fi

  # Connect REST CSRF probe (added 0.13.17, CL-2). After 0.13.15's
  # bottom-out reauth shipped, the leep-paint-collection 2026-05-05 e2e
  # run STILL hit `403 CSRF Failed` on `POST /api/programs/<uuid>/opportunities/`
  # even after a full session.invalidate() + hqOAuthLogin rebuild
  # (runs/20260505-1505/3-connect/connect-opp-setup_BLOCKED.md). That
  # means the bottoming-out invariant the 0.13.15 retry promised is
  # violated for some Connect-side state we don't yet understand.
  #
  # This probe deliberately POSTs an EMPTY body to /api/programs/ with
  # the live session's sessionid + csrftoken (cookie + X-CSRFToken
  # header). A healthy session should return 400 (DRF validation
  # error: missing required fields). If the response is 403 with a
  # body that mentions CSRF, the same class of failure that blocked
  # leep is live RIGHT NOW — surface it loudly at /ace:doctor time so
  # the operator doesn't burn a phase debugging it.
  #
  # WARN-level (not FAIL): doctor-green should NOT require live Connect
  # auth on every install; this only runs when the session file exists.
  if [ -f "$CONNECT_SESS" ] && [ -n "$CONNECT_BASE" ] && command -v curl >/dev/null 2>&1; then
    CONNECT_PROBE_HEADERS="$(node -e "
      try {
        const s = JSON.parse(require('fs').readFileSync('$CONNECT_SESS','utf8'));
        const host = new URL('$CONNECT_BASE').hostname;
        const sid = (s.cookies || []).find(c => c.name === 'sessionid' && (c.domain || '').includes(host));
        const csrf = (s.cookies || []).find(c => c.name === 'csrftoken' && (c.domain || '').includes(host));
        if (!sid || !csrf) { process.exit(0); }
        const cookieHdr = 'sessionid=' + sid.value + '; csrftoken=' + csrf.value;
        process.stdout.write(JSON.stringify({ cookie: cookieHdr, csrf: csrf.value }));
      } catch(_) {}
    " 2>/dev/null)"
    if [ -n "$CONNECT_PROBE_HEADERS" ]; then
      PROBE_COOKIE="$(printf '%s' "$CONNECT_PROBE_HEADERS" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); process.stdout.write(d.cookie||''); } catch(_) {}")"
      PROBE_CSRF="$(printf '%s' "$CONNECT_PROBE_HEADERS" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); process.stdout.write(d.csrf||''); } catch(_) {}")"
      # POST empty body. Healthy: 400 (DRF "this field is required"). Bug: 403 + CSRF.
      PROBE_TMP="$(mktemp -t ace-doctor-connect-probe.XXXXXX 2>/dev/null || mktemp)"
      PROBE_STATUS="$(curl -sS -o "$PROBE_TMP" -w '%{http_code}' --max-time 5 \
        -X POST \
        -H "Cookie: $PROBE_COOKIE" \
        -H "X-CSRFToken: $PROBE_CSRF" \
        -H "Referer: $CONNECT_BASE/" \
        -H "Content-Type: application/json" \
        -d '{}' \
        "$CONNECT_BASE/api/programs/" 2>/dev/null || echo "000")"
      PROBE_BODY="$(head -c 200 "$PROBE_TMP" 2>/dev/null)"
      rm -f "$PROBE_TMP" 2>/dev/null
      case "$PROBE_STATUS" in
        400)
          pass "connect_csrf_probe: POST /api/programs/ (empty body) → 400 (session healthy, CSRF accepted)"
          ;;
        403)
          if printf '%s' "$PROBE_BODY" | grep -qi 'CSRF'; then
            fail "connect_csrf_probe: POST /api/programs/ → 403 CSRF — same shape as leep-20260505-1505 BLOCKED. Body: ${PROBE_BODY:0:200}" "/ace:connect-login to manually rebuild session; if that doesn't recover, the 0.13.15 bottom-out invariant is violated and the MCP retry path won't self-heal"
          else
            warn "connect_csrf_probe: POST /api/programs/ → 403 (non-CSRF body — likely permission denial). Body: ${PROBE_BODY:0:200}" "verify ace@dimagi-ai.com is still in a program-manager org"
          fi
          ;;
        401)
          warn "connect_csrf_probe: POST /api/programs/ → 401 (session anon). Body: ${PROBE_BODY:0:200}" "/ace:connect-login to rebuild session"
          ;;
        000)
          warn "connect_csrf_probe: cannot reach $CONNECT_BASE/api/programs/ (network/timeout)" "verify $CONNECT_BASE reachable"
          ;;
        2*|201)
          # Unlikely (we sent an empty body), but if Connect somehow accepted
          # it, surface as INFO — still indicates session+CSRF were accepted.
          info "connect_csrf_probe: POST /api/programs/ → $PROBE_STATUS (unexpected success on empty body — session accepted CSRF)"
          ;;
        *)
          info "connect_csrf_probe: POST /api/programs/ → $PROBE_STATUS (not 400/403/401; non-diagnostic). Body: ${PROBE_BODY:0:200}"
          ;;
      esac
    fi
  fi

  # ── Connect Labs (solicitations / reviews / awards) ──────────────────
  # ACE consumes labs.connect.dimagi.com/mcp/ via the connect-labs stdio
  # proxy (mcp/connect-labs-server.ts). Three checks:
  #   1. LABS_MCP_TOKEN present in .env (drift detection)
  #   2. Labs MCP reachable + PAT accepted (initialize JSON-RPC frame)
  #   3. Connect OAuth bridge live (list_solicitations distinguishes
  #      PAT-level 401 from tool-level PERMISSION_DENIED)
  LABS_TOKEN="$(get_env LABS_MCP_TOKEN)"
  LABS_URL="${LABS_MCP_URL:-https://labs.connect.dimagi.com/mcp/}"
  if [ -z "$LABS_TOKEN" ]; then
    warn "connect_labs_env: LABS_MCP_TOKEN missing or unresolved" "re-inject .env via op inject (ACE - Connect Labs item in 1Password)"
  else
    pass "connect_labs_env: LABS_MCP_TOKEN present"
    # Probe 1: PAT validity. POST an initialize frame; expect 200 (or any 2xx).
    # 401 means PAT bad/revoked; timeout means labs is down.
    LABS_REACH_CODE="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 \
      -X POST \
      -H "Authorization: Bearer $LABS_TOKEN" \
      -H "Content-Type: application/json" \
      -d '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{},"clientInfo":{"name":"ace-doctor","version":"1"}}}' \
      "$LABS_URL" 2>/dev/null || echo "000")"
    case "$LABS_REACH_CODE" in
      2*)
        pass "connect_labs_mcp_reachable: $LABS_URL (HTTP $LABS_REACH_CODE)"
        # Probe 2: Connect OAuth bridge. Call list_solicitations and look at
        # the response body for tool-level PERMISSION_DENIED (which means
        # PAT is good but the labs user hasn't completed Connect OAuth).
        LABS_OAUTH_BODY="$(curl -sS --max-time 5 \
          -X POST \
          -H "Authorization: Bearer $LABS_TOKEN" \
          -H "Content-Type: application/json" \
          -d '{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"list_solicitations","arguments":{}}}' \
          "$LABS_URL" 2>/dev/null || echo "")"
        if echo "$LABS_OAUTH_BODY" | grep -q "PERMISSION_DENIED\|connect_oauth\|ConnectTokenError"; then
          warn "connect_labs_connect_oauth: PAT accepted but Connect OAuth bridge missing for ace@dimagi-ai.com" "have ace@dimagi-ai.com sign into labs once and authorize Connect"
        elif echo "$LABS_OAUTH_BODY" | grep -q '"error"'; then
          warn "connect_labs_connect_oauth: list_solicitations returned an error" "inspect response: $LABS_OAUTH_BODY"
        else
          pass "connect_labs_connect_oauth: list_solicitations responded (Connect OAuth bridge live)"
        fi
        ;;
      401)
        warn "connect_labs_mcp_reachable: HTTP 401 — PAT invalid or revoked" "rotate via mcp_create_token --user ace@dimagi-ai.com --name ACE-plugin --ttl-days 0"
        ;;
      000)
        warn "connect_labs_mcp_reachable: cannot reach $LABS_URL (network/DNS/timeout)" "verify labs.connect.dimagi.com is up and reachable from this network"
        ;;
      *)
        warn "connect_labs_mcp_reachable: $LABS_URL returned HTTP $LABS_REACH_CODE" "investigate labs MCP health"
        ;;
    esac
  fi

  # ── Nova (CommCare app builder MCP) ──────────────────────────────────
  # Presence check only — live HTTP probe runs in [Auth liveness] below.
  # Drift detection: if NOVA_API_KEY is missing or unresolved (still
  # `op://...`), bin/ace-setup's user-scope MCP override will be skipped
  # and /nova:* falls back to OAuth — broken under concurrent worktrees.
  NOVA_KEY_VAL="$(get_env NOVA_API_KEY)"
  if [ -z "$NOVA_KEY_VAL" ]; then
    warn "nova_env: NOVA_API_KEY missing or unresolved" "mint at https://commcare.app/settings as the ACE Gmail identity, save to 1Password item \"ACE - Nova\" / field \`api_key\`, then /ace:setup --force-env"
  else
    pass "nova_env: NOVA_API_KEY present"
  fi

  # ── CommCare HQ REST API key (used by ace-connect for CCHQ atoms) ────
  # Presence check only — live HTTP probe runs in [Auth liveness] below.
  # Distinct from NOVA_API_KEY (which is the Nova MCP bearer) and from
  # connect_session cookies (which are OAuth-via-CCHQ session state).
  # ACE_HQ_API_KEY is the long-lived REST key Connect's
  # `connect_create_opportunity` and friends use to read app metadata
  # from CCHQ during opportunity wiring. Pre-0.13.122 the dead-key
  # class was invisible until two phases deep into a /ace:run; the
  # liveness probe below catches it pre-flight.
  HQ_KEY_VAL="$(get_env ACE_HQ_API_KEY)"
  if [ -z "$HQ_KEY_VAL" ]; then
    warn "hq_api_key_env: ACE_HQ_API_KEY missing or unresolved" "mint at https://www.commcarehq.org/account/api_keys/ as ace@dimagi-ai.com, save to 1Password item \"ACE - CommCare HQ API Key (connect-ace-prod)\" / field \`credential\`, then op inject -i .env.tpl -o \$CLAUDE_PLUGIN_DATA/.env --force --account dimagi.1password.com"
  else
    pass "hq_api_key_env: ACE_HQ_API_KEY present"
  fi
else
  # No .env at all — individual env-derived checks would all warn the same way.
  # Emit one consolidated pointer instead of three duplicates.
  warn "runtime_env: ocs_env, gmail_config, ocs_session, connect_env, connect_labs_env, nova_env all skipped (no .env)" "resolve env_file warning above first"
fi

echo ""
echo "[Network reachability]"
# Anonymous probes against each host ACE talks to. Catches corporate
# VPN/proxy issues before they masquerade as auth bugs in the
# [Auth liveness] block below. Each probe is a single GET with a 3s
# timeout. We accept any HTTP status (4xx/5xx still proves DNS+TLS work);
# only a literal 000 (curl couldn't connect) is a failure here.
if command -v curl >/dev/null 2>&1; then
  for entry in \
      "openchatstudio:https://www.openchatstudio.com/" \
      "connect:https://connect.dimagi.com/" \
      "commcarehq:https://www.commcarehq.org/" \
      "labs:https://labs.connect.dimagi.com/" \
      "nova_mcp:https://mcp.commcare.app/" \
      "googleapis:https://www.googleapis.com/"; do
    name="${entry%%:*}"
    url="${entry#*:}"
    # curl's `-w '%{http_code}'` already prints 000 on connection failure
    # (DNS, refused, timeout) — the trailing `|| echo "000"` is redundant
    # AND harmful: when curl exits non-zero, both the -w "000" and the
    # echo "000" land in the substitution, producing "000000" which
    # falls through the case match below. The empty-fallback only fires
    # if curl is missing entirely.
    #
    # Retries: 1 retry × 1s delay catches transient network blips
    # (Wi-Fi reconnect, DNS hiccup, VPN renegotiation) that one-shot
    # curls from bash hit but persistent MCP subprocess connections
    # don't. Bounded at 2 attempts × ~3s ≈ 7s per host.
    status="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 3 \
      --retry 1 --retry-delay 1 --retry-all-errors --retry-connrefused \
      "$url" 2>/dev/null)"
    [ -z "$status" ] && status="000"
    case "$status" in
      000)
        warn "net_$name: cannot reach $url (timeout/DNS/connection refused)" "check VPN/proxy; if you're on a corp network, ask IT to allow $url"
        ;;
      *)
        pass "net_$name: $url → HTTP $status (reachable)"
        ;;
    esac
  done
else
  warn "net_reachability: curl not on PATH — skipped" "install curl"
fi

echo ""
echo "[Auth liveness]"
# Single-screen view of "which MCPs can actually authenticate right now?"
# Each probe issues ONE cheap, idempotent HTTP call against the live system
# the MCP talks to. PASS = the cred works today. WARN = expired/missing —
# remediation hint names the exact command to fix it. Useful for the
# 2-machine workflow where session cookies are per-machine and need
# re-login on each workstation, but the static `.env` is 1Password-backed.
#
# Existing live probes elsewhere in this output (drive_shared, ocs_shared_collection_team,
# connect_csrf_probe, connect_labs_mcp_reachable, connect_labs_connect_oauth)
# stay where they are — those are context-specific. This block is the
# always-on per-MCP auth liveness summary.

# 1. ace-gdrive — service-account about.get
# Always on if SA key is present; doesn't depend on ACE_DRIVE_ROOT_FOLDER_ID.
if [ -n "$KEY" ] && [ -d "$ROOT/node_modules/@googleapis/drive" ]; then
  # cd "$ROOT" so the inline `import` from '@googleapis/drive' resolves
  # against the plugin's node_modules instead of whatever CWD doctor was
  # invoked from. Without this, an /ace:doctor run from outside the plugin
  # dir silently fails the import (stderr suppressed by 2>/dev/null) and
  # the probe falls through with an empty error message.
  GDRIVE_AUTH_PROBE="$(cd "$ROOT" && GOOGLE_APPLICATION_CREDENTIALS="$KEY" node --input-type=module -e "
    import { drive as makeDrive } from '@googleapis/drive';
    import { GoogleAuth } from 'google-auth-library';
    const auth = new GoogleAuth({ keyFile: process.env.GOOGLE_APPLICATION_CREDENTIALS, scopes: ['https://www.googleapis.com/auth/drive.metadata.readonly'] });
    const drive = makeDrive({ version: 'v3', auth });
    try {
      const r = await drive.about.get({ fields: 'user(emailAddress)' });
      console.log(JSON.stringify({ ok: true, email: r.data.user?.emailAddress || '' }));
    } catch (e) {
      console.log(JSON.stringify({ ok: false, message: e.message }));
    }
  " 2>/dev/null)"
  GDRIVE_OK="$(printf '%s' "$GDRIVE_AUTH_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.ok?'1':'0'); } catch { console.log('?'); }" 2>/dev/null)"
  GDRIVE_EMAIL="$(printf '%s' "$GDRIVE_AUTH_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.email||''); } catch { console.log(''); }" 2>/dev/null)"
  GDRIVE_MSG="$(printf '%s' "$GDRIVE_AUTH_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.message||''); } catch { console.log(''); }" 2>/dev/null)"
  if [ "$GDRIVE_OK" = "1" ]; then
    pass "gdrive_auth: ace-gdrive authed as $GDRIVE_EMAIL (drive.about.get)"
  else
    warn "gdrive_auth: drive.about.get failed: $GDRIVE_MSG" "rotate gws-sa-key.json in 1Password and re-run /ace:setup; verify the SA hasn't been disabled in Google Cloud Console"
  fi
else
  warn "gdrive_auth: skipped — gws_key missing or node_modules/@googleapis/drive not installed" "see gws_key warning above; npm ci if deps are missing"
fi

# 2. ace-ocs — GET /a/<team>/chatbots/ with session cookies, --max-redirs 0
# Same probe shape as mcp/ocs/auth/playwright-session.ts:isAuthenticated().
# 200 (and not /accounts/login/) = authed. 302 = expired.
if [ -n "$OCS_BASE" ] && [ -n "$OCS_TEAM" ]; then
  OCS_SESS="$HOME/.ace/ocs-session-$OCS_TEAM.json"
  if [ -f "$OCS_SESS" ]; then
    OCS_COOKIES="$(node -e "
      try {
        const s = JSON.parse(require('fs').readFileSync('$OCS_SESS','utf8'));
        const cs = (s.cookies || []).filter(c => c.name === 'sessionid' || c.name === 'csrftoken');
        process.stdout.write(cs.map(c => c.name + '=' + c.value).join('; '));
      } catch(_) {}
    " 2>/dev/null)"
    if [ -n "$OCS_COOKIES" ]; then
      OCS_AUTH_STATUS="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 --max-redirs 0 \
        -b "$OCS_COOKIES" "$OCS_BASE/a/$OCS_TEAM/chatbots/" 2>/dev/null || echo "000")"
      case "$OCS_AUTH_STATUS" in
        200)
          pass "ocs_auth: ace-ocs authed against team $OCS_TEAM (GET /a/$OCS_TEAM/chatbots/ → 200)"
          ;;
        301|302)
          warn "ocs_auth: ace-ocs session expired (HTTP $OCS_AUTH_STATUS — redirect to login)" "/ace:ocs-login (or set OCS_USERNAME/OCS_PASSWORD in .env so MCP auto-relogins)"
          ;;
        000)
          warn "ocs_auth: cannot reach $OCS_BASE (network/DNS/timeout)" "verify $OCS_BASE is reachable from this network"
          ;;
        *)
          warn "ocs_auth: GET /a/$OCS_TEAM/chatbots/ → HTTP $OCS_AUTH_STATUS" "/ace:ocs-login if this persists"
          ;;
      esac
    else
      warn "ocs_auth: $OCS_SESS exists but contains no sessionid/csrftoken cookies" "/ace:ocs-login to rebuild the session"
    fi
  else
    warn "ocs_auth: $OCS_SESS missing (no live probe possible)" "/ace:ocs-login (or set OCS_USERNAME/OCS_PASSWORD for headless auto-login)"
  fi
else
  warn "ocs_auth: skipped — OCS_BASE_URL or OCS_TEAM_SLUG not set in .env" "see ocs_env warning above"
fi

# 3. ace-connect — GET /accounts/login/ with connect.dimagi.com cookies, --max-redirs 0
# Mirrors mcp/connect/auth/playwright-session.ts:getContext() probe.
# 302 = authed (Connect bounces authed users away from the login form).
# 200 = anon (login form rendered).
if [ -n "$CONNECT_BASE" ] && [ -f "$CONNECT_SESS" ]; then
  CONNECT_HOST="$(printf '%s' "$CONNECT_BASE" | node -e "try { console.log(new URL(require('fs').readFileSync(0,'utf8').trim()).hostname); } catch { console.log(''); }" 2>/dev/null)"
  CONNECT_AUTH_COOKIES="$(node -e "
    try {
      const s = JSON.parse(require('fs').readFileSync('$CONNECT_SESS','utf8'));
      const host = '$CONNECT_HOST';
      const cs = (s.cookies || []).filter(c =>
        (c.name === 'sessionid' || c.name === 'csrftoken') &&
        (c.domain || '').includes(host)
      );
      process.stdout.write(cs.map(c => c.name + '=' + c.value).join('; '));
    } catch(_) {}
  " 2>/dev/null)"
  if [ -n "$CONNECT_AUTH_COOKIES" ]; then
    CONNECT_AUTH_STATUS="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 --max-redirs 0 \
      -b "$CONNECT_AUTH_COOKIES" "$CONNECT_BASE/accounts/login/" 2>/dev/null || echo "000")"
    case "$CONNECT_AUTH_STATUS" in
      301|302)
        pass "connect_auth: ace-connect authed (GET /accounts/login/ → $CONNECT_AUTH_STATUS, bounced away)"
        ;;
      200)
        warn "connect_auth: ace-connect session expired (login form rendered → anon)" "/ace:connect-login (or set ACE_HQ_USERNAME/PASSWORD for OAuth auto-relogin)"
        ;;
      000)
        warn "connect_auth: cannot reach $CONNECT_BASE (network/DNS/timeout)" "verify $CONNECT_BASE is reachable"
        ;;
      *)
        warn "connect_auth: GET $CONNECT_BASE/accounts/login/ → HTTP $CONNECT_AUTH_STATUS" "/ace:connect-login if this persists"
        ;;
    esac
  else
    warn "connect_auth: $CONNECT_SESS exists but contains no connect.dimagi.com sessionid/csrftoken" "/ace:connect-login to rebuild"
  fi
else
  if [ -z "$CONNECT_BASE" ]; then
    warn "connect_auth: skipped — CONNECT_BASE_URL not set in .env" "see connect_env warning above"
  else
    warn "connect_auth: skipped — $CONNECT_SESS missing" "/ace:connect-login OR set ACE_HQ_USERNAME/PASSWORD for headless OAuth"
  fi
fi

# 4. ace-connect (CCHQ side) — separate cookie jar, separate expiry clock.
# turmeric-20260505-1024 surfaced this: Connect cookies fresh while CCHQ
# rejected every commcare_* atom mid-run. Probe both independently.
if [ -f "$CONNECT_SESS" ]; then
  CCHQ_BASE="https://www.commcarehq.org"
  CCHQ_AUTH_COOKIES="$(node -e "
    try {
      const s = JSON.parse(require('fs').readFileSync('$CONNECT_SESS','utf8'));
      const cs = (s.cookies || []).filter(c =>
        (c.name === 'sessionid' || c.name === 'csrftoken') &&
        (c.domain || '').includes('commcarehq')
      );
      process.stdout.write(cs.map(c => c.name + '=' + c.value).join('; '));
    } catch(_) {}
  " 2>/dev/null)"
  if [ -n "$CCHQ_AUTH_COOKIES" ]; then
    CCHQ_AUTH_STATUS="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 --max-redirs 0 \
      -b "$CCHQ_AUTH_COOKIES" "$CCHQ_BASE/accounts/login/" 2>/dev/null || echo "000")"
    case "$CCHQ_AUTH_STATUS" in
      301|302)
        pass "cchq_auth: CCHQ session authed (GET $CCHQ_BASE/accounts/login/ → $CCHQ_AUTH_STATUS)"
        ;;
      200)
        warn "cchq_auth: CCHQ session expired even though Connect may be fresh (separate cookie clock)" "/ace:connect-login (the OAuth-via-CCHQ flow re-establishes both)"
        ;;
      000)
        warn "cchq_auth: cannot reach $CCHQ_BASE (network/DNS/timeout)" "verify CCHQ is reachable"
        ;;
      *)
        warn "cchq_auth: GET $CCHQ_BASE/accounts/login/ → HTTP $CCHQ_AUTH_STATUS" "/ace:connect-login if this persists"
        ;;
    esac
  else
    info "cchq_auth: no commcarehq cookies in $CONNECT_SESS (only Connect cookies — commcare_* atoms unavailable until /ace:connect-login runs the OAuth-via-CCHQ flow)"
  fi
else
  : # already warned above under connect_auth
fi

# 5. ace-connect (CCHQ REST API key) — separate auth mechanism from
# the cookies probed in #3+#4. ACE_HQ_API_KEY is the long-lived REST
# key Connect's `connect_create_opportunity` uses to fetch HQ app
# metadata when wiring an opp. Failure mode this catches: dead/rotated
# key produces "Failed to fetch apps from CommCare HQ." two phases
# into a /ace:run (~30 min wall-clock burn, observed turmeric
# 20260509-0455). One GET against CCHQ's application list endpoint:
# 200 = key valid, 401 = invalid/revoked, anything else = transport
# issue (covered by net_cchq probe above).
if [ -n "$HQ_KEY_VAL" ] && [ -n "$HQ_DOMAIN" ] && [ -n "$HQ_USER" ]; then
  # See net_reachability comment above for the curl `|| echo "000"`
  # double-fallback bug — same pattern, same fix. Pre-this-fix, a
  # connection failure here produced HTTP_PROBE_CODE="000000" which
  # fell through to the catch-all WARN.
  #
  # Endpoint switched 0.13.129: was GET /api/v0.5/application/?limit=1,
  # now GET /api/v0.5/user/?limit=1. Live timing on a fresh probe:
  # /application/ takes 5+ seconds (occasionally 10s+) on cold cache —
  # the response serializes the FULL app blueprint per row (modules,
  # forms, settings, fixtures) and a single row's JSON is 100KB+. ACE
  # only needs to know "is the API key valid?", which is settled in
  # tastypie's auth middleware before the view runs.
  # /user/?limit=1 is a small bounded query that returns 200 (auth ok)
  # in ~250ms or 401 (auth bad) in ~200ms. ~20x faster, same diagnosis.
  #
  # HEAD on /application/ was tried first (0.13.128 attempt) but tastypie
  # returns 405 for both good and bad keys before auth middleware runs,
  # so HEAD doesn't validate auth on this endpoint. HEAD on /user/ would
  # have the same problem — GET is the only method that goes through auth
  # for a useful diagnosis.
  #
  # 3s timeout (down from 5s): /user/?limit=1 should be under 500ms even
  # on slow links; 3s catches genuinely hung connections without burning
  # doctor wall-clock. cchq_auth + net_commcarehq above already cover
  # basic CCHQ reachability — if THIS probe still trips 000 while those
  # passed, the diagnosis is server-side endpoint slowness, not network.
  HQ_API_PROBE_CODE="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 3 \
    -H "Authorization: ApiKey $HQ_USER:$HQ_KEY_VAL" \
    "https://www.commcarehq.org/a/$HQ_DOMAIN/api/v0.5/user/?limit=1" 2>/dev/null)"
  [ -z "$HQ_API_PROBE_CODE" ] && HQ_API_PROBE_CODE="000"
  case "$HQ_API_PROBE_CODE" in
    2*)
      pass "hq_api_key_auth: ACE_HQ_API_KEY authed against $HQ_DOMAIN (GET /api/v0.5/user/ → HTTP $HQ_API_PROBE_CODE)"
      ;;
    401|403)
      warn "hq_api_key_auth: HTTP $HQ_API_PROBE_CODE — ACE_HQ_API_KEY invalid, revoked, or scoped to wrong domain ($HQ_DOMAIN). Connect's create_opportunity / set_verification_flags will fail mid-Phase-3 with \"Failed to fetch apps from CommCare HQ.\"" "mint a new HQ API key at https://www.commcarehq.org/account/api_keys/ as ace@dimagi-ai.com, update 1Password item \"ACE - CommCare HQ API Key (connect-ace-prod)\" field \`credential\`, then op inject -i .env.tpl -o \$CLAUDE_PLUGIN_DATA/.env --force --account dimagi.1password.com AND /reload-plugins so the ace-connect MCP picks up the new env"
      ;;
    000)
      # cchq_auth + net_commcarehq above already prove CCHQ is reachable
      # in this same doctor run — if THIS probe times out while those
      # passed, the right diagnosis is server-side endpoint slowness, not
      # network failure. Don't tell the operator their internet is down
      # when we just proved it isn't. Likely transient; recovery is to
      # re-run the doctor.
      warn "hq_api_key_auth: GET /api/v0.5/user/ did not complete in 3s (CCHQ basic reachability OK per cchq_auth/net_commcarehq above)" "transient — re-run /ace:doctor; if persists, the CCHQ API endpoint may be degraded (status.commcare.org)"
      ;;
    *)
      warn "hq_api_key_auth: GET /a/$HQ_DOMAIN/api/v0.5/user/ → HTTP $HQ_API_PROBE_CODE" "investigate; if persists, rotate the key per the recovery recipe above"
      ;;
  esac
elif [ -z "$HQ_KEY_VAL" ]; then
  warn "hq_api_key_auth: skipped — ACE_HQ_API_KEY not set" "see hq_api_key_env warning above"
elif [ -z "$HQ_DOMAIN" ]; then
  warn "hq_api_key_auth: skipped — ACE_HQ_DOMAIN not set" "see hq_domain warning above"
else
  warn "hq_api_key_auth: skipped — ACE_HQ_USERNAME not set" "see connect_env warning above"
fi

# 5b. ace-connect (CCHQ Connect-features project-space setup) — Phase 3
# + Phase 5 both fail confusingly when the target HQ project space
# hasn't been wired for CommCare Connect per the "Run Your First Connect
# Opportunity" doc (Confluence / GDrive 18Y1UQJW1aIwcgSt-Mt1Vze5pdQPAPs0I).
# Two required setup items, both check-able from the web UI with the
# CCHQ cookies the connect-login flow leaves behind:
#
#   (a) Feature flag `COMMCARE_CONNECT` enabled — gates the
#       `connect_username` permission CCHQ uses to recognize a
#       ConnectID-owned mobile worker. With it OFF, Connect's
#       `_create_hq_user` POST to `/a/<domain>/api/v0.5/user/` gets
#       400 `"You don't have permission to use connect_username field"`,
#       which `_create_hq_user` re-raises as `CommCareHQAPIException`,
#       which `start_learn_app` does NOT catch → Django 500.
#       The Android client correctly logs the failed response and
#       swallows it (the response shape isn't a structured JSON error),
#       so the opp-detail "Start" button appears to silently no-op
#       from the FLW's point of view. From the field this looks like
#       a client bug, but the actual cause is "feature flag not
#       enabled in the HQ project space."
#
#   (b) Active OAuth 2.0 Connection at /motech/conn/ pointing at
#       `https://connect.dimagi.com/api/receiver/` — required so CCHQ
#       can forward submitted forms back to Connect for verification +
#       payment. Without this, FLW submissions are never visible to
#       Connect, payment never accrues, and Phase 8 monitoring stalls.
#
# Both must be set up ONCE per HQ project space; ACE has no MCP atom
# to do this (the flag flip requires a Dimagi super-user; the OAuth
# client credentials live in 1Password "Connect Delivery / Tech").
# This probe surfaces missing setup so the operator can fix it BEFORE
# burning a /ace:run on a non-Connect-enabled project space.
#
# Diagnosis surfaced 2026-05-12 (turmeric run 20260511-2053):
# `connect-ace-prod` had `COMMCARE_CONNECT: false` AND the conn-setup
# page showed `<td>Deleted</td>` — two weeks of "phantom FLW-client
# noop" diagnoses on the selector map (2026-04-30 calibration note)
# were retracted by inspecting the actual project setup state.
# Tracking: CI-660 (https://dimagi.atlassian.net/browse/CI-660).
if [ -n "$HQ_DOMAIN" ] && [ -f "$CONNECT_SESS" ]; then
  CCHQ_BASE="https://www.commcarehq.org"
  CCHQ_PROBE_COOKIES="$(node -e "
    try {
      const s = JSON.parse(require('fs').readFileSync('$CONNECT_SESS','utf8'));
      const cs = (s.cookies || []).filter(c =>
        (c.name === 'sessionid' || c.name === 'csrftoken') &&
        (c.domain || '').includes('commcarehq')
      );
      process.stdout.write(cs.map(c => c.name + '=' + c.value).join('; '));
    } catch(_) {}
  " 2>/dev/null)"
  if [ -n "$CCHQ_PROBE_COOKIES" ]; then
    # The toggles_dict <div data-name="toggles_dict" ...> is embedded in
    # every project-settings page; we hit data-forwarding because it's
    # cheap and stable. grep for the COMMCARE_CONNECT flag value.
    CCHQ_FLAGS_HTML="$(curl -sS -L -b "$CCHQ_PROBE_COOKIES" --max-time 10 \
      "$CCHQ_BASE/a/$HQ_DOMAIN/motech/forwarding/" 2>/dev/null || echo "")"
    if [ -n "$CCHQ_FLAGS_HTML" ]; then
      # Parse the toggles_dict to extract the COMMCARE_CONNECT bool.
      # Live shape:  &quot;COMMCARE_CONNECT&quot;: true   (or false)
      CCHQ_CONNECT_FLAG="$(printf '%s' "$CCHQ_FLAGS_HTML" | grep -oE '&quot;COMMCARE_CONNECT&quot;: (true|false)' | head -1 | grep -oE '(true|false)$' || echo "unknown")"
    else
      CCHQ_CONNECT_FLAG="unreachable"
    fi

    # Check for an active Connection Settings entry. The /motech/conn/
    # listing page is rendered entirely client-side via Knockout (the
    # static HTML has the template but not the data), so a static curl
    # can't see the rows there. Instead, hit /motech/forwarding/new/FormRepeater/
    # and inspect the server-rendered `<select name="connection_settings_id">`
    # — if at least one <option> exists with a numeric value > 0, an
    # active connection exists. (The dropdown ONLY surfaces non-deleted
    # connections, so the presence of any option is a clean PASS signal.)
    CCHQ_CONN_HTML="$(curl -sS -L -b "$CCHQ_PROBE_COOKIES" --max-time 10 \
      "$CCHQ_BASE/a/$HQ_DOMAIN/motech/forwarding/new/FormRepeater/" 2>/dev/null || echo "")"
    CCHQ_CONN_OPTION_COUNT="$(printf '%s' "$CCHQ_CONN_HTML" | node -e "
      const s=require('fs').readFileSync(0,'utf8');
      const m=s.match(/<select[^>]*name=\"connection_settings_id\"[^>]*>([\\s\\S]*?)<\/select>/);
      if(!m){console.log(0);process.exit(0);}
      const opts=[...m[1].matchAll(/<option[^>]*value=\"([0-9]+)\"/g)];
      console.log(opts.length);
    " 2>/dev/null || echo "0")"
    CCHQ_CONN_TO_CONNECT="$CCHQ_CONN_OPTION_COUNT"
    # Detect prior 'Deleted' rows on the conn page just for the WARN
    # message — separately fetched, since the forwarder add page won't
    # show deleted entries.
    CCHQ_CONN_LISTING_HTML="$(curl -sS -L -b "$CCHQ_PROBE_COOKIES" --max-time 10 \
      "$CCHQ_BASE/a/$HQ_DOMAIN/motech/conn/" 2>/dev/null || echo "")"
    CCHQ_CONN_DELETED="$(printf '%s' "$CCHQ_CONN_LISTING_HTML" | grep -ciE '<td[^>]*>Deleted</td>' || true)"

    # (c) Check that a generic FormRepeater data-forwarding rule actually
    # exists under "Forward Forms", per the "Run Your First Connect
    # Opportunity" Confluence doc. The /motech/forwarding/ listing
    # renders one section per repeater type, each with a friendly-name
    # heading. When the section is empty the HTML has `You haven't
    # configured any services to forward to yet.` right after the
    # heading; when populated it has a <table> with the rule rows.
    # The signal: the absence of "haven't configured" text immediately
    # after our section heading = at least one rule exists.
    CCHQ_FWD_LIST_HTML="$CCHQ_FLAGS_HTML"  # same page already fetched above
    CCHQ_CONNECT_RULE_PRESENT="$(printf '%s' "$CCHQ_FWD_LIST_HTML" | node -e "
      const s=require('fs').readFileSync(0,'utf8');
      const heading = '>Forward Forms<';
      const i = s.indexOf(heading);
      if (i < 0) { console.log('0'); process.exit(0); }
      const after = s.slice(i, i + 2000);  // window past the heading
      const empty = /You haven't configured any services to forward to yet/.test(after);
      const populated = /<table/.test(after);
      console.log(empty ? '0' : (populated ? '1' : '0'));
    " 2>/dev/null || echo "0")"

    SETUP_DOC="GDrive 18Y1UQJW1aIwcgSt-Mt1Vze5pdQPAPs0I"
    REMED_FLAG="ask a Dimagi super-user to flip the COMMCARE_CONNECT feature flag ON for '$HQ_DOMAIN' (Settings → Feature Flags and Privileges → 'Enable CommCare Connect features...')"
    REMED_CONN="Settings → Project Settings → Connection Settings (Integration) → Add new connection → URL https://connect.dimagi.com/api/receiver/ → OAuth 2.0 Client Credentials Grant → Client ID/Secret from 1Password 'Connect Delivery / Tech' → Token URL https://connect.dimagi.com/o/token/ → Pass Credentials in header → Test Connection must return 200 'Connection successful'"
    REMED_RULE="Settings → Project Settings → Data Forwarding → **'Forward Forms'** section → 'Add a service to forward to' → select the connection from step (2) → name e.g. 'Forward Forms to Connect' → HTTP Request Method POST → **Payload Format JSON** → **Include 'app_id' URL query parameter ✅** → leave Users to exclude + XMLNSes blank → Start Forwarding."
    REMEDIATION_ALL="enable the feature flag + configure the OAuth connection + add the data-forwarding rule per the 'Run Your First Connect Opportunity' doc ($SETUP_DOC). Concretely: (1) $REMED_FLAG. (2) $REMED_CONN. (3) $REMED_RULE."

    if [ "$CCHQ_CONNECT_FLAG" = "true" ] && [ "$CCHQ_CONN_TO_CONNECT" -gt 0 ] && [ "$CCHQ_CONNECT_RULE_PRESENT" = "1" ]; then
      pass "cchq_connect_features: COMMCARE_CONNECT flag enabled on '$HQ_DOMAIN', OAuth connection to connect.dimagi.com configured, AND a 'Forward Forms' rule (FormRepeater) is active"
    elif [ "$CCHQ_CONNECT_FLAG" = "unreachable" ] || [ "$CCHQ_CONNECT_FLAG" = "unknown" ]; then
      warn "cchq_connect_features: could not read toggles_dict from $CCHQ_BASE/a/$HQ_DOMAIN/motech/forwarding/ (cookies may be stale or project access may be missing for ace@dimagi-ai.com)" "/ace:connect-login to refresh the CCHQ session; then re-run /ace:doctor. If the cookies refresh and this probe still can't see the flag, the project may not exist or the user lacks access."
    elif [ "$CCHQ_CONNECT_FLAG" = "false" ] && [ "$CCHQ_CONN_TO_CONNECT" -eq 0 ]; then
      warn "cchq_connect_features: NONE of the 3 setup items configured on '$HQ_DOMAIN' (flag OFF, no OAuth conn, no data-forwarding rule) — Phase 3 (opp create + payment-unit sync) will partially succeed, Phase 5 (Learn-app launch on AVD) will fail with the 'silent FLW-client noop' symptom because /users/start_learn_app/ returns Django 500 (CommCareHQAPIException uncaught), and form submissions in Phase 5/8 will never reach Connect for verification/payment" "$REMEDIATION_ALL"
    elif [ "$CCHQ_CONNECT_FLAG" = "false" ]; then
      warn "cchq_connect_features: COMMCARE_CONNECT feature flag is OFF on '$HQ_DOMAIN' — /users/start_learn_app/ will 500 because CCHQ rejects the connect_username field (gated by this flag), and the Connect Android client logs+swallows the failed response so the opp-detail 'Start' button appears to silently no-op. OAuth connection IS present; only the flag is missing." "$REMED_FLAG. Full setup doc: $SETUP_DOC."
    elif [ "$CCHQ_CONN_TO_CONNECT" -eq 0 ]; then
      DELETED_HINT=""
      [ "$CCHQ_CONN_DELETED" -gt 0 ] && DELETED_HINT=" (page shows a '<td>Deleted</td>' row — a prior connection was removed)"
      warn "cchq_connect_features: OAuth connection from '$HQ_DOMAIN' to https://connect.dimagi.com/api/receiver/ is missing${DELETED_HINT} — feature flag IS enabled, so claim+Learn-app launch will work, but FLW form submissions from the Deliver app will not reach Connect for verification/payment, breaking Phase 8 monitoring" "$REMED_CONN. Then $REMED_RULE. Full setup doc: $SETUP_DOC."
    elif [ "$CCHQ_CONNECT_RULE_PRESENT" != "1" ]; then
      warn "cchq_connect_features: no active rule on '$HQ_DOMAIN' under 'Forward Forms' — feature flag + OAuth connection are configured, but without the data-forwarding rule, FLW form submissions from the Deliver app will not reach Connect for verification/payment." "$REMED_RULE. Full setup doc: $SETUP_DOC."
    fi
  else
    info "cchq_connect_features: skipped — no CCHQ cookies in $CONNECT_SESS (covered by cchq_auth warning above). Re-run /ace:connect-login so the OAuth-via-CCHQ flow leaves valid commcarehq.org cookies, then re-run /ace:doctor."
  fi
else
  if [ -z "$HQ_DOMAIN" ]; then
    warn "cchq_connect_features: skipped — ACE_HQ_DOMAIN not set (see hq_domain warning above)" "set ACE_HQ_DOMAIN in .env and re-run"
  else
    warn "cchq_connect_features: skipped — $CONNECT_SESS missing (see connect_auth warning above)" "/ace:connect-login first; then this probe will tell you whether the HQ project space is wired for Connect"
  fi
fi

# 6. ace-connect-labs — already covered by connect_labs_mcp_reachable +
# connect_labs_connect_oauth above; reference here so the auth-liveness
# block reads as a complete inventory.
if [ -n "$LABS_TOKEN" ]; then
  info "labs_auth: see connect_labs_mcp_reachable + connect_labs_connect_oauth above (live PAT + OAuth-bridge probes already run)"
else
  warn "labs_auth: skipped — LABS_MCP_TOKEN not set" "see connect_labs_env warning above; mint via /ace:labs-token-mint and re-inject .env"
fi

# 7. nova — POST initialize JSON-RPC frame to https://mcp.commcare.app/mcp
# with bearer auth. 200 = NOVA_API_KEY value is accepted by the Nova MCP
# server; 401 = key invalid/revoked. This is an HTTP-only probe — it
# does not verify Claude Code's plugin MCP entry is reading the same key
# (that's covered by `nova_shell_env` below). The Accept header includes
# text/event-stream because Nova returns SSE frames for the response
# body even though the request is plain JSON.
#
# Retries: 2 retries × 1s delay catch transient network blips (Wi-Fi
# reconnect, DNS hiccup, VPN renegotiation) that a one-shot 5s curl
# from bash hits but the persistent MCP subprocess connection does not.
# Worst case ~18s before WARN. Source: select-session feedback that
# nova_auth WARNed while the live MCP subprocess was healthy.
if [ -n "$NOVA_KEY_VAL" ]; then
  NOVA_REACH_CODE="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 5 \
    --retry 2 --retry-delay 1 --retry-all-errors --retry-connrefused \
    -X POST \
    -H "Authorization: Bearer $NOVA_KEY_VAL" \
    -H "Content-Type: application/json" \
    -H "Accept: application/json, text/event-stream" \
    -d '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{},"clientInfo":{"name":"ace-doctor","version":"1"}}}' \
    "https://mcp.commcare.app/mcp" 2>/dev/null || echo "000")"
  case "$NOVA_REACH_CODE" in
    2*)
      pass "nova_auth: ace-nova authed (POST initialize → HTTP $NOVA_REACH_CODE)"
      ;;
    401)
      warn "nova_auth: HTTP 401 — NOVA_API_KEY invalid or revoked" "rotate at https://commcare.app/settings, update 1Password item \"ACE - Nova\" / field \`api_key\`, then /ace:setup --force-env"
      ;;
    000)
      warn "nova_auth: cannot reach https://mcp.commcare.app/mcp (network/DNS/timeout)" "check VPN/proxy; net_nova_mcp probe above should also flag this"
      ;;
    *)
      warn "nova_auth: POST https://mcp.commcare.app/mcp → HTTP $NOVA_REACH_CODE" "investigate Nova MCP health"
      ;;
  esac
else
  warn "nova_auth: skipped — NOVA_API_KEY not set" "see nova_env warning above; mint at https://commcare.app/settings"
fi

# 7b. nova_shell_env — verify NOVA_API_KEY is in the Claude Code parent
# shell's env. Nova plugin v1.1.0's .mcp.json uses a headersHelper that
# reads NOVA_API_KEY from the process env; without it in the shell, the
# helper emits `{}` and every Nova call 401s. ACE's .env is loaded only
# into ACE's own MCP subprocesses, so the operator must source
# ~/.ace/env.sh from their shell rc once per machine.
#
# Also flag (and remove) any leftover user-scope `nova:` MCP override
# from the pre-1.1.0 setup — that entry shadows the plugin's PAT-aware
# entry under Claude Code's URL-dedup and re-introduces the identity
# divergence Braxton fixed in voidcraft-labs/nova-plugin#11 / #13.
# Determine which rc file ACE's auto-append targets on this machine
# (matches the picker in bin/ace-setup). Used to give a precise
# remediation when the marker block is missing or present-but-not-applied.
NOVA_RC_FILE=""
NOVA_OS_NAME="$(uname -s 2>/dev/null)"
NOVA_SHELL_NAME="$(basename "${SHELL:-/bin/sh}")"
case "$NOVA_OS_NAME:$NOVA_SHELL_NAME" in
  Darwin:zsh)  NOVA_RC_FILE="$HOME/.zshenv" ;;
  Darwin:bash) NOVA_RC_FILE="$HOME/.bash_profile" ;;
  Linux:zsh)   NOVA_RC_FILE="$HOME/.zshrc" ;;
  Linux:bash)  NOVA_RC_FILE="$HOME/.bashrc" ;;
esac
NOVA_MARKER_PRESENT=0
if [ -n "$NOVA_RC_FILE" ] && [ -f "$NOVA_RC_FILE" ] && grep -qF "# >>> ACE managed >>>" "$NOVA_RC_FILE" 2>/dev/null; then
  NOVA_MARKER_PRESENT=1
fi

if [ -n "${NOVA_API_KEY:-}" ]; then
  pass "nova_shell_env: NOVA_API_KEY present in shell env (Nova plugin headersHelper will authenticate)"
elif [ -z "$NOVA_KEY_VAL" ]; then
  warn "nova_shell_env: skipped — NOVA_API_KEY not set in ACE .env either" "see nova_env warning above"
elif [ "$NOVA_MARKER_PRESENT" = "1" ]; then
  warn "nova_shell_env: ACE marker block present in $NOVA_RC_FILE but NOVA_API_KEY not in this Claude Code session's env" "restart Claude Code (Cmd-Q + reopen) — the rc block only takes effect on the next shell/process launch"
elif [ -f "$HOME/.ace/env.sh" ] && [ -n "$NOVA_RC_FILE" ]; then
  warn "nova_shell_env: ~/.ace/env.sh exists but $NOVA_RC_FILE doesn't source it" "re-run /ace:setup --force-env  (it auto-appends a marker-fenced source block since 0.13.298)"
elif [ -f "$HOME/.ace/env.sh" ]; then
  warn "nova_shell_env: ~/.ace/env.sh exists but couldn't auto-detect your shell rc (OS=$NOVA_OS_NAME SHELL=$NOVA_SHELL_NAME)" "manually add 'source ~/.ace/env.sh' to your shell's startup file, then restart Claude Code"
else
  warn "nova_shell_env: NOVA_API_KEY not in shell env and ~/.ace/env.sh missing" "run /ace:setup --force-env  (writes ~/.ace/env.sh and appends source line to $NOVA_RC_FILE)"
fi
if command -v claude >/dev/null 2>&1 && claude mcp list 2>/dev/null | grep -qE '^nova:[[:space:]]'; then
  warn "nova_shell_env: stale user-scope nova: MCP override detected (pre-1.1.0 setup)" "the override shadows the Nova plugin's PAT-aware MCP entry. Run: claude mcp remove nova --scope user  (then restart Claude Code)"
fi

# 7c. nova_needs_auth_cache — verify Claude Code is not caching
# `plugin:nova:nova` as needs-authentication. When this entry exists,
# Claude Code skips reconnecting to the Nova MCP server even if the
# server is reachable and the credentials are valid — symptom is that
# only `mcp__plugin_nova_nova__authenticate` / `complete_authentication`
# surface, never the real toolset (`list_apps`, `get_app`, etc.).
#
# Common cause: the cache was written before NOVA_API_KEY made it into
# the shell env (pre-Nova-v1.1.0 setup, or post-/ace:setup but
# pre-Claude-Code-restart). Once `nova_env` + `nova_shell_env` +
# `nova_auth` all PASS, a leftover entry here is a clear stuck state.
#
# Remediation: delete the entry and restart Claude Code (the running
# process won't re-attempt the connection on its own). Per Braxton's
# voidcraft-labs/nova-plugin#11 comment.
NOVA_NEEDS_AUTH_CACHE="$HOME/.claude/mcp-needs-auth-cache.json"
if [ ! -f "$NOVA_NEEDS_AUTH_CACHE" ]; then
  pass "nova_needs_auth_cache: ~/.claude/mcp-needs-auth-cache.json absent (Claude Code has no stuck-auth entries cached)"
else
  NOVA_CACHE_HAS_NOVA="$(node -e "
    try {
      const d = JSON.parse(require('fs').readFileSync('$NOVA_NEEDS_AUTH_CACHE','utf8'));
      console.log('plugin:nova:nova' in d ? '1' : '0');
    } catch(_) { console.log('error'); }
  " 2>/dev/null)"
  if [ "$NOVA_CACHE_HAS_NOVA" = "error" ]; then
    warn "nova_needs_auth_cache: $NOVA_NEEDS_AUTH_CACHE present but unparseable" "node failed to parse the file. Inspect manually or remove it; Claude Code will recreate as needed"
  elif [ "$NOVA_CACHE_HAS_NOVA" = "1" ]; then
    # Hard fail when nova_auth has confirmed the upstream key works —
    # in that case the cache is anchored on stale auth state and Nova
    # tools won't surface until it's cleared. Soft warn otherwise
    # (operator may genuinely not be authed yet).
    if [ -n "$NOVA_KEY_VAL" ]; then
      fail "nova_needs_auth_cache: plugin:nova:nova cached as needs-auth despite valid NOVA_API_KEY" "remove the stuck entry and restart Claude Code (running process won't re-connect on its own):
       node -e 'const f=\"$NOVA_NEEDS_AUTH_CACHE\"; const d=JSON.parse(require(\"fs\").readFileSync(f,\"utf8\")); delete d[\"plugin:nova:nova\"]; require(\"fs\").writeFileSync(f, JSON.stringify(d,null,2)+\"\\n\");'
       Then Cmd-Q Claude Code and reopen. Symptom: only \`mcp__plugin_nova_nova__authenticate\` surfaces, real tools (\`list_apps\` etc.) are missing.
       Per Braxton's nova-plugin#11."
      mark_fail
    else
      warn "nova_needs_auth_cache: plugin:nova:nova cached as needs-auth (NOVA_API_KEY not set — possibly correct)" "if you intend to use Nova, see nova_env above; otherwise this entry is benign"
    fi
  else
    pass "nova_needs_auth_cache: plugin:nova:nova not stuck in needs-auth-cache"
  fi
fi

# 7d. commcare_cli_jar — gates Phase 3 `app-release-smoke` Step 4.5
# (runtime install validation via `commcare-cli.jar validate`). The CLI
# runs the same install path the Android device runs, catching the
# runtime-install failure class that the structural Steps 3–4 miss
# (canonical case: a `connect.deliver_unit.entity_id` bound to a
# `#case/<calculated-field>` on a case-create form — install-time
# resource graph reads null, CCZ rejected with "A part of your
# application is invalid").
#
# Auto-installed by `/ace:setup` (downloads the latest tagged
# commcare-cli.jar from dimagi/commcare-core's GitHub releases — picks
# up `commcare_2.63.0` today, ~10MB). `--force-install` refreshes the
# cache. Override via `ACE_COMMCARE_CLI_JAR=<absolute path>` if you want
# to pin to a specific build.
#
# WARN (not FAIL) on absence — `app-release-smoke` continues with
# `cli_validate.verdict: unavailable` so the structural gates still
# run. Becomes a real Phase 3 BLOCKER only when the operator wants the
# install-time gate active.
COMMCARE_CLI_JAR_PATH=""
if [ -n "${ACE_COMMCARE_CLI_JAR:-}" ]; then
  COMMCARE_CLI_JAR_PATH="$ACE_COMMCARE_CLI_JAR"
elif [ -n "${ACE_PLUGIN_DATA_DIR:-}" ] && [ -f "$ACE_PLUGIN_DATA_DIR/commcare-cli.jar" ]; then
  COMMCARE_CLI_JAR_PATH="$ACE_PLUGIN_DATA_DIR/commcare-cli.jar"
elif [ -f "$HOME/.claude/plugins/data/ace-ace/commcare-cli.jar" ]; then
  COMMCARE_CLI_JAR_PATH="$HOME/.claude/plugins/data/ace-ace/commcare-cli.jar"
fi
if [ -z "$COMMCARE_CLI_JAR_PATH" ]; then
  warn "commcare_cli_jar: not found at \$ACE_COMMCARE_CLI_JAR or \$CLAUDE_PLUGIN_DATA/commcare-cli.jar" "run /ace:setup — it auto-downloads the latest commcare-cli.jar from dimagi/commcare-core releases. Without this, Phase 3 app-release-smoke can't catch runtime-install defects (e.g. bednet-spot-check/20260525-1405 class)."
elif [ ! -r "$COMMCARE_CLI_JAR_PATH" ]; then
  warn "commcare_cli_jar: $COMMCARE_CLI_JAR_PATH not readable" "fix file permissions or re-run /ace:setup --force-install"
else
  COMMCARE_CLI_JAR_SIZE="$(stat -f %z "$COMMCARE_CLI_JAR_PATH" 2>/dev/null || stat -c %s "$COMMCARE_CLI_JAR_PATH" 2>/dev/null || echo 0)"
  COMMCARE_CLI_VERSION="$(cat "$COMMCARE_CLI_JAR_PATH.version" 2>/dev/null || echo unknown)"
  if [ "$COMMCARE_CLI_JAR_SIZE" -lt 1000000 ]; then
    warn "commcare_cli_jar: $COMMCARE_CLI_JAR_PATH suspiciously small ($COMMCARE_CLI_JAR_SIZE bytes; version=$COMMCARE_CLI_VERSION)" "re-run /ace:setup --force-install to redownload"
  else
    # Resolve Java exactly the way the jar-runner does
    # (lib/commcare-cli-validate.ts::resolveJavaPath, wrapped by
    # scripts/resolve-java-path.ts) — NOT a naive `command -v java`. The macOS
    # /usr/bin/java stub passes `command -v` even with no working JDK, and the
    # resolver also finds keg-only Homebrew openjdk that isn't on PATH. Using
    # the same resolver keeps this check honest: it PASSes whenever ACE can
    # actually run the jar, and only blames the jar when a real JDK runs it.
    COMMCARE_JAVA_BIN="$(cd "$ROOT" 2>/dev/null && npx tsx scripts/resolve-java-path.ts 2>/dev/null)"
    if [ -z "$COMMCARE_JAVA_BIN" ]; then
      warn "commcare_cli_jar: $COMMCARE_CLI_JAR_PATH present but no working Java runtime found (resolveJavaPath: not on PATH, no \$ACE_JAVA_BIN, no /usr/libexec/java_home, no Homebrew openjdk)" "install JDK 17+ (brew install openjdk@17 on macOS)"
    else
      # `<java> -jar <jar> help` triggers the jar's usage banner
      # ("The available commands are: validate / play / ..."), which is what
      # we grep for. The jar exits non-zero on "help" (not a real subcommand),
      # so we ignore exit code and look only at the combined output.
      COMMCARE_CLI_HELP="$("$COMMCARE_JAVA_BIN" -jar "$COMMCARE_CLI_JAR_PATH" help 2>&1 || true)"
      if echo "$COMMCARE_CLI_HELP" | grep -q -iE 'validate'; then
        pass "commcare_cli_jar: $COMMCARE_CLI_JAR_PATH (${COMMCARE_CLI_JAR_SIZE} bytes; version=${COMMCARE_CLI_VERSION}; java=$COMMCARE_JAVA_BIN; banner lists validate)"
      else
        warn "commcare_cli_jar: $COMMCARE_CLI_JAR_PATH present, java=$COMMCARE_JAVA_BIN runs but usage banner lacks 'validate'" "stale jar — re-run /ace:setup --force-install (pulls latest from dimagi/commcare-core releases)"
      fi
    fi
  fi
fi

# 8. ace-mobile — local-only MCP (Maestro + adb + AVD + APK). It does not
# authenticate against any remote service at runtime, so there is no
# "live auth probe" distinct from the others. The auth-adjacent things
# the mobile workflow depends on are covered elsewhere:
#   - Operator's Connect session (e.g. for probe-find-phone-invite.ts) →
#     connect_auth above
#   - AVD / Maestro / adb / APK / ACE_E2E_* env vars → [Mobile] block below
# The previous OTP-page probe in 0.13.25 was a leftover from the
# deprecated fetchOtp path (mobile-bootstrap.md step 6 explicitly notes
# OTP fetching is no longer the recommended flow); removed in 0.13.26.
info "mobile_auth: ace-mobile is local — see connect_auth above for Connect-side state and [Mobile] block below for AVD / Maestro / cookies"

# 8b. ace-mobile cloud backend — when the operator has flipped to the
# cloud backend (via /ace:mobile-backend cloud OR
# ACE_MOBILE_BACKEND=cloud), the runtime path is ECS task → ace-web
# (PAT auth) → SSM → EC2 instance → Android emulator. We probe the
# topmost rung — `GET /api/mobile/diagnose` against the configured
# ACE_WEB_BASE_URL — and emit a single-line state summary. The probe
# is read-only (does not start EC2). If diagnose returns 200 with
# ssm_ok=true + adb_visible_count>0 the emulator is hot and Phase 5
# can run; ssm_ok=false means EC2 is stopped (callers will start it
# on first ensure-running call); HTTP non-2xx means the PAT or
# ace-web is broken. Only runs when ACE_WEB_BASE_URL + PAT are both
# set — otherwise skipped silently (the env-presence is already
# tracked above by ace_web_pat_token).
ACE_WEB_BASE="$(get_env ACE_WEB_BASE_URL)"
if [ -n "$PAT_TOKEN" ] && [ -n "$ACE_WEB_BASE" ]; then
  # Strip trailing slash to mirror cloud.ts normalisation.
  ACE_WEB_BASE="${ACE_WEB_BASE%/}"
  CLOUD_EMU_BODY="$(mktemp -t ace-doctor-cloud-emu.XXXXXX)"
  CLOUD_EMU_CODE="$(curl -sS -o "$CLOUD_EMU_BODY" -w '%{http_code}' --max-time 8 \
    -H "Authorization: Bearer $PAT_TOKEN" \
    "$ACE_WEB_BASE/api/mobile/diagnose" 2>/dev/null || echo "000")"
  case "$CLOUD_EMU_CODE" in
    2*)
      # Parse the envelope to surface the most actionable signal.
      CLOUD_EMU_SUMMARY="$(python3 -c "
import json, sys
try:
    d = json.load(open('$CLOUD_EMU_BODY'))
    data = (d.get('data') or {})
    if not data.get('ssm_ok'):
        print('ec2_stopped')
    else:
        n = data.get('adb_visible_count') or len([a for a in (data.get('adb_devices') or []) if a.get('state') == 'device'])
        runner = data.get('runner_service_state') or 'unknown'
        marker_age = data.get('marker_age_seconds')
        if n > 0:
            print(f'adb={n}_runner={runner}_marker_age_s={marker_age}')
        else:
            print(f'adb=0_runner={runner}_marker_age_s={marker_age}')
except Exception as e:
    print(f'parse_err:{e}')
" 2>/dev/null)"
      case "$CLOUD_EMU_SUMMARY" in
        adb=0*|parse_err*)
          warn "cloud_emu: $ACE_WEB_BASE/api/mobile/diagnose → HTTP $CLOUD_EMU_CODE but emulator unhealthy ($CLOUD_EMU_SUMMARY)" "the emulator may have crashed or the runner unit failed — call /api/mobile/restart-runner to cold-boot cleanly, or wait for ensure-running's auto-recovery on next run"
          ;;
        ec2_stopped)
          info "cloud_emu: ec2 instance is stopped — ensure-running will start it on first call (~5 min cold-boot)"
          ;;
        *)
          pass "cloud_emu: emulator healthy ($CLOUD_EMU_SUMMARY)"
          ;;
      esac
      ;;
    401|403)
      warn "cloud_emu: HTTP $CLOUD_EMU_CODE — PAT invalid or revoked" "re-mint via /ace:ace-web-pat-mint and re-inject .env"
      ;;
    404)
      warn "cloud_emu: HTTP 404 — ACE_WEB_BASE_URL ($ACE_WEB_BASE) does not expose /api/mobile/diagnose; ace-web may be older than #312" "deploy a newer ace-web or unset ACE_WEB_BASE_URL"
      ;;
    000)
      warn "cloud_emu: cannot reach $ACE_WEB_BASE (network/DNS/timeout)" "check VPN/proxy and ACE_WEB_BASE_URL"
      ;;
    *)
      warn "cloud_emu: GET $ACE_WEB_BASE/api/mobile/diagnose → HTTP $CLOUD_EMU_CODE" "inspect ace-web logs; if persists, ace-web may be down"
      ;;
  esac
  rm -f "$CLOUD_EMU_BODY"
else
  info "cloud_emu: skipped — ACE_WEB_BASE_URL or ACE_WEB_PAT_TOKEN not set (cloud backend disabled — see /ace:mobile-backend)"
fi

# mobile_infra (added 0.13.128): single-line gate that summarizes mobile
# readiness so an operator scanning [Auth liveness] sees the gating
# signal without having to read the verbose [Mobile] block. The detail
# block below is unchanged — it stays the diagnostic surface for
# operators who get a WARN here and need to see which sub-check failed.
#
# Failure mode this catches: Phase 5's `app-screenshot-capture` skill
# silently degrades to `verdict: incomplete` and ships a no-screenshot
# training run when the AVD is offline / Maestro is missing / cookies
# are stale (real failure mode from turmeric 20260509-1448 — AVD boot
# stuck at `offline` + adb port-5037 collision; the verbose [Mobile]
# block correctly reported the state but the doctor summary read clean
# and the operator didn't see the gap until Phase 5's own report).
#
# Recovery is `/ace:mobile-bootstrap` for almost every failure here —
# it's the canonical one-shot setup that installs Maestro, adb,
# creates/repairs the AVD, seeds Playwright cookies, and verifies the
# ACE_E2E_* env vars. The `fix:` hint always points there; for the rare
# "ACE_E2E_PHONE not set" case, mobile-bootstrap also re-injects from
# 1Password.
MOBILE_ISSUES=()

# Maestro present + executable
_MOBILE_MAESTRO=""
for _candidate in \
    "$(command -v maestro 2>/dev/null)" \
    "${HOME}/.maestro/bin/maestro"; do
  [ -n "$_candidate" ] && [ -x "$_candidate" ] && _MOBILE_MAESTRO="$_candidate" && break
done
[ -z "$_MOBILE_MAESTRO" ] && MOBILE_ISSUES+=("maestro missing")

# adb present + reachable (a stale daemon on port 5037 that's hung
# manifests as `adb devices` hanging, not as a missing binary — bound
# the call so we fail loud rather than wait forever).
if ! command -v adb >/dev/null 2>&1; then
  MOBILE_ISSUES+=("adb missing")
elif ! _ADB_DEVICES_OUT="$(timeout 3 adb devices 2>/dev/null)"; then
  MOBILE_ISSUES+=("adb daemon unreachable (port 5037 collision or stale daemon)")
fi

# Configured AVD exists + booted. AVD_NAME / EMULATOR_BIN resolution
# logic is duplicated in [Mobile] block below; keeping it here too so
# this check is self-contained and survives [Mobile]-block edits.
_MOBILE_AVD_NAME="$(get_env ACE_AVD_NAME)"
[ -z "$_MOBILE_AVD_NAME" ] && _MOBILE_AVD_NAME="${ACE_AVD_NAME:-ACE_Pixel_API_34}"
_MOBILE_EMULATOR_BIN=""
for _candidate in \
    "$(command -v emulator 2>/dev/null)" \
    "/opt/homebrew/share/android-commandlinetools/emulator/emulator" \
    "${ANDROID_HOME:-}/emulator/emulator" \
    "${ANDROID_SDK_ROOT:-}/emulator/emulator"; do
  [ -x "$_candidate" ] && _MOBILE_EMULATOR_BIN="$_candidate" && break
done
if [ -z "$_MOBILE_EMULATOR_BIN" ]; then
  MOBILE_ISSUES+=("emulator binary not on PATH (Android SDK missing)")
elif ! "$_MOBILE_EMULATOR_BIN" -list-avds 2>/dev/null | grep -q "^${_MOBILE_AVD_NAME}$"; then
  MOBILE_ISSUES+=("AVD '${_MOBILE_AVD_NAME}' not created")
elif ! echo "${_ADB_DEVICES_OUT:-}" | grep -q "^emulator-"; then
  MOBILE_ISSUES+=("AVD '${_MOBILE_AVD_NAME}' not booted")
else
  # AVD is booted. Probe the on-device Maestro driver gRPC channel —
  # the canonical Phase 5 failure mode that pre-0.13.165 doctor missed
  # was "AVD booted, Maestro driver app installed but its gRPC server
  # dead." Symptom: `maestro test` returns `deviceInfo … UNAVAILABLE`
  # and Phase 5 `app-screenshot-capture` degrades to
  # `verdict: incomplete` for a state that's auto-recoverable.
  #
  # This probe is the same shape as `MaestroBackend.probeDriver` —
  # short-timeout `maestro hierarchy` against the emulator's adb port.
  # Doctor shells out directly rather than spinning up `npx tsx` to
  # avoid ~3s of JIT startup on the hot path; if the doctor probe and
  # the backend probe ever drift, prefer the backend (it's the one that
  # decides whether to heal). Recovery is `mobile_ensure_avd_running`
  # (called by `mobile-bootstrap` and by Phase 5 Step 3); doctor only
  # diagnoses, never mutates.
  _MOBILE_SERIAL="$(echo "${_ADB_DEVICES_OUT:-}" | awk '/^emulator-[0-9]+\s+device/ {print $1; exit}')"
  if [ -n "$_MOBILE_SERIAL" ] && [ -n "$_MOBILE_MAESTRO" ]; then
    _MOBILE_ADB_PORT="${_MOBILE_SERIAL#emulator-}"
    _MOBILE_ADB_PORT=$((_MOBILE_ADB_PORT + 1))
    # `maestro hierarchy` on a healthy AVD returns ~2s; 10s gives us
    # plenty of headroom for slow first-time driver attach without
    # waiting through the full 30s UNAVAILABLE timeout on a hung
    # driver. `timeout` here is GNU coreutils on Linux / brew coreutils
    # on macOS — `gtimeout` is the macOS fallback if neither is on PATH.
    _MOBILE_TIMEOUT_BIN="$(command -v timeout 2>/dev/null || command -v gtimeout 2>/dev/null)"
    if [ -n "$_MOBILE_TIMEOUT_BIN" ]; then
      if "$_MOBILE_TIMEOUT_BIN" 10 "$_MOBILE_MAESTRO" --host=localhost --port="$_MOBILE_ADB_PORT" hierarchy >/dev/null 2>&1; then
        : # healthy; no message
      else
        MOBILE_ISSUES+=("Maestro driver on '${_MOBILE_SERIAL}' not responding on gRPC (hierarchy probe failed; Phase 5 will hit deviceInfo UNAVAILABLE)")
      fi
    fi
    unset _MOBILE_TIMEOUT_BIN _MOBILE_ADB_PORT
  fi
  unset _MOBILE_SERIAL
fi

# Playwright cookies: directory exists with a non-empty Cookies file.
_MOBILE_PW_DIR="${ACE_PLAYWRIGHT_USER_DATA_DIR:-${HOME}/.ace/playwright-userdata}"
if ! [ -d "${_MOBILE_PW_DIR}" ] || ! find "${_MOBILE_PW_DIR}" -name 'Cookies' -type f -size +0c 2>/dev/null | grep -q .; then
  MOBILE_ISSUES+=("Playwright cookies missing (${_MOBILE_PW_DIR})")
fi

# E2E env vars (registration on a fresh AVD requires phone+PIN+backup-code)
_MOBILE_MISSING_ENV=()
for _v in ACE_E2E_PHONE ACE_E2E_PIN ACE_E2E_BACKUP_CODE; do
  _val="$(get_env "$_v")"
  [ -z "$_val" ] && _val="${!_v:-}"
  [ -z "$_val" ] && _MOBILE_MISSING_ENV+=("$_v")
done
if [ ${#_MOBILE_MISSING_ENV[@]} -gt 0 ]; then
  MOBILE_ISSUES+=("env vars missing: $(IFS=,; echo "${_MOBILE_MISSING_ENV[*]}")")
fi

if [ ${#MOBILE_ISSUES[@]} -eq 0 ]; then
  pass "mobile_infra: maestro + adb + AVD '${_MOBILE_AVD_NAME}' booted, driver gRPC responsive, cookies + ACE_E2E_* env all OK (Phase 5 app-screenshot-capture ready)"
else
  # Build the joined string with `; ` separators. `IFS=…` with `${arr[*]}`
  # only uses the first IFS char as separator (bash 3.2 limitation), so a
  # manual loop gives readable multi-issue messages.
  _MOBILE_JOINED=""
  for _issue in "${MOBILE_ISSUES[@]}"; do
    _MOBILE_JOINED="${_MOBILE_JOINED:+${_MOBILE_JOINED}; }${_issue}"
  done
  # Driver-only failures are auto-recoverable inside
  # `mobile_ensure_avd_running` (force-stop + uninstall + reinstall);
  # everything else needs `/ace:mobile-bootstrap`. Both lead to the
  # same operator command since bootstrap itself calls
  # `mobile_ensure_avd_running`, so the heal path runs either way.
  warn "mobile_infra: ${_MOBILE_JOINED}. Phase 5 app-screenshot-capture is gated on these — pre-0.13.165 it would degrade silently to verdict:incomplete; current builds halt with [BLOCKER] until recovery runs." "/ace:mobile-bootstrap (one-shot recovery — boots the AVD and triggers the auto-heal in mobile_ensure_avd_running for the Maestro driver). See [Mobile] block below for per-component detail."
fi
unset MOBILE_ISSUES _MOBILE_MAESTRO _ADB_DEVICES_OUT _MOBILE_AVD_NAME _MOBILE_EMULATOR_BIN _MOBILE_PW_DIR _MOBILE_MISSING_ENV _candidate _v _val

# --- selector_map_currency ---
# Phase 5 (`qa-and-training`) Maestro recipes reference logical selector
# names via `${SELECTOR:<logical-name>}` placeholders. At resolve time
# `mobile_resolve_selectors({yaml, apk_version})` substitutes those with
# concrete matchers from `mcp/mobile/selectors/connect-<VERSION>.yaml`.
# When the deployed Connect APK bumps (e.g. 2.62.0 → 2.63.0) and no fresh
# selector map exists for the new version — or the map exists but lacks
# rows for selectors the static recipes need — Phase 5 blocks late, after
# the AVD is already booted and the recipe is mid-flight.
#
# This probe is the static structural pre-flight: does the map for the
# deployed APK exist, is it populated, and does it cover every logical
# name referenced in `mcp/mobile/recipes/static/*.yaml`? No network. Reads
# `ACE_CONNECT_APK_VERSION` from .env; if unset, picks the newest
# `connect-*.yaml` on disk and INFOs the fallback (the env var is
# advisory — the canonical source is the apk_version yaml header).
#
# Classification:
#   - map missing OR zero rows → FAIL (Phase 5 cannot run)
#   - any referenced selector unresolved → WARN (Phase 5 may partially
#     run; uncovered surfaces will halt mid-recipe)
#   - all resolvable + zero unverified → PASS
#   - all resolvable + some unverified → PASS with INFO line listing the
#     unverified count (unverified rows are best-guesses pending a
#     baseline-screenshot calibration — see skills/connect-baseline-screenshots)
#
# Companion of cloud_emu and ocs_shared_collection_team: same shape —
# named probe, single-line gate, PASS/WARN/FAIL + concrete remediation
# (`/ace:step connect-baseline-screenshots`).
SELECTOR_MAP_DIR="$ROOT/mcp/mobile/selectors"
SELECTOR_RECIPES_DIR="$ROOT/mcp/mobile/recipes/static"
SELECTOR_APK_VERSION="$(get_env ACE_CONNECT_APK_VERSION)"
SELECTOR_APK_VERSION_SOURCE="env"
if [ -z "$SELECTOR_APK_VERSION" ]; then
  # Fall back to newest connect-*.yaml on disk (version-sorted).
  SELECTOR_APK_VERSION="$(ls -1 "$SELECTOR_MAP_DIR"/connect-*.yaml 2>/dev/null \
    | sed -E 's|.*/connect-([^/]+)\.yaml$|\1|' \
    | sort -V | tail -1)"
  SELECTOR_APK_VERSION_SOURCE="newest-on-disk"
fi
SELECTOR_MAP_REL="mcp/mobile/selectors/connect-${SELECTOR_APK_VERSION}.yaml"
SELECTOR_MAP_PATH="$ROOT/$SELECTOR_MAP_REL"

if [ -z "$SELECTOR_APK_VERSION" ]; then
  fail "selector_map_currency: no selector maps found under $SELECTOR_MAP_DIR and ACE_CONNECT_APK_VERSION unset" "run /ace:step connect-baseline-screenshots to seed a map for the deployed APK"
elif ! [ -f "$SELECTOR_MAP_PATH" ]; then
  fail "selector_map_currency: no map for APK $SELECTOR_APK_VERSION at $SELECTOR_MAP_REL" "run /ace:step connect-baseline-screenshots"
else
  # Selector keys live under `selectors:` at 2-space indent; each row is
  # `  <kebab-name>:` on its own line. Awk slice between the `^selectors:$`
  # anchor and EOF keeps us robust to other top-level fields above it.
  SELECTOR_KNOWN="$(awk '
    /^selectors:[[:space:]]*$/ { in_sel=1; next }
    in_sel && /^[a-zA-Z_]/ { in_sel=0 }
    in_sel && /^  [a-z][a-z0-9-]*:[[:space:]]*$/ {
      gsub(/^  |:[[:space:]]*$/, "", $0); print $0
    }
  ' "$SELECTOR_MAP_PATH" 2>/dev/null)"
  SELECTOR_KNOWN_COUNT=$(printf '%s\n' "$SELECTOR_KNOWN" | grep -c . | tr -d '[:space:]')
  : "${SELECTOR_KNOWN_COUNT:=0}"
  # Count rows marked `unverified: true` (best-guesses pending live calibration).
  SELECTOR_UNVERIFIED_COUNT=$(grep -cE '^[[:space:]]+unverified:[[:space:]]*true' "$SELECTOR_MAP_PATH" 2>/dev/null | tr -d '[:space:]')
  : "${SELECTOR_UNVERIFIED_COUNT:=0}"
  SELECTOR_VERIFIED_COUNT=$((SELECTOR_KNOWN_COUNT - SELECTOR_UNVERIFIED_COUNT))

  if [ "$SELECTOR_KNOWN_COUNT" -eq 0 ]; then
    fail "selector_map_currency: $SELECTOR_MAP_REL exists but has zero selector rows" "run /ace:step connect-baseline-screenshots"
  else
    # Logical names referenced by every static recipe. `-h` suppresses
    # filenames so the sed pipeline only sees `${SELECTOR:foo}` tokens.
    SELECTOR_REFD=""
    SELECTOR_RECIPE_COUNT=0
    if [ -d "$SELECTOR_RECIPES_DIR" ]; then
      SELECTOR_REFD="$(grep -h -oE '\$\{SELECTOR:[^}]+\}' "$SELECTOR_RECIPES_DIR"/*.yaml 2>/dev/null \
        | sed -E 's/^\$\{SELECTOR:([^}]+)\}$/\1/' | sort -u)"
      SELECTOR_RECIPE_COUNT=$(ls -1 "$SELECTOR_RECIPES_DIR"/*.yaml 2>/dev/null | wc -l | tr -d '[:space:]')
    fi
    # Diff referenced ∖ known. `comm -23` requires sorted inputs.
    SELECTOR_UNRESOLVED="$(comm -23 \
      <(printf '%s\n' "$SELECTOR_REFD" | grep . | sort -u) \
      <(printf '%s\n' "$SELECTOR_KNOWN" | grep . | sort -u))"
    SELECTOR_UNRESOLVED_COUNT=$(printf '%s\n' "$SELECTOR_UNRESOLVED" | grep -c . | tr -d '[:space:]')
    : "${SELECTOR_UNRESOLVED_COUNT:=0}"
    SELECTOR_REFD_COUNT=$(printf '%s\n' "$SELECTOR_REFD" | grep -c . | tr -d '[:space:]')
    : "${SELECTOR_REFD_COUNT:=0}"

    if [ "$SELECTOR_UNRESOLVED_COUNT" -gt 0 ]; then
      # Cap the listed names at 5 to keep the WARN line readable.
      SELECTOR_UNRESOLVED_HEAD="$(printf '%s\n' "$SELECTOR_UNRESOLVED" | head -5 | tr '\n' ',' | sed 's/,$//; s/,/, /g')"
      SELECTOR_OVERFLOW=""
      if [ "$SELECTOR_UNRESOLVED_COUNT" -gt 5 ]; then
        SELECTOR_OVERFLOW=" (+$((SELECTOR_UNRESOLVED_COUNT - 5)) more)"
      fi
      warn "selector_map_currency: $SELECTOR_UNRESOLVED_COUNT selector(s) referenced by recipes have no matcher in $SELECTOR_MAP_REL: ${SELECTOR_UNRESOLVED_HEAD}${SELECTOR_OVERFLOW}" "run /ace:step connect-baseline-screenshots to calibrate against the live APK"
    else
      pass "selector_map_currency: APK $SELECTOR_APK_VERSION, $SELECTOR_VERIFIED_COUNT verified + $SELECTOR_UNVERIFIED_COUNT unverified row(s), $SELECTOR_REFD_COUNT selector(s) referenced across $SELECTOR_RECIPE_COUNT recipe(s) all resolvable"
      if [ "$SELECTOR_UNVERIFIED_COUNT" -gt 0 ]; then
        info "selector_map_currency: $SELECTOR_UNVERIFIED_COUNT row(s) marked unverified: true — best-guess values pending live calibration via connect-baseline-screenshots"
      fi
    fi
    if [ "$SELECTOR_APK_VERSION_SOURCE" = "newest-on-disk" ]; then
      info "selector_map_currency: ACE_CONNECT_APK_VERSION not set in .env — used newest map on disk ($SELECTOR_APK_VERSION); set the env var to gate on a specific deployed version"
    fi
  fi
fi
unset SELECTOR_MAP_DIR SELECTOR_RECIPES_DIR SELECTOR_APK_VERSION SELECTOR_APK_VERSION_SOURCE \
      SELECTOR_MAP_REL SELECTOR_MAP_PATH SELECTOR_KNOWN SELECTOR_KNOWN_COUNT \
      SELECTOR_UNVERIFIED_COUNT SELECTOR_VERIFIED_COUNT SELECTOR_REFD SELECTOR_RECIPE_COUNT \
      SELECTOR_UNRESOLVED SELECTOR_UNRESOLVED_COUNT SELECTOR_UNRESOLVED_HEAD \
      SELECTOR_OVERFLOW SELECTOR_REFD_COUNT

echo ""
echo "[Mobile]"

# Resolve the maestro launcher even when ~/.maestro/bin isn't on PATH.
# Mirrors `resolveMaestroBinDir()` in mcp/mobile/backends/avd.ts: the official
# installer drops it at ~/.maestro/bin/maestro on macOS/Linux but only patches
# the user's interactive shell rc, so a non-login shell (or doctor invoked
# from Claude Code) never sees it. Without this fallback doctor reports
# MISSING on a perfectly working install.
MAESTRO_BIN=""
for candidate in \
    "${MAESTRO_BIN:-}" \
    "$(command -v maestro 2>/dev/null)" \
    "${HOME}/.maestro/bin/maestro"; do
  [ -n "$candidate" ] && [ -x "$candidate" ] && MAESTRO_BIN="$candidate" && break
done
if [ -n "$MAESTRO_BIN" ]; then
  # JAVA_HOME may not be set in doctor's shell; resolve it like avd.ts does
  # so `--version` doesn't print "Unable to locate a Java Runtime".
  if [ -z "${JAVA_HOME:-}" ] && [ -x /usr/libexec/java_home ]; then
    export JAVA_HOME="$(/usr/libexec/java_home -v 17 2>/dev/null)"
  fi
  if [ -z "${JAVA_HOME:-}" ] && [ -d /opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home ]; then
    export JAVA_HOME="/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home"
  fi
  MAESTRO_VER="$("$MAESTRO_BIN" --version 2>/dev/null | tail -1)"
  echo "  Maestro:                $MAESTRO_BIN    ${MAESTRO_VER:-unknown}    OK"
  # Version-floor advisory: ACE standardized on Maestro v2.x as of
  # 0.13.x (post-malaria-itn-app debug arc). v1.39 still works for
  # recipe playback — driver APK layout and gRPC contract are
  # wire-compatible — but the cheap probe1 in `assertMaestroDriverHealthy`
  # was recalibrated for v2's slower JVM cold-start. Operators on v1.x
  # should upgrade so local-backend behavior matches the (forthcoming)
  # v2.x-baked cloud AMI. WARN-level, not BLOCKER: cloud-AMI rebake
  # is tracked separately and operators using the cloud backend with a
  # v1-bundled AMI still work fine.
  if echo "$MAESTRO_VER" | grep -qE '^1\.'; then
    echo "  WARN maestro_version:   ${MAESTRO_VER} — ACE has standardized on Maestro v2.x"
    echo "    fix: curl -Ls 'https://get.maestro.mobile.dev' | bash  # reinstalls latest (currently v2.3.x)"
  fi
else
  echo "  Maestro:                MISSING — install with curl -Ls 'https://get.maestro.mobile.dev' | bash"
fi

if command -v adb >/dev/null 2>&1; then
  echo "  adb:                    $(which adb)    $(adb version | head -1)    OK"
  # Detect the multi-user-shared-adb-server pattern that breaks Maestro
  # auto-discovery. dadb-1.2.10 (bundled with Maestro 2.3.0–2.5.1) aborts
  # `Dadb.list` on the first `unauthorized` device returned by `adb devices`,
  # and on a shared workstation that bites any operator whose `~/.android/adbkey`
  # isn't authorized on a sibling user's emulator. Diagnosed live 2026-05-01;
  # workaround landed in 0.10.65 (`MaestroBackend.runRecipe` adds
  # `--host`/`--port` so dadb takes the direct-TCP path), but a leftover
  # unauthorized entry still surfaces other footguns (e.g., `adb shell` calls
  # without -s pick the wrong device). WARN-level: ACE registration works
  # via the 0.10.65 patch, but the operator should know.
  UNAUTH_DEVS="$(adb devices 2>/dev/null | awk '/^emulator-/ && $2=="unauthorized" {print $1}' | tr '\n' ' ' | sed 's/ $//')"
  if [ -n "$UNAUTH_DEVS" ]; then
    echo "  WARN adb_unauthorized: $UNAUTH_DEVS"
    echo "    fix: another user on this machine has emulators visible to your adb server."
    echo "    ACE bypasses this since 0.10.65, but unrelated 'adb shell' calls without -s may"
    echo "    pick the wrong device. Disconnect with 'adb disconnect <serial>' (transient)"
    echo "    or pin a per-session adb server (ANDROID_ADB_SERVER_PORT=5038 adb start-server)."
    echo "    Note: ACE's local AVD backend now auto-allocates this port per session."
  fi
else
  echo "  adb:                    MISSING — install with brew install android-platform-tools"
fi

# Surface the allocator inputs for the local AVD backend. The MCP server
# probes these ports lazily on first AVD use; doctor only shows what's
# DECLARED in env (live allocation lives inside the running MCP process,
# not visible from a one-shot bash check). Either env var set → that port
# is pinned; unset → MCP auto-picks the next free pair starting at the
# default. See `mcp/mobile/port-allocator.ts`.
ADB_PORT_ENV="$(get_env ANDROID_ADB_SERVER_PORT)"
EMU_PORT_ENV="$(get_env ACE_MOBILE_EMULATOR_PORT)"
if [ -n "$ADB_PORT_ENV" ] || [ -n "$EMU_PORT_ENV" ]; then
  echo "  Port allocation:        pinned via env"
  echo "    ANDROID_ADB_SERVER_PORT=${ADB_PORT_ENV:-(unset; auto from 5037)}"
  echo "    ACE_MOBILE_EMULATOR_PORT=${EMU_PORT_ENV:-(unset; auto from 5554/5555)}"
else
  echo "  Port allocation:        auto (probe-and-pick from 5037 / 5554)    OK"
  echo "    note: two concurrent /ace:run sessions on this laptop will get"
  echo "    distinct adb-server + emulator ports. Pin via ANDROID_ADB_SERVER_PORT"
  echo "    + ACE_MOBILE_EMULATOR_PORT in .env for deterministic CI."
fi

# Read ACE_AVD_NAME from .env first (matches the rest of doctor's behavior),
# fall back to process env, then to the default.
AVD_NAME="$(get_env ACE_AVD_NAME)"
[ -z "$AVD_NAME" ] && AVD_NAME="${ACE_AVD_NAME:-ACE_Pixel_API_34}"

# Search broader paths for emulator/adb in case the doctor session doesn't
# have ANDROID_HOME on PATH (common when run from a non-interactive shell).
EMULATOR_BIN=""
for candidate in \
    "$(command -v emulator 2>/dev/null)" \
    "/opt/homebrew/share/android-commandlinetools/emulator/emulator" \
    "${ANDROID_HOME:-}/emulator/emulator" \
    "${ANDROID_SDK_ROOT:-}/emulator/emulator"; do
  [ -x "$candidate" ] && EMULATOR_BIN="$candidate" && break
done

if [ -n "$EMULATOR_BIN" ] && "$EMULATOR_BIN" -list-avds 2>/dev/null | grep -q "^${AVD_NAME}$"; then
  if adb devices 2>/dev/null | grep -q "^emulator-"; then
    echo "  AVD:                    ${AVD_NAME}    booted    OK"
    # Driver gRPC probe (Phase 5 readiness). See mobile_infra rollup
    # above for the rationale + the auto-heal recovery path.
    _DRIVER_SERIAL="$(adb devices 2>/dev/null | awk '/^emulator-[0-9]+\s+device/ {print $1; exit}')"
    if [ -n "$_DRIVER_SERIAL" ] && [ -n "$MAESTRO_BIN" ]; then
      _DRIVER_ADB_PORT="${_DRIVER_SERIAL#emulator-}"
      _DRIVER_ADB_PORT=$((_DRIVER_ADB_PORT + 1))
      _DRIVER_TIMEOUT_BIN="$(command -v timeout 2>/dev/null || command -v gtimeout 2>/dev/null)"
      if [ -n "$_DRIVER_TIMEOUT_BIN" ]; then
        if "$_DRIVER_TIMEOUT_BIN" 10 "$MAESTRO_BIN" --host=localhost --port="$_DRIVER_ADB_PORT" hierarchy >/dev/null 2>&1; then
          echo "  Maestro driver:         responsive on adb tcp:${_DRIVER_ADB_PORT}    OK"
        else
          echo "  Maestro driver:         NOT RESPONDING on adb tcp:${_DRIVER_ADB_PORT}"
          echo "    fix: /ace:mobile-bootstrap (boots the AVD, triggering the auto-heal in mobile_ensure_avd_running: force-stop dev.mobile.maestro + uninstall both halves, then maestro hierarchy reinstalls)."
        fi
      else
        echo "  Maestro driver:         SKIPPED (no \`timeout\` binary on PATH — install GNU coreutils for the gRPC probe)"
      fi
      unset _DRIVER_TIMEOUT_BIN _DRIVER_ADB_PORT
    fi
    unset _DRIVER_SERIAL
  else
    echo "  AVD:                    ${AVD_NAME}    available (not booted)    OK"
  fi
else
  echo "  AVD:                    ${AVD_NAME}    MISSING — create via Android Studio or 'avdmanager create avd -n ${AVD_NAME} -k \"system-images;android-34;google_apis;arm64-v8a\" -d pixel_7'"
fi

PLAYWRIGHT_DIR="${ACE_PLAYWRIGHT_USER_DATA_DIR:-${HOME}/.ace/playwright-userdata}"
if [ -d "${PLAYWRIGHT_DIR}" ] && find "${PLAYWRIGHT_DIR}" -name 'Cookies' -type f -size +0c 2>/dev/null | grep -q .; then
  echo "  Playwright cookies:     ${PLAYWRIGHT_DIR}    valid    OK"
else
  echo "  Playwright cookies:     MISSING — run /ace:mobile-bootstrap"
fi

# Read ACE_E2E_* and ACE_AVD_NAME from $ENV_FILE via get_env so they aren't
# perpetually MISSING when doctor runs from a shell that didn't load .env.
for v in ACE_E2E_PHONE ACE_E2E_PIN ACE_E2E_BACKUP_CODE ACE_AVD_NAME; do
  val="$(get_env "$v")"
  [ -z "$val" ] && val="${!v:-}"
  if [ -n "$val" ]; then
    echo "  ${v}:    set    OK"
  else
    echo "  ${v}:    MISSING — populate via 1Password + op inject"
  fi
done

echo ""
echo "[Drive layout]"
if [ -f "$ROOT/scripts/doctor-drive-layout.ts" ]; then
  cd "$ROOT" && npx tsx scripts/doctor-drive-layout.ts 2>&1
else
  warn "drive_layout: scripts/doctor-drive-layout.ts not present" "run /ace:update to pull a version that ships the audit (>= 0.11.9)"
fi

echo ""

# --- End-of-run summary table (added 0.13.129) ---
#
# Tee'd output is in $DOCTOR_LOG. Sleep briefly so the tee subprocess
# flushes all the [Drive layout] subprocess writes before we count.
# 200ms is invisible to humans and well above tee's typical buffer
# flush latency on macOS / Linux for a ~5 KB file.
sleep 0.2

# Capture all counts AND listings BEFORE printing anything — once the
# summary header lines start streaming through tee, they'll land in the
# log and get re-counted. Snapshot first, print second.
_DOCTOR_PASS=$(grep -c '^PASS ' "$DOCTOR_LOG" 2>/dev/null | tr -d '[:space:]')
_DOCTOR_WARN=$(grep -c '^WARN ' "$DOCTOR_LOG" 2>/dev/null | tr -d '[:space:]')
_DOCTOR_FAIL=$(grep -c '^FAIL ' "$DOCTOR_LOG" 2>/dev/null | tr -d '[:space:]')
: "${_DOCTOR_PASS:=0}" "${_DOCTOR_WARN:=0}" "${_DOCTOR_FAIL:=0}"
_DOCTOR_FAIL_LIST="$(grep '^FAIL ' "$DOCTOR_LOG" 2>/dev/null | sed -E 's/^FAIL ([^:]+):.*$/  - \1/')"
_DOCTOR_WARN_LIST="$(grep '^WARN ' "$DOCTOR_LOG" 2>/dev/null | sed -E 's/^WARN ([^:]+):.*$/  - \1/')"

if [ "$_DOCTOR_FAIL" -gt 0 ]; then
  _DOCTOR_VERDICT="BROKEN — ACE will not function until FAILs are fixed"
elif [ "$_DOCTOR_WARN" -gt 0 ]; then
  _DOCTOR_VERDICT="HEALTHY — ACE works; warnings below are non-fatal"
else
  _DOCTOR_VERDICT="HEALTHY — all checks passed"
fi

echo "================================================================"
echo "ACE Doctor Summary"
echo "================================================================"
printf "  PASS: %s   WARN: %s   FAIL: %s\n" "$_DOCTOR_PASS" "$_DOCTOR_WARN" "$_DOCTOR_FAIL"
echo "  Verdict: $_DOCTOR_VERDICT"
echo "================================================================"

if [ "$_DOCTOR_FAIL" -gt 0 ]; then
  echo "FAIL items (must fix):"
  printf '%s\n' "$_DOCTOR_FAIL_LIST"
  echo "----------------------------------------------------------------"
fi

if [ "$_DOCTOR_WARN" -gt 0 ]; then
  echo "WARN items (review optional):"
  printf '%s\n' "$_DOCTOR_WARN_LIST"
  echo "----------------------------------------------------------------"
fi

echo ""
echo "STATUS: COMPLETE"
