#!/usr/bin/env bash
# ace-doctor — health checks for an ACE plugin install.
#
# By default audits the plugin copy this script ships with (i.e. $(dirname $0)/..).
# That's the right answer when launched via the /ace:doctor slash command, because
# Claude Code loads slash command bodies from the installed plugin copy, and the
# launcher execs bin/ace-doctor from that same copy.
#
# Overrides:
#   ACE_DIR=/path/to/ace      audit a specific plugin root
#   --here                    walk up from $PWD to find an ACE checkout (dev mode)
#   --installed               force use of the newest ~/.claude/plugins/cache/ace/ace/*
#
# Exit status: 0 always (check results go to stdout as PASS/WARN/FAIL lines).
set +e

SELF_DIR="$(cd "$(dirname "$0")/.." && pwd)"
MODE="self"
ROOT=""

while [ $# -gt 0 ]; do
  case "$1" in
    --here)       MODE="pwd" ;;
    --installed)  MODE="installed" ;;
    --root)       shift; ROOT="$1" ;;
    *)            echo "ace-doctor: unknown arg: $1" >&2; exit 2 ;;
  esac
  shift
done

# Root resolution
if [ -n "${ACE_DIR:-}" ]; then
  ROOT="$ACE_DIR"
elif [ -n "$ROOT" ]; then
  :  # already set via --root
elif [ "$MODE" = "pwd" ]; then
  D="$PWD"
  while [ "$D" != "/" ]; do
    if [ -f "$D/.claude-plugin/plugin.json" ] && grep -q '"name": "ace"' "$D/.claude-plugin/plugin.json" 2>/dev/null; then
      ROOT="$D"; break
    fi
    D="$(dirname "$D")"
  done
elif [ "$MODE" = "installed" ]; then
  # Prefer the authoritative install path Claude Code records in
  # ~/.claude/plugins/installed_plugins.json. Fall back to version-sorted
  # newest directory under the cache if that file is missing or unreadable.
  REG="$HOME/.claude/plugins/installed_plugins.json"
  if [ -f "$REG" ]; then
    ROOT="$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$REG','utf8')); const e=d['ace@ace']; if(Array.isArray(e)){for(const x of e){if(x&&x.installPath){console.log(x.installPath);break;}}} else if(e&&e.installPath){console.log(e.installPath);} } catch(_) {}" 2>/dev/null)"
  fi
  if [ -z "$ROOT" ] || [ ! -f "$ROOT/.claude-plugin/plugin.json" ]; then
    ROOT="$(ls -1d "$HOME"/.claude/plugins/cache/ace/ace/*/ 2>/dev/null | sed 's:/$::' | sort -V | tail -1)"
  fi
else
  # Default: self — audit the plugin copy this script lives in.
  ROOT="$SELF_DIR"
fi

if [ -z "$ROOT" ] || [ ! -f "$ROOT/.claude-plugin/plugin.json" ]; then
  echo "FAIL plugin_root_not_found: could not locate ACE plugin (mode=$MODE)"
  echo "  fix: run from an ACE checkout, or after /plugin install ace@ace, or pass --root /path"
  exit 0
fi

echo "INFO plugin_root=$ROOT (mode=$MODE)"

# If the user is inside a dev worktree that differs from $ROOT, flag it so they
# know the doctor is auditing the installed copy rather than their checkout.
PWD_MATCH=""
D="$PWD"
while [ "$D" != "/" ]; do
  if [ -f "$D/.claude-plugin/plugin.json" ] && grep -q '"name": "ace"' "$D/.claude-plugin/plugin.json" 2>/dev/null; then
    PWD_MATCH="$D"; break
  fi
  D="$(dirname "$D")"
done
if [ -n "$PWD_MATCH" ] && [ "$PWD_MATCH" != "$ROOT" ]; then
  echo "INFO cwd_is_ace_checkout=$PWD_MATCH (pass --here to audit it instead)"
fi

pass() { printf 'PASS %s\n' "$1"; }
warn() { printf 'WARN %s\n' "$1"; [ -n "${2:-}" ] && printf '  fix: %s\n' "$2"; }
fail() { printf 'FAIL %s\n' "$1"; [ -n "${2:-}" ] && printf '  fix: %s\n' "$2"; }

# --- Version consistency ---
VER_FILE="$(tr -d '[:space:]' < "$ROOT/VERSION" 2>/dev/null || echo missing)"
VER_PLUGIN="$(node -e "console.log(require('$ROOT/.claude-plugin/plugin.json').version);" 2>/dev/null || echo missing)"
VER_MARKET="$(node -e "console.log(require('$ROOT/.claude-plugin/marketplace.json').plugins[0].version);" 2>/dev/null || echo missing)"
VER_PKG="$(node -e "console.log(require('$ROOT/package.json').version);" 2>/dev/null || echo missing)"

if [ "$VER_FILE" = "$VER_PLUGIN" ] && [ "$VER_PLUGIN" = "$VER_MARKET" ] && [ "$VER_MARKET" = "$VER_PKG" ]; then
  pass "version_consistency: all four sources agree on $VER_FILE"
else
  warn "version_consistency: VERSION=$VER_FILE plugin.json=$VER_PLUGIN marketplace.json=$VER_MARKET package.json=$VER_PKG" "bump all four in a single commit when releasing"
fi

# --- Node / npm ---
if command -v node >/dev/null 2>&1; then
  pass "node: $(node --version)"
else
  fail "node: not on PATH" "install Node.js v18+"
fi

if command -v npm >/dev/null 2>&1; then
  pass "npm: $(npm --version)"
else
  fail "npm: not on PATH" "install Node.js v18+ (bundles npm)"
fi

# --- node_modules + tsx ---
if [ -d "$ROOT/node_modules" ] && [ -x "$ROOT/node_modules/.bin/tsx" ]; then
  pass "deps: node_modules present, tsx=$("$ROOT/node_modules/.bin/tsx" --version 2>&1 | head -1)"
else
  fail "deps: node_modules missing or tsx not installed at $ROOT" "run /ace:setup (or 'npm install' in $ROOT)"
fi

# --- Google service-account key ---
# Canonical: $CLAUDE_PLUGIN_DATA/gws-sa-key.json — survives plugin updates.
# Legacy: $ROOT/.gws-sa-key.json — for pre-migration installs.
if [ -n "${CLAUDE_PLUGIN_DATA:-}" ]; then
  DATA_DIR="$CLAUDE_PLUGIN_DATA"
else
  DATA_DIR="$HOME/.claude/plugins/data/ace-ace"
fi
CANONICAL_KEY="$DATA_DIR/gws-sa-key.json"
LEGACY_KEY="$ROOT/.gws-sa-key.json"

KEY=""
KEY_LOC=""
if [ -f "$CANONICAL_KEY" ] && [ -r "$CANONICAL_KEY" ]; then
  KEY="$CANONICAL_KEY"; KEY_LOC="canonical"
elif [ -f "$LEGACY_KEY" ] && [ -r "$LEGACY_KEY" ]; then
  KEY="$LEGACY_KEY"; KEY_LOC="legacy"
fi

if [ -n "$KEY" ]; then
  CE="$(node -e "try { console.log(JSON.parse(require('fs').readFileSync('$KEY','utf8')).client_email); } catch(e) { console.log('unreadable'); }" 2>/dev/null || echo unreadable)"
  if [ "$CE" = "unreadable" ]; then
    fail "gws_key: $KEY is not valid JSON" "re-drop the service-account key"
  elif [ "$KEY_LOC" = "legacy" ]; then
    warn "gws_key: $CE at LEGACY path $LEGACY_KEY" "migrate to $CANONICAL_KEY so it survives plugin updates: mv \"$LEGACY_KEY\" \"$CANONICAL_KEY\" && chmod 600 \"$CANONICAL_KEY\""
  else
    pass "gws_key: $CE at $CANONICAL_KEY"
  fi
else
  fail "gws_key: missing (checked $CANONICAL_KEY and $LEGACY_KEY)" "mkdir -p \"$DATA_DIR\" && drop the service-account JSON at $CANONICAL_KEY (ask Jon for the ACE key)"
fi

# --- .mcp.json sanity ---
if [ -f "$ROOT/.mcp.json" ]; then
  MCP_NAMES="$(node -e "const m=require('$ROOT/.mcp.json'); console.log(Object.keys(m).join(','));" 2>/dev/null || echo parse_error)"
  if [ "$MCP_NAMES" = "parse_error" ]; then
    fail "mcp_manifest: .mcp.json does not parse" "verify JSON syntax"
  else
    pass "mcp_manifest: servers=$MCP_NAMES"
    case "$MCP_NAMES" in
      *ace-gdrive*) ;;
      *) warn "mcp_manifest: ace-gdrive not declared" "restore the ace-gdrive entry in .mcp.json" ;;
    esac
  fi
else
  fail "mcp_manifest: .mcp.json missing" "restore .mcp.json at the plugin root"
fi

# --- ace-update-check binary ---
if [ -x "$ROOT/bin/ace-update-check" ]; then
  pass "update_check: bin/ace-update-check executable"
else
  warn "update_check: bin/ace-update-check missing or not executable" "chmod +x $ROOT/bin/ace-update-check"
fi

# --- Auto-update hook (hooks/hooks.json) ---
if [ -f "$ROOT/hooks/hooks.json" ]; then
  if grep -q "ace-update-check" "$ROOT/hooks/hooks.json" 2>/dev/null; then
    pass "auto_update: hooks/hooks.json declares SessionStart update check"
  else
    warn "auto_update: hooks/hooks.json exists but does not reference ace-update-check" "verify hooks/hooks.json content"
  fi
else
  warn "auto_update: hooks/hooks.json missing" "restore hooks/hooks.json at the plugin root"
fi

# --- Related repos (optional, soft warnings) ---
if [ -d "$HOME/emdash-projects/ace-web" ] || [ -d "$HOME/ace-web" ]; then
  pass "ace_web: local checkout detected"
else
  warn "ace_web: no local checkout of jjackson/ace-web found" "clone if you need the browser harness"
fi

if command -v connect-mcp >/dev/null 2>&1 || [ -d "$HOME/emdash-projects/connect-labs" ]; then
  pass "connect_labs: available"
else
  warn "connect_labs: not detected" "install separately if skills need CommCare/Connect MCP tools"
fi

# --- Runtime readiness (things needed to actually run an opportunity) ---
# These are all WARN, not FAIL: a user who only wants design-review runs
# doesn't need OCS/Gmail configured. But doctor-green should still tell
# them what's unset so they see the wall before they hit it at Phase 4.

# Prefer the plugin-data .env (persistent across updates). Fall back to a
# dev checkout's ./.env if that's where the user keeps their secrets.
ENV_FILE=""
if [ -f "$DATA_DIR/.env" ]; then
  ENV_FILE="$DATA_DIR/.env"
elif [ -f "$ROOT/.env" ]; then
  ENV_FILE="$ROOT/.env"
fi

if [ -n "$ENV_FILE" ]; then
  pass "env_file: $ENV_FILE"
else
  warn "env_file: no .env found (checked $DATA_DIR/.env and $ROOT/.env)" "op inject -i \"$ROOT/.env.tpl\" -o \"$DATA_DIR/.env\" --account dimagi.1password.com"
fi

# get_env KEY — prints the value of KEY from $ENV_FILE, or empty if absent/unresolved.
# Strips surrounding quotes and treats unresolved 1Password refs (op://...) as empty.
get_env() {
  [ -z "$ENV_FILE" ] && return
  local raw
  raw="$(grep -E "^[[:space:]]*$1=" "$ENV_FILE" 2>/dev/null | tail -1 | sed -E "s/^[[:space:]]*$1=//; s/^['\"]//; s/['\"]$//")"
  case "$raw" in
    op://*) return ;;  # unresolved 1Password reference — treat as missing
    *) printf '%s' "$raw" ;;
  esac
}

if [ -n "$ENV_FILE" ]; then
  OCS_BASE="$(get_env OCS_BASE_URL)"
  OCS_TEAM="$(get_env OCS_TEAM_SLUG)"
  OCS_GTID="$(get_env OCS_GOLDEN_TEMPLATE_ID)"
  GMAIL_ACCT="$(get_env ACE_GMAIL_ACCOUNT)"
  DRIVE_ROOT="$(get_env ACE_DRIVE_ROOT_FOLDER_ID)"
  SHARED_COLL="$(get_env OCS_SHARED_COLLECTION_ID)"
  LLM_PROV="$(get_env OCS_LLM_PROVIDER_ID)"
  EMBED_MODEL="$(get_env OCS_EMBEDDING_MODEL_ID)"

  if [ -n "$OCS_BASE" ] && [ -n "$OCS_TEAM" ] && [ -n "$OCS_GTID" ]; then
    pass "ocs_env: base=$OCS_BASE team=$OCS_TEAM golden_template=$OCS_GTID"
  else
    missing=""
    [ -z "$OCS_BASE" ] && missing="$missing OCS_BASE_URL"
    [ -z "$OCS_TEAM" ] && missing="$missing OCS_TEAM_SLUG"
    [ -z "$OCS_GTID" ] && missing="$missing OCS_GOLDEN_TEMPLATE_ID"
    hint="re-inject .env via 1Password, or run /ace:ocs-bootstrap-template (for OCS_GOLDEN_TEMPLATE_ID)"
    warn "ocs_env: missing or unresolved:$missing" "$hint"
  fi

  # Drive root folder — required by /ace:run's smart-default PDD picker
  # (agents/ace-orchestrator.md § Starting a New Opportunity). Without this,
  # the picker falls through to the inline-paste fallback with no signal
  # that the env var is the cause.
  if [ -n "$DRIVE_ROOT" ]; then
    pass "drive_root: ACE_DRIVE_ROOT_FOLDER_ID=$DRIVE_ROOT"
  else
    warn "drive_root: ACE_DRIVE_ROOT_FOLDER_ID not set (PDD auto-discovery disabled)" "re-inject .env via op inject (var added in 0.5.3)"
  fi

  # Shared collection triple — required by ocs-agent-setup for per-opp bot
  # clones to inherit Connect knowledge. Without these, cloned bots publish
  # with empty RAG and silently answer from base LLM only.
  # (2026-04-20 run log P1 backlog; see learnings.md "Metadata files as hypotheses".)
  if [ -n "$SHARED_COLL" ] && [ -n "$LLM_PROV" ] && [ -n "$EMBED_MODEL" ]; then
    pass "ocs_shared_collection: id=$SHARED_COLL provider=$LLM_PROV embedding=$EMBED_MODEL"
  else
    sc_missing=""
    [ -z "$SHARED_COLL" ] && sc_missing="$sc_missing OCS_SHARED_COLLECTION_ID"
    [ -z "$LLM_PROV" ] && sc_missing="$sc_missing OCS_LLM_PROVIDER_ID"
    [ -z "$EMBED_MODEL" ] && sc_missing="$sc_missing OCS_EMBEDDING_MODEL_ID"
    warn "ocs_shared_collection: missing or unresolved:$sc_missing (per-opp bots will have empty RAG)" "re-inject .env via op inject (vars added in 0.5.1)"
  fi

  if [ -n "$GMAIL_ACCT" ]; then
    pass "gmail_config: ACE_GMAIL_ACCOUNT=$GMAIL_ACCT"
  else
    warn "gmail_config: ACE_GMAIL_ACCOUNT not set" "re-inject .env via 1Password"
  fi

  # Catch-all: any future .env.tpl addition that the installed .env hasn't
  # picked up yet. Diff the KEY= sets; warn with a single line listing
  # whatever is missing. Informational — WARN, not FAIL (per learnings.md
  # "Runtime-health checks should be WARN, not FAIL").
  if [ -f "$ROOT/.env.tpl" ]; then
    TPL_KEYS="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ROOT/.env.tpl" 2>/dev/null | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
    ENV_KEYS="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ENV_FILE" 2>/dev/null | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
    ENV_DIFF="$(comm -23 <(printf '%s\n' "$TPL_KEYS") <(printf '%s\n' "$ENV_KEYS") | tr '\n' ' ' | sed 's/ *$//')"
    if [ -n "$ENV_DIFF" ]; then
      warn "env_drift: $ENV_FILE is missing keys from .env.tpl: $ENV_DIFF" "op inject -i \"$ROOT/.env.tpl\" -o \"$ENV_FILE\" --account dimagi.1password.com (preserves 1Password-backed values)"
    else
      pass "env_drift: $ENV_FILE has every key declared in .env.tpl"
    fi

    # Class-level preventer: any key declared in .env.tpl but with zero
    # consumers in actual code is dead ceremony — it gets injected, eats
    # a 1Password lookup, and adds a paste-this line nobody needs. Grep
    # every TPL_KEY against the code-bearing dirs; warn on any hit with
    # zero consumers. Docs (README/CHANGELOG/runs/playbook) don't count.
    # Added 0.5.7 after the bootstrap-output audit found three dead vars.
    UNUSED=""
    CODE_DIRS="mcp lib scripts skills bin hooks agents commands test"
    for key in $TPL_KEYS; do
      HITS="$(cd "$ROOT" && grep -rE "\\b$key\\b" $CODE_DIRS 2>/dev/null | head -1)"
      if [ -z "$HITS" ]; then
        UNUSED="$UNUSED $key"
      fi
    done
    UNUSED="$(printf '%s' "$UNUSED" | sed 's/^ //')"
    if [ -n "$UNUSED" ]; then
      warn "unused_env_keys: declared in .env.tpl but never read by code: $UNUSED" "drop them from .env.tpl, or wire them into a consumer (mcp/ lib/ scripts/ skills/ bin/ hooks/ agents/ commands/ test/)"
    else
      pass "unused_env_keys: every .env.tpl key has at least one consumer"
    fi
  fi

  # OCS Playwright session — keyed by team slug. Required before any skill
  # that hits OCS via the Playwright backend (most of Phase 4).
  if [ -n "$OCS_TEAM" ]; then
    SESS="$HOME/.ace/ocs-session-$OCS_TEAM.json"
    if [ -f "$SESS" ]; then
      # freshness check: warn if > 30 days old (session cookies expire)
      if find "$SESS" -mtime +30 2>/dev/null | grep -q .; then
        warn "ocs_session: $SESS is older than 30 days — may be expired" "/ace:ocs-login"
      else
        pass "ocs_session: $SESS present"
      fi
    else
      warn "ocs_session: $SESS missing" "/ace:ocs-login"
    fi
  else
    # No team slug — can't check for a session file. Already warned on ocs_env.
    :
  fi
else
  # No .env at all — individual env-derived checks would all warn the same way.
  # Emit one consolidated pointer instead of three duplicates.
  warn "runtime_env: ocs_env, gmail_config, ocs_session all skipped (no .env)" "resolve env_file warning above first"
fi

echo ""
echo "STATUS: COMPLETE"
