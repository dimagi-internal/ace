#!/usr/bin/env bash
# ace-doctor — health checks for an ACE plugin install.
#
# By default audits the plugin copy this script ships with (i.e. $(dirname $0)/..).
# That's the right answer when launched via the /ace:doctor slash command, because
# Claude Code loads slash command bodies from the installed plugin copy, and the
# launcher execs bin/ace-doctor from that same copy.
#
# Overrides:
#   ACE_DIR=/path/to/ace      audit a specific plugin root
#   --here                    walk up from $PWD to find an ACE checkout (dev mode)
#   --installed               force use of the newest ~/.claude/plugins/cache/ace/ace/*
#
# Exit status: 0 always (check results go to stdout as PASS/WARN/FAIL lines).
set +e

SELF_DIR="$(cd "$(dirname "$0")/.." && pwd)"
MODE="self"
ROOT=""
SUBCOMMAND=""
SUB_OPP=""

# Sub-commands run before the standard check pipeline. Today only `verdicts <opp>`
# is supported — fetches ACE/<opp>/verdicts/ from Drive and validates each YAML
# against lib/verdict-schema.ts via parseVerdictYaml. Class-level preventer at
# the operator boundary (test/lib/real-verdict-validation.test.ts covers fixtures;
# this covers live opp output).
if [ "${1:-}" = "verdicts" ]; then
  SUBCOMMAND="verdicts"
  shift
  if [ -z "${1:-}" ]; then
    echo "usage: ace-doctor verdicts <opp-name>" >&2
    exit 2
  fi
  SUB_OPP="$1"
  shift
elif [ "${1:-}" = "state-yaml-lint" ]; then
  SUBCOMMAND="state-yaml-lint"
  shift
  if [ -z "${1:-}" ]; then
    echo "usage: ace-doctor state-yaml-lint <opp-name>" >&2
    exit 2
  fi
  SUB_OPP="$1"
  shift
fi

while [ $# -gt 0 ]; do
  case "$1" in
    --here)       MODE="pwd" ;;
    --installed)  MODE="installed" ;;
    --root)       shift; ROOT="$1" ;;
    *)            echo "ace-doctor: unknown arg: $1" >&2; exit 2 ;;
  esac
  shift
done

# Root resolution
if [ -n "${ACE_DIR:-}" ]; then
  ROOT="$ACE_DIR"
elif [ -n "$ROOT" ]; then
  :  # already set via --root
elif [ "$MODE" = "pwd" ]; then
  D="$PWD"
  while [ "$D" != "/" ]; do
    if [ -f "$D/.claude-plugin/plugin.json" ] && grep -q '"name": "ace"' "$D/.claude-plugin/plugin.json" 2>/dev/null; then
      ROOT="$D"; break
    fi
    D="$(dirname "$D")"
  done
elif [ "$MODE" = "installed" ]; then
  # Prefer the authoritative install path Claude Code records in
  # ~/.claude/plugins/installed_plugins.json. Fall back to version-sorted
  # newest directory under the cache if that file is missing or unreadable.
  REG="$HOME/.claude/plugins/installed_plugins.json"
  if [ -f "$REG" ]; then
    ROOT="$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$REG','utf8')); const e=d['ace@ace']; if(Array.isArray(e)){for(const x of e){if(x&&x.installPath){console.log(x.installPath);break;}}} else if(e&&e.installPath){console.log(e.installPath);} } catch(_) {}" 2>/dev/null)"
  fi
  if [ -z "$ROOT" ] || [ ! -f "$ROOT/.claude-plugin/plugin.json" ]; then
    ROOT="$(ls -1d "$HOME"/.claude/plugins/cache/ace/ace/*/ 2>/dev/null | sed 's:/$::' | sort -V | tail -1)"
  fi
else
  # Default: self — audit the plugin copy this script lives in.
  ROOT="$SELF_DIR"
fi

if [ -z "$ROOT" ] || [ ! -f "$ROOT/.claude-plugin/plugin.json" ]; then
  echo "FAIL plugin_root_not_found: could not locate ACE plugin (mode=$MODE)"
  echo "  fix: run from an ACE checkout, or after /plugin install ace@ace, or pass --root /path"
  exit 0
fi

echo "INFO plugin_root=$ROOT (mode=$MODE)"

# Dispatch sub-commands. Sub-commands short-circuit the rest of the script.
if [ "$SUBCOMMAND" = "verdicts" ]; then
  if [ ! -f "$ROOT/scripts/validate-opp-verdicts.ts" ]; then
    echo "FAIL verdicts_subcommand: $ROOT/scripts/validate-opp-verdicts.ts not found"
    echo "  fix: run /ace:update to pull a version that ships the validator (>= 0.10.29)"
    exit 0
  fi
  cd "$ROOT" && exec npx tsx scripts/validate-opp-verdicts.ts "$SUB_OPP"
fi

if [ "$SUBCOMMAND" = "state-yaml-lint" ]; then
  if [ ! -f "$ROOT/scripts/lint-opp-state.ts" ]; then
    echo "FAIL state-yaml-lint_subcommand: $ROOT/scripts/lint-opp-state.ts not found"
    echo "  fix: run /ace:update to pull a version that ships the lint (>= 0.11.6)"
    exit 0
  fi
  cd "$ROOT" && exec npx tsx scripts/lint-opp-state.ts "$SUB_OPP"
fi

# If the user is inside a dev worktree that differs from $ROOT, flag it so they
# know the doctor is auditing the installed copy rather than their checkout.
PWD_MATCH=""
D="$PWD"
while [ "$D" != "/" ]; do
  if [ -f "$D/.claude-plugin/plugin.json" ] && grep -q '"name": "ace"' "$D/.claude-plugin/plugin.json" 2>/dev/null; then
    PWD_MATCH="$D"; break
  fi
  D="$(dirname "$D")"
done
if [ -n "$PWD_MATCH" ] && [ "$PWD_MATCH" != "$ROOT" ]; then
  echo "INFO cwd_is_ace_checkout=$PWD_MATCH (pass --here to audit it instead)"
fi

pass() { printf 'PASS %s\n' "$1"; }
warn() { printf 'WARN %s\n' "$1"; [ -n "${2:-}" ] && printf '  fix: %s\n' "$2"; }
fail() { printf 'FAIL %s\n' "$1"; [ -n "${2:-}" ] && printf '  fix: %s\n' "$2"; }
# No _log() abstraction in this script; mirrors the pass/warn/fail printf pattern.
info() { printf 'INFO %s\n' "$1"; }

# --- Version consistency ---
VER_FILE="$(tr -d '[:space:]' < "$ROOT/VERSION" 2>/dev/null || echo missing)"
VER_PLUGIN="$(node -e "console.log(require('$ROOT/.claude-plugin/plugin.json').version);" 2>/dev/null || echo missing)"
VER_MARKET="$(node -e "console.log(require('$ROOT/.claude-plugin/marketplace.json').plugins[0].version);" 2>/dev/null || echo missing)"
VER_PKG="$(node -e "console.log(require('$ROOT/package.json').version);" 2>/dev/null || echo missing)"

if [ "$VER_FILE" = "$VER_PLUGIN" ] && [ "$VER_PLUGIN" = "$VER_MARKET" ] && [ "$VER_MARKET" = "$VER_PKG" ]; then
  pass "version_consistency: all four sources agree on $VER_FILE"
else
  warn "version_consistency: VERSION=$VER_FILE plugin.json=$VER_PLUGIN marketplace.json=$VER_MARKET package.json=$VER_PKG" "bump all four in a single commit when releasing"
fi

# --- Running session vs installed registry ---
# After `/ace:update` lands a new cache dir, the running session keeps
# using the OLD plugin path until the session is reloaded. Slash commands
# get the new bodies on next invocation, but MCP servers only re-launch
# on `/reload-plugins` or a fresh session. The canonical symptom is "No
# such tool available: connect_<atom>" right after an update — the registry
# points at v0.10.21 but the MCP server is still running v0.10.20's binaries.
#
# Detect: compare $ROOT's VERSION against the version recorded in
# installed_plugins.json. They should match. If they don't, surface as a
# WARN with the actionable fix (`/reload-plugins` or restart the session).
REG_VER=""
REG_PATH=""
if [ -f "$HOME/.claude/plugins/installed_plugins.json" ]; then
  REG_VER="$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$HOME/.claude/plugins/installed_plugins.json','utf8')); const e=d['ace@ace']||(d.plugins&&d.plugins['ace@ace']); const v=Array.isArray(e)?e[0]:e; console.log(v&&v.version||''); } catch(_) {}" 2>/dev/null)"
  REG_PATH="$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$HOME/.claude/plugins/installed_plugins.json','utf8')); const e=d['ace@ace']||(d.plugins&&d.plugins['ace@ace']); const v=Array.isArray(e)?e[0]:e; console.log(v&&v.installPath||''); } catch(_) {}" 2>/dev/null)"
fi
if [ -n "$REG_VER" ] && [ "$VER_FILE" != "missing" ]; then
  if [ "$REG_VER" = "$VER_FILE" ]; then
    pass "session_freshness: running v$VER_FILE matches registry"
  else
    warn "session_freshness: running v$VER_FILE but registry has v$REG_VER at $REG_PATH" "MCP servers still use the running session's binaries — run /reload-plugins (or restart this Claude Code session) to pick up registry version. Symptom of stale state: 'No such tool available: connect_*' after /ace:update."
  fi
fi

# --- Node / npm ---
if command -v node >/dev/null 2>&1; then
  pass "node: $(node --version)"
else
  fail "node: not on PATH" "install Node.js v18+"
fi

if command -v npm >/dev/null 2>&1; then
  pass "npm: $(npm --version)"
else
  fail "npm: not on PATH" "install Node.js v18+ (bundles npm)"
fi

# --- node_modules + tsx ---
if [ -d "$ROOT/node_modules" ] && [ -x "$ROOT/node_modules/.bin/tsx" ]; then
  pass "deps: node_modules present, tsx=$("$ROOT/node_modules/.bin/tsx" --version 2>&1 | head -1)"
else
  fail "deps: node_modules missing or tsx not installed at $ROOT" "run /ace:setup (or 'npm install' in $ROOT)"
fi

# --- Google service-account key ---
# Canonical: $CLAUDE_PLUGIN_DATA/gws-sa-key.json — survives plugin updates.
# Legacy: $ROOT/.gws-sa-key.json — for pre-migration installs.
if [ -n "${CLAUDE_PLUGIN_DATA:-}" ]; then
  DATA_DIR="$CLAUDE_PLUGIN_DATA"
else
  DATA_DIR="$HOME/.claude/plugins/data/ace-ace"
fi
CANONICAL_KEY="$DATA_DIR/gws-sa-key.json"
LEGACY_KEY="$ROOT/.gws-sa-key.json"

KEY=""
KEY_LOC=""
if [ -f "$CANONICAL_KEY" ] && [ -r "$CANONICAL_KEY" ]; then
  KEY="$CANONICAL_KEY"; KEY_LOC="canonical"
elif [ -f "$LEGACY_KEY" ] && [ -r "$LEGACY_KEY" ]; then
  KEY="$LEGACY_KEY"; KEY_LOC="legacy"
fi

if [ -n "$KEY" ]; then
  CE="$(node -e "try { console.log(JSON.parse(require('fs').readFileSync('$KEY','utf8')).client_email); } catch(e) { console.log('unreadable'); }" 2>/dev/null || echo unreadable)"
  if [ "$CE" = "unreadable" ]; then
    fail "gws_key: $KEY is not valid JSON" "re-drop the service-account key"
  elif [ "$KEY_LOC" = "legacy" ]; then
    warn "gws_key: $CE at LEGACY path $LEGACY_KEY" "migrate to $CANONICAL_KEY so it survives plugin updates: mv \"$LEGACY_KEY\" \"$CANONICAL_KEY\" && chmod 600 \"$CANONICAL_KEY\""
  else
    pass "gws_key: $CE at $CANONICAL_KEY"
  fi
else
  fail "gws_key: missing (checked $CANONICAL_KEY and $LEGACY_KEY)" "mkdir -p \"$DATA_DIR\" && drop the service-account JSON at $CANONICAL_KEY (ask Jon for the ACE key)"
fi

# --- MCP manifest sanity ---
# As of 0.5.16 MCP servers live inline in plugin.json under "mcpServers",
# NOT in a separate .mcp.json at plugin root. See
# https://github.com/anthropics/claude-code/issues/9427 — Claude Code fails
# to expand ${CLAUDE_PLUGIN_ROOT}/${CLAUDE_PLUGIN_DATA} when a plugin declares
# its servers via plugin-root .mcp.json, but the expansion works correctly
# when declared inline in plugin.json.
PLUGIN_JSON="$ROOT/.claude-plugin/plugin.json"
if [ -f "$PLUGIN_JSON" ]; then
  MCP_NAMES="$(node -e "const m=require('$PLUGIN_JSON'); console.log(Object.keys(m.mcpServers||{}).join(','));" 2>/dev/null || echo parse_error)"
  if [ "$MCP_NAMES" = "parse_error" ]; then
    fail "mcp_manifest: plugin.json does not parse" "verify JSON syntax"
  elif [ -z "$MCP_NAMES" ]; then
    fail "mcp_manifest: plugin.json has no mcpServers block" "restore the mcpServers object with ace-gdrive and ace-ocs"
  else
    pass "mcp_manifest: servers=$MCP_NAMES (inline in plugin.json)"
    case "$MCP_NAMES" in
      *ace-gdrive*) ;;
      *) warn "mcp_manifest: ace-gdrive not declared" "restore the ace-gdrive entry in plugin.json mcpServers" ;;
    esac
  fi
else
  fail "mcp_manifest: .claude-plugin/plugin.json missing" "restore plugin.json at the plugin root"
fi

# --- Stale .mcp.json guard ---
# If both a plugin.json mcpServers block AND a .mcp.json exist, warn — the
# legacy .mcp.json hits the upstream substitution bug (9427) and will shadow
# silently on versions where Claude Code merges the two sources.
if [ -f "$ROOT/.mcp.json" ]; then
  warn "mcp_manifest: stale .mcp.json present at plugin root" "delete $ROOT/.mcp.json — MCP servers now live inline in plugin.json (see 9427)"
fi

# --- MCP env passthrough check ---
# Catch the class of silent-stall fixed in 0.5.7: an MCP server source that
# uses `dotenv` to load `$CLAUDE_PLUGIN_DATA/.env` but whose plugin.json
# mcpServers entry has no env block passing CLAUDE_PLUGIN_DATA through. The
# subprocess spawns with an empty process.env.CLAUDE_PLUGIN_DATA, dotenv
# silently falls back to ./.env (subprocess cwd), the real .env is never
# loaded, every secret reads as undefined, and downstream API calls get
# 401/403 with no clear signal that the env var was the root cause.
#
# This check is static: parse plugin.json, look at each server's args for a
# .ts/.js source path, read that source, check for the dotenv+CLAUDE_PLUGIN_DATA
# pattern, then verify the plugin.json env block includes CLAUDE_PLUGIN_DATA.
if [ -f "$PLUGIN_JSON" ] && [ "$MCP_NAMES" != "parse_error" ] && [ -n "$MCP_NAMES" ]; then
  MCP_ENV_ISSUES="$(node -e "
    const fs = require('fs');
    const path = require('path');
    const root = '$ROOT';
    const plugin = JSON.parse(fs.readFileSync(path.join(root, '.claude-plugin', 'plugin.json'), 'utf8'));
    const servers = plugin.mcpServers || {};
    const issues = [];
    for (const [name, cfg] of Object.entries(servers)) {
      if (!cfg || typeof cfg !== 'object') continue;
      // Resolve the source file: the last .ts or .js arg, with \${CLAUDE_PLUGIN_ROOT} expanded.
      const args = Array.isArray(cfg.args) ? cfg.args : [];
      const src = args.filter(a => typeof a === 'string' && /\\.(ts|js)$/.test(a)).pop();
      if (!src) continue;
      const resolved = src.replace(/\\\$\\{CLAUDE_PLUGIN_ROOT\\}/g, root);
      let body = '';
      try { body = fs.readFileSync(resolved, 'utf8'); } catch (_) { continue; }
      // Does this server read process.env.CLAUDE_PLUGIN_DATA to locate .env?
      const usesPluginData = /process\\.env\\.CLAUDE_PLUGIN_DATA/.test(body) && /dotenv|dotenvConfig|\\brequire\\s*\\(\\s*[\"']dotenv/.test(body);
      if (!usesPluginData) continue;
      // If it does, the plugin.json env block MUST pass CLAUDE_PLUGIN_DATA through.
      const env = (cfg.env && typeof cfg.env === 'object') ? cfg.env : {};
      if (!('CLAUDE_PLUGIN_DATA' in env)) {
        issues.push(name);
      }
    }
    if (issues.length) console.log(issues.join(','));
  " 2>/dev/null)"
  if [ -n "$MCP_ENV_ISSUES" ]; then
    warn "mcp_env_passthrough: servers loading \$CLAUDE_PLUGIN_DATA/.env without env passthrough: $MCP_ENV_ISSUES (silent 401/403 on every tool call)" "add \"CLAUDE_PLUGIN_DATA\": \"\\\${CLAUDE_PLUGIN_DATA}\" to each server's env block in plugin.json mcpServers"
  else
    pass "mcp_env_passthrough: every MCP server that needs CLAUDE_PLUGIN_DATA receives it"
  fi
fi

# --- ace-update-check binary ---
if [ -x "$ROOT/bin/ace-update-check" ]; then
  pass "update_check: bin/ace-update-check executable"
else
  warn "update_check: bin/ace-update-check missing or not executable" "chmod +x $ROOT/bin/ace-update-check"
fi

# --- Auto-update hook (hooks/hooks.json) ---
if [ -f "$ROOT/hooks/hooks.json" ]; then
  if grep -q "ace-update-check" "$ROOT/hooks/hooks.json" 2>/dev/null; then
    pass "auto_update: hooks/hooks.json declares SessionStart update check"
  else
    warn "auto_update: hooks/hooks.json exists but does not reference ace-update-check" "verify hooks/hooks.json content"
  fi
else
  warn "auto_update: hooks/hooks.json missing" "restore hooks/hooks.json at the plugin root"
fi

# --- Sibling plugin installs (Phase 2 + Phase 3 dependencies) ---
# (ace-web is a sibling repo for browser-harness work but is NOT a runtime
# dependency of the plugin — intentionally not checked here. Sibling plugins
# below ARE consumed by ACE skills, so they remain warned-on.)
# Nova drives Phase 2 (commcare-setup): pdd-to-learn-app, pdd-to-deliver-app,
# app-deploy. Without Nova installed, those skills produce stub artifacts.
# connect-labs drives Phase 3 (connect-setup): connect-program-setup,
# connect-opp-setup. Without it, the skills can't actually create programs
# or opportunities. Both failure modes are silent — the skills run, write
# something, and the operator only notices days later when nothing works.
# The signal we can check from here is simple and authoritative: is the
# plugin listed in ~/.claude/plugins/installed_plugins.json?
PLUGIN_REG="$HOME/.claude/plugins/installed_plugins.json"

probe_plugin() {
  # probe_plugin <pattern> — print the matched plugin key (or empty).
  # Pattern matches against keys in installed_plugins.json (e.g., "nova@" or "connect-labs").
  [ -f "$PLUGIN_REG" ] || return
  node -e "
    try {
      const d = JSON.parse(require('fs').readFileSync('$PLUGIN_REG','utf8'));
      const plugins = d.plugins || d;
      const pat = '$1';
      for (const k of Object.keys(plugins)) {
        if (k.indexOf(pat) !== -1) { console.log(k); break; }
      }
    } catch(_) {}
  " 2>/dev/null
}

NOVA_KEY="$(probe_plugin nova)"
if [ -n "$NOVA_KEY" ]; then
  pass "nova_plugin: $NOVA_KEY installed"
else
  warn "nova_plugin: not installed (Phase 2 commcare-setup degrades to HITL stubs — pdd-to-learn-app, pdd-to-deliver-app, app-deploy will not produce real apps)" "/plugin install nova@nova-marketplace, then sign in via OAuth on first /nova:autobuild"
fi

CL_KEY="$(probe_plugin connect-labs)"
if [ -n "$CL_KEY" ]; then
  pass "connect_labs_plugin: $CL_KEY installed"
else
  warn "connect_labs_plugin: not installed (Phase 3 connect-setup degrades to HITL — connect-program-setup, connect-opp-setup cannot create programs or opportunities)" "install the connect-labs plugin from its marketplace"
fi

# Local checkout is still useful for development; keep as a soft hint.
if [ -d "$HOME/emdash-projects/connect-labs" ]; then
  pass "connect_labs_repo: local checkout detected (dev mode)"
fi

# --- Runtime readiness (things needed to actually run an opportunity) ---
# These are all WARN, not FAIL: a user who only wants design-review runs
# doesn't need OCS/Gmail configured. But doctor-green should still tell
# them what's unset so they see the wall before they hit it at Phase 4.

# Prefer the plugin-data .env (persistent across updates). Fall back to a
# dev checkout's ./.env if that's where the user keeps their secrets.
ENV_FILE=""
if [ -f "$DATA_DIR/.env" ]; then
  ENV_FILE="$DATA_DIR/.env"
elif [ -f "$ROOT/.env" ]; then
  ENV_FILE="$ROOT/.env"
fi

if [ -n "$ENV_FILE" ]; then
  pass "env_file: $ENV_FILE"
else
  warn "env_file: no .env found (checked $DATA_DIR/.env and $ROOT/.env)" "op inject -i \"$ROOT/.env.tpl\" -o \"$DATA_DIR/.env\" --account dimagi.1password.com"
fi

# get_env KEY — prints the value of KEY from $ENV_FILE, or empty if absent/unresolved.
# Strips surrounding quotes and treats unresolved 1Password refs (op://...) as empty.
get_env() {
  [ -z "$ENV_FILE" ] && return
  local raw
  raw="$(grep -E "^[[:space:]]*$1=" "$ENV_FILE" 2>/dev/null | tail -1 | sed -E "s/^[[:space:]]*$1=//; s/^['\"]//; s/['\"]$//")"
  case "$raw" in
    op://*) return ;;  # unresolved 1Password reference — treat as missing
    *) printf '%s' "$raw" ;;
  esac
}

if [ -n "$ENV_FILE" ]; then
  OCS_BASE="$(get_env OCS_BASE_URL)"
  OCS_TEAM="$(get_env OCS_TEAM_SLUG)"
  OCS_GTID="$(get_env OCS_GOLDEN_TEMPLATE_ID)"
  GMAIL_ACCT="$(get_env ACE_GMAIL_ACCOUNT)"
  DRIVE_ROOT="$(get_env ACE_DRIVE_ROOT_FOLDER_ID)"
  SHARED_COLL="$(get_env OCS_SHARED_COLLECTION_ID)"
  LLM_PROV="$(get_env OCS_LLM_PROVIDER_ID)"
  EMBED_MODEL="$(get_env OCS_EMBEDDING_MODEL_ID)"

  if [ -n "$OCS_BASE" ] && [ -n "$OCS_TEAM" ] && [ -n "$OCS_GTID" ]; then
    pass "ocs_env: base=$OCS_BASE team=$OCS_TEAM golden_template=$OCS_GTID"
  else
    missing=""
    [ -z "$OCS_BASE" ] && missing="$missing OCS_BASE_URL"
    [ -z "$OCS_TEAM" ] && missing="$missing OCS_TEAM_SLUG"
    [ -z "$OCS_GTID" ] && missing="$missing OCS_GOLDEN_TEMPLATE_ID"
    hint="re-inject .env via 1Password, or run /ace:ocs-bootstrap-template (for OCS_GOLDEN_TEMPLATE_ID)"
    warn "ocs_env: missing or unresolved:$missing" "$hint"
  fi

  # Drive root folder — required by /ace:run's smart-default PDD picker
  # (agents/ace-orchestrator.md § Starting a New Opportunity). Without this,
  # the picker falls through to the inline-paste fallback with no signal
  # that the env var is the cause.
  if [ -n "$DRIVE_ROOT" ]; then
    pass "drive_root: ACE_DRIVE_ROOT_FOLDER_ID=$DRIVE_ROOT"
  else
    warn "drive_root: ACE_DRIVE_ROOT_FOLDER_ID not set (PDD auto-discovery disabled)" "re-inject .env via op inject (var added in 0.5.3)"
  fi

  # ACE_E2E_AUTH_TOKEN gates the /auth/e2e-login/ shared-secret automation
  # path on labs. Without it, scripted tools like
  # tools/walkthrough/run_chat_e2e.py and the upload-transcript skill
  # cannot drive the deployed ace-web. Token rotates via AWS Secrets
  # Manager; mirrored into deploy/aws/task-definition.json AND should be
  # in .env so local tools and the doctor agree on the value.
  E2E_TOKEN="$(get_env ACE_E2E_AUTH_TOKEN)"
  if [ -n "$E2E_TOKEN" ]; then
    pass "e2e_auth_token: ACE_E2E_AUTH_TOKEN is set (${#E2E_TOKEN} chars)"
  else
    warn "e2e_auth_token: ACE_E2E_AUTH_TOKEN not set" "add to .env (mirror from deploy/aws/task-definition.json or AWS Secrets Manager); needed by tools/walkthrough/run_chat_e2e.py and skills/upload-transcript"
  fi

  # ACE_TRAINING_DECK_TEMPLATE_ID gates the training-deck-build skill.
  # The skill is non-blocking (Phase 6 doesn't require the Slides deck), so
  # a missing template is WARN, not FAIL — but operators should know the
  # training-deck workflow won't produce a deck until they bootstrap it.
  TDID="$(get_env ACE_TRAINING_DECK_TEMPLATE_ID)"
  if [ -n "$TDID" ]; then
    pass "training_deck_template: ACE_TRAINING_DECK_TEMPLATE_ID=$TDID"
  else
    warn "training_deck_template: ACE_TRAINING_DECK_TEMPLATE_ID not set" "run 'npx tsx scripts/bootstrap-training-deck-template.ts' to create the template, then add the ID to 1Password and re-inject .env (training-deck-build skips silently without it)"
  fi

  # Shared-Drive canary: the configured root MUST live on a Google Shared Drive.
  # Service Accounts have zero My-Drive quota, so a My-Drive-parented root means
  # every artifact write fails with "user storage quota exceeded" on the FIRST
  # opportunity created. Files on a Shared Drive carry a non-empty `driveId`;
  # files in My Drive don't. One files.get probe catches the entire class.
  # (2026-04-27, after dogfood run #1 surfaced this as a silent My-Drive fallback.)
  if [ -n "$DRIVE_ROOT" ] && [ -n "$KEY" ] && [ -d "$ROOT/node_modules/googleapis" ]; then
    DRIVE_ROOT_PROBE="$(GOOGLE_APPLICATION_CREDENTIALS="$KEY" node --input-type=module -e "
      import { google } from 'googleapis';
      const auth = new google.auth.GoogleAuth({ keyFile: process.env.GOOGLE_APPLICATION_CREDENTIALS, scopes: ['https://www.googleapis.com/auth/drive'] });
      const drive = google.drive({ version: 'v3', auth });
      try {
        const r = await drive.files.get({ fileId: '$DRIVE_ROOT', fields: 'name, driveId, mimeType', supportsAllDrives: true });
        const driveId = r.data.driveId || '';
        const name = r.data.name || '';
        const mt = r.data.mimeType || '';
        console.log(JSON.stringify({ ok: true, name, driveId, mimeType: mt }));
      } catch (e) {
        console.log(JSON.stringify({ ok: false, message: e.message }));
      }
    " 2>/dev/null)"
    PROBE_OK="$(printf '%s' "$DRIVE_ROOT_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.ok?'1':'0'); } catch { console.log('?'); }" 2>/dev/null)"
    PROBE_DRIVE_ID="$(printf '%s' "$DRIVE_ROOT_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.driveId||''); } catch { console.log(''); }" 2>/dev/null)"
    PROBE_NAME="$(printf '%s' "$DRIVE_ROOT_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.name||''); } catch { console.log(''); }" 2>/dev/null)"
    PROBE_MSG="$(printf '%s' "$DRIVE_ROOT_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.message||''); } catch { console.log(''); }" 2>/dev/null)"
    if [ "$PROBE_OK" = "1" ]; then
      if [ -n "$PROBE_DRIVE_ID" ]; then
        pass "drive_shared: \"$PROBE_NAME\" lives on Shared Drive ($PROBE_DRIVE_ID)"
      else
        fail "drive_shared: \"$PROBE_NAME\" is in My Drive (no driveId) — every artifact write will fail with 'user storage quota exceeded'" "move the folder onto a Shared Drive that the SA is a member of, or set ACE_DRIVE_ROOT_FOLDER_ID to a folder that already lives on one"
      fi
    elif [ -n "$PROBE_MSG" ]; then
      warn "drive_shared: could not probe ACE_DRIVE_ROOT_FOLDER_ID: $PROBE_MSG" "verify the SA has Editor access to the folder; re-inject .env if the ID is stale"
    fi
  fi

  # Multi-run layout sanity: at least one <opp>/inputs/pdd.md should
  # exist under the Drive root. Without one, /ace:run zero-arg fires
  # the new-layout setup error. INFO (not WARN) — first-time installs
  # legitimately have nothing yet.
  if [ -n "$DRIVE_ROOT" ] && [ -n "$KEY" ] && [ -d "$ROOT/node_modules/googleapis" ]; then
    INPUTS_PROBE="$(GOOGLE_APPLICATION_CREDENTIALS="$KEY" node --input-type=module -e "
      import { google } from 'googleapis';
      const auth = new google.auth.GoogleAuth({ keyFile: process.env.GOOGLE_APPLICATION_CREDENTIALS, scopes: ['https://www.googleapis.com/auth/drive'] });
      const drive = google.drive({ version: 'v3', auth });
      try {
        const root = '$DRIVE_ROOT';
        const opps = await drive.files.list({
          q: \`'\${root}' in parents and mimeType='application/vnd.google-apps.folder' and trashed=false\`,
          fields: 'files(id,name)', supportsAllDrives: true, includeItemsFromAllDrives: true, pageSize: 100,
        });
        let count = 0;
        for (const opp of opps.data.files || []) {
          const inputs = await drive.files.list({
            q: \`'\${opp.id}' in parents and name='inputs' and mimeType='application/vnd.google-apps.folder' and trashed=false\`,
            fields: 'files(id)', supportsAllDrives: true, includeItemsFromAllDrives: true,
          });
          const inputsFolders = inputs.data.files || [];
          if (inputsFolders.length === 0) continue;
          const inputsId = inputsFolders[0].id;
          const pddCheck = await drive.files.list({
            q: \`'\${inputsId}' in parents and trashed=false\`,
            fields: 'files(id,name)', supportsAllDrives: true, includeItemsFromAllDrives: true, pageSize: 50,
          });
          const hasPdd = (pddCheck.data.files || []).some(f =>
            f.name === 'pdd.md' || f.name === 'pdd.gdoc' || /pdd/i.test(f.name)
          );
          if (hasPdd) count += 1;
        }
        console.log(JSON.stringify({ ok: true, count }));
      } catch (e) { console.log(JSON.stringify({ ok: false, message: String(e.message || e) })); }
    " 2>/dev/null)"
    INPUTS_OK="$(printf '%s' "$INPUTS_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.ok?'1':'0'); } catch { console.log('?'); }" 2>/dev/null)"
    INPUTS_COUNT="$(printf '%s' "$INPUTS_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.count||0); } catch { console.log('0'); }" 2>/dev/null)"
    INPUTS_MSG="$(printf '%s' "$INPUTS_PROBE" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.message||''); } catch { console.log(''); }" 2>/dev/null)"
    if [ "$INPUTS_OK" = "1" ]; then
      if [ "$INPUTS_COUNT" -gt 0 ] 2>/dev/null; then
        pass "input_packs: $INPUTS_COUNT opp(s) under \$ACE_DRIVE_ROOT_FOLDER_ID have an inputs/ subfolder"
      else
        info "input_packs: no opps with inputs/ found yet — first-time setup, see /ace:run for the new-layout howto"
      fi
    else
      warn "input_packs: could not probe ACE_DRIVE_ROOT_FOLDER_ID for inputs/: $INPUTS_MSG" "verify the SA has Editor access to the Drive root and re-run /ace:doctor"
    fi
  fi

  # Shared collection triple — required by ocs-agent-setup for per-opp bot
  # clones to inherit Connect knowledge. Without these, cloned bots publish
  # with empty RAG and silently answer from base LLM only.
  # (2026-04-20 run log P1 backlog; see learnings.md "Metadata files as hypotheses".)
  if [ -n "$SHARED_COLL" ] && [ -n "$LLM_PROV" ] && [ -n "$EMBED_MODEL" ]; then
    pass "ocs_shared_collection: id=$SHARED_COLL provider=$LLM_PROV embedding=$EMBED_MODEL"
  else
    sc_missing=""
    [ -z "$SHARED_COLL" ] && sc_missing="$sc_missing OCS_SHARED_COLLECTION_ID"
    [ -z "$LLM_PROV" ] && sc_missing="$sc_missing OCS_LLM_PROVIDER_ID"
    [ -z "$EMBED_MODEL" ] && sc_missing="$sc_missing OCS_EMBEDDING_MODEL_ID"
    warn "ocs_shared_collection: missing or unresolved:$sc_missing (per-opp bots will have empty RAG)" "re-inject .env via op inject (vars added in 0.5.1)"
  fi

  # Team-membership probe: confirm OCS_SHARED_COLLECTION_ID actually lives on
  # OCS_TEAM_SLUG. The check above only verifies the env var is set; it would
  # PASS even when the ID points at a different team's collection — which is
  # exactly what happened in the 2026-04-27 turmeric-dogfood run, where the
  # configured 350 belonged to "NM Bot" on a different team. Cloned per-opp
  # bots silently inherited the wrong domain's RAG. (canopy session-review
  # finding #5, 2026-04-28 cycle.)
  #
  # Probe: GET /a/$TEAM/documents/collections/$ID with the Playwright session
  # cookie. 200 = collection lives on this team. 404 = it doesn't. 302 = the
  # session is expired (already warned by the ocs_session check below; skip).
  if [ -n "$SHARED_COLL" ] && [ -n "$OCS_TEAM" ] && [ -n "$OCS_BASE" ]; then
    SC_SESS="$HOME/.ace/ocs-session-$OCS_TEAM.json"
    if [ -f "$SC_SESS" ]; then
      SC_COOKIES="$(node -e "
        try {
          const s = JSON.parse(require('fs').readFileSync('$SC_SESS','utf8'));
          const cs = (s.cookies || []).filter(c => c.name === 'sessionid' || c.name === 'csrftoken');
          process.stdout.write(cs.map(c => c.name + '=' + c.value).join('; '));
        } catch(_) {}
      " 2>/dev/null)"
      if [ -n "$SC_COOKIES" ]; then
        SC_STATUS="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 3 -b "$SC_COOKIES" "$OCS_BASE/a/$OCS_TEAM/documents/collections/$SHARED_COLL" 2>/dev/null)"
        case "$SC_STATUS" in
          200)
            pass "ocs_shared_collection_team: collection $SHARED_COLL exists on team $OCS_TEAM"
            ;;
          404)
            warn "ocs_shared_collection_team: collection $SHARED_COLL does NOT exist on team $OCS_TEAM (cloned per-opp bots will fail to attach RAG, or attach a different team's collection)" "open $OCS_BASE/a/$OCS_TEAM/documents/ in the OCS UI; pick a collection that belongs to this team and update OCS_SHARED_COLLECTION_ID in $ENV_FILE"
            ;;
          301|302)
            : # session expired — ocs_session check below already warns
            ;;
          000|"")
            : # network error — silent; not the probe's job to flag
            ;;
          *)
            warn "ocs_shared_collection_team: probe returned HTTP $SC_STATUS for collection $SHARED_COLL on team $OCS_TEAM" "verify $OCS_BASE reachable; refresh session via /ace:ocs-login"
            ;;
        esac
      fi
    fi
  fi

  if [ -n "$GMAIL_ACCT" ]; then
    pass "gmail_config: ACE_GMAIL_ACCOUNT=$GMAIL_ACCT"
  else
    warn "gmail_config: ACE_GMAIL_ACCOUNT not set" "re-inject .env via 1Password"
  fi

  # Catch-all: any future .env.tpl addition that the installed .env hasn't
  # picked up yet. Diff the KEY= sets; warn with a single line listing
  # whatever is missing. Informational — WARN, not FAIL (per learnings.md
  # "Runtime-health checks should be WARN, not FAIL").
  if [ -f "$ROOT/.env.tpl" ]; then
    TPL_KEYS="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ROOT/.env.tpl" 2>/dev/null | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
    ENV_KEYS="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ENV_FILE" 2>/dev/null | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
    ENV_DIFF="$(comm -23 <(printf '%s\n' "$TPL_KEYS") <(printf '%s\n' "$ENV_KEYS") | tr '\n' ' ' | sed 's/ *$//')"
    if [ -n "$ENV_DIFF" ]; then
      warn "env_drift: $ENV_FILE is missing keys from .env.tpl: $ENV_DIFF" "op inject -i \"$ROOT/.env.tpl\" -o \"$ENV_FILE\" --account dimagi.1password.com (preserves 1Password-backed values)"
    else
      pass "env_drift: $ENV_FILE has every key declared in .env.tpl"
    fi

    # Class-level preventer: any key declared in .env.tpl but with zero
    # consumers in actual code is dead ceremony — it gets injected, eats
    # a 1Password lookup, and adds a paste-this line nobody needs. Grep
    # every TPL_KEY against the code-bearing dirs; warn on any hit with
    # zero consumers. Docs (README/CHANGELOG/runs/playbook) don't count.
    # Added 0.5.7 after the bootstrap-output audit found three dead vars.
    UNUSED=""
    CODE_DIRS="mcp lib scripts skills bin hooks agents commands test"
    for key in $TPL_KEYS; do
      HITS="$(cd "$ROOT" && grep -rE "\\b$key\\b" $CODE_DIRS 2>/dev/null | head -1)"
      if [ -z "$HITS" ]; then
        UNUSED="$UNUSED $key"
      fi
    done
    UNUSED="$(printf '%s' "$UNUSED" | sed 's/^ //')"
    if [ -n "$UNUSED" ]; then
      warn "unused_env_keys: declared in .env.tpl but never read by code: $UNUSED" "drop them from .env.tpl, or wire them into a consumer (mcp/ lib/ scripts/ skills/ bin/ hooks/ agents/ commands/ test/)"
    else
      pass "unused_env_keys: every .env.tpl key has at least one consumer"
    fi
  fi

  # OCS Playwright session — keyed by team slug. The Playwright backend
  # auto-logs-in via OCS_USERNAME / OCS_PASSWORD when no saved session
  # exists, so a missing file is fine as long as creds are configured.
  # /ace:ocs-login is the manual fallback for SSO/MFA accounts.
  if [ -n "$OCS_TEAM" ]; then
    SESS="$HOME/.ace/ocs-session-$OCS_TEAM.json"
    OCS_USER="$(get_env OCS_USERNAME)"
    OCS_PASS="$(get_env OCS_PASSWORD)"
    HAS_CREDS=0
    [ -n "$OCS_USER" ] && [ -n "$OCS_PASS" ] && HAS_CREDS=1
    if [ -f "$SESS" ]; then
      # freshness check: 30-day cookie lifetime
      if find "$SESS" -mtime +30 2>/dev/null | grep -q .; then
        if [ "$HAS_CREDS" = "1" ]; then
          pass "ocs_session: $SESS >30 days old — auto-login will refresh on next call"
        else
          warn "ocs_session: $SESS is older than 30 days — may be expired" "/ace:ocs-login"
        fi
      else
        pass "ocs_session: $SESS present"
      fi
    else
      if [ "$HAS_CREDS" = "1" ]; then
        pass "ocs_session: not yet saved (auto-login on first call via OCS_USERNAME/OCS_PASSWORD)"
      else
        warn "ocs_session: $SESS missing and OCS_USERNAME/OCS_PASSWORD unset" "/ace:setup or /ace:ocs-login"
      fi
    fi
  else
    # No team slug — can't check for a session file. Already warned on ocs_env.
    :
  fi

  # ── Connect (ace-connect MCP) ───────────────────────────────────────
  CONNECT_BASE="$(get_env CONNECT_BASE_URL)"
  HQ_USER="$(get_env ACE_HQ_USERNAME)"
  HQ_PASS="$(get_env ACE_HQ_PASSWORD)"

  if [ -n "$CONNECT_BASE" ] && [ -n "$HQ_USER" ] && [ -n "$HQ_PASS" ]; then
    pass "connect_env: base=$CONNECT_BASE hq_user=$HQ_USER hq_password=<set>"
  else
    cm=""
    [ -z "$CONNECT_BASE" ] && cm="$cm CONNECT_BASE_URL"
    [ -z "$HQ_USER" ] && cm="$cm ACE_HQ_USERNAME"
    [ -z "$HQ_PASS" ] && cm="$cm ACE_HQ_PASSWORD"
    warn "connect_env: missing or unresolved:$cm" "re-inject .env via op inject (vars added in 0.8.0)"
  fi

  # ACE_HQ_DOMAIN — the CommCare HQ project space ace@dimagi-ai.com uploads
  # apps to. Default and only sanctioned value: connect-ace-prod. A different
  # value silently routes Nova uploads to the wrong project space; the apps
  # build but Phase 3 connect-setup can't bind them. Item 1 of the turmeric
  # run_time_followups (0.10.29).
  HQ_DOMAIN="$(get_env ACE_HQ_DOMAIN)"
  if [ -z "$HQ_DOMAIN" ]; then
    warn "hq_domain: ACE_HQ_DOMAIN not set (Nova app uploads will fall back; expected connect-ace-prod)" "add ACE_HQ_DOMAIN=connect-ace-prod to 1Password and re-inject .env"
  elif [ "$HQ_DOMAIN" = "connect-ace-prod" ]; then
    pass "hq_domain: ACE_HQ_DOMAIN=$HQ_DOMAIN"
  else
    warn "hq_domain: ACE_HQ_DOMAIN=$HQ_DOMAIN (expected connect-ace-prod)" "if intentional override, ignore; otherwise update .env to ACE_HQ_DOMAIN=connect-ace-prod"
  fi

  # Connect session file. Created by /ace:connect-login OR refreshed silently
  # by hq-oauth-login.ts when ACE_HQ_USERNAME/PASSWORD are set in .env.
  CONNECT_SESS="$HOME/.ace/connect-session.json"
  if [ -f "$CONNECT_SESS" ]; then
    AGE_S="$(($(date +%s) - $(stat -f %m "$CONNECT_SESS" 2>/dev/null || stat -c %Y "$CONNECT_SESS" 2>/dev/null || echo 0)))"
    AGE_H="$((AGE_S / 3600))"
    if [ "$AGE_H" -lt 24 ]; then
      pass "connect_session: $CONNECT_SESS (age ${AGE_H}h)"
    else
      warn "connect_session: $CONNECT_SESS is ${AGE_H}h old — may be stale" "automated re-login will run on first MCP call if HQ creds are set; otherwise /ace:connect-login"
    fi
  elif [ -n "$HQ_USER" ] && [ -n "$HQ_PASS" ]; then
    pass "connect_session: not present (will auto-login from .env on first call)"
  else
    warn "connect_session: $CONNECT_SESS missing and no HQ creds in .env" "/ace:connect-login OR set ACE_HQ_USERNAME/PASSWORD"
  fi
else
  # No .env at all — individual env-derived checks would all warn the same way.
  # Emit one consolidated pointer instead of three duplicates.
  warn "runtime_env: ocs_env, gmail_config, ocs_session, connect_env all skipped (no .env)" "resolve env_file warning above first"
fi

echo ""
echo "[Mobile]"

# Resolve the maestro launcher even when ~/.maestro/bin isn't on PATH.
# Mirrors `resolveMaestroBinDir()` in mcp/mobile/backends/avd.ts: the official
# installer drops it at ~/.maestro/bin/maestro on macOS/Linux but only patches
# the user's interactive shell rc, so a non-login shell (or doctor invoked
# from Claude Code) never sees it. Without this fallback doctor reports
# MISSING on a perfectly working install.
MAESTRO_BIN=""
for candidate in \
    "${MAESTRO_BIN:-}" \
    "$(command -v maestro 2>/dev/null)" \
    "${HOME}/.maestro/bin/maestro"; do
  [ -n "$candidate" ] && [ -x "$candidate" ] && MAESTRO_BIN="$candidate" && break
done
if [ -n "$MAESTRO_BIN" ]; then
  # JAVA_HOME may not be set in doctor's shell; resolve it like avd.ts does
  # so `--version` doesn't print "Unable to locate a Java Runtime".
  if [ -z "${JAVA_HOME:-}" ] && [ -x /usr/libexec/java_home ]; then
    export JAVA_HOME="$(/usr/libexec/java_home -v 17 2>/dev/null)"
  fi
  if [ -z "${JAVA_HOME:-}" ] && [ -d /opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home ]; then
    export JAVA_HOME="/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home"
  fi
  MAESTRO_VER="$("$MAESTRO_BIN" --version 2>/dev/null | tail -1)"
  echo "  Maestro:                $MAESTRO_BIN    ${MAESTRO_VER:-unknown}    OK"
else
  echo "  Maestro:                MISSING — install with curl -Ls 'https://get.maestro.mobile.dev' | bash"
fi

if command -v adb >/dev/null 2>&1; then
  echo "  adb:                    $(which adb)    $(adb version | head -1)    OK"
  # Detect the multi-user-shared-adb-server pattern that breaks Maestro
  # auto-discovery. dadb-1.2.10 (bundled with Maestro 2.3.0–2.5.1) aborts
  # `Dadb.list` on the first `unauthorized` device returned by `adb devices`,
  # and on a shared workstation that bites any operator whose `~/.android/adbkey`
  # isn't authorized on a sibling user's emulator. Diagnosed live 2026-05-01;
  # workaround landed in 0.10.65 (`MaestroBackend.runRecipe` adds
  # `--host`/`--port` so dadb takes the direct-TCP path), but a leftover
  # unauthorized entry still surfaces other footguns (e.g., `adb shell` calls
  # without -s pick the wrong device). WARN-level: ACE registration works
  # via the 0.10.65 patch, but the operator should know.
  UNAUTH_DEVS="$(adb devices 2>/dev/null | awk '/^emulator-/ && $2=="unauthorized" {print $1}' | tr '\n' ' ' | sed 's/ $//')"
  if [ -n "$UNAUTH_DEVS" ]; then
    echo "  WARN adb_unauthorized: $UNAUTH_DEVS"
    echo "    fix: another user on this machine has emulators visible to your adb server."
    echo "    ACE bypasses this since 0.10.65, but unrelated 'adb shell' calls without -s may"
    echo "    pick the wrong device. Disconnect with 'adb disconnect <serial>' (transient)"
    echo "    or run a per-user adb server (ANDROID_ADB_SERVER_PORT=5038 adb start-server)."
  fi
else
  echo "  adb:                    MISSING — install with brew install android-platform-tools"
fi

# Read ACE_AVD_NAME from .env first (matches the rest of doctor's behavior),
# fall back to process env, then to the default.
AVD_NAME="$(get_env ACE_AVD_NAME)"
[ -z "$AVD_NAME" ] && AVD_NAME="${ACE_AVD_NAME:-ACE_Pixel_API_34}"

# Search broader paths for emulator/adb in case the doctor session doesn't
# have ANDROID_HOME on PATH (common when run from a non-interactive shell).
EMULATOR_BIN=""
for candidate in \
    "$(command -v emulator 2>/dev/null)" \
    "/opt/homebrew/share/android-commandlinetools/emulator/emulator" \
    "${ANDROID_HOME:-}/emulator/emulator" \
    "${ANDROID_SDK_ROOT:-}/emulator/emulator"; do
  [ -x "$candidate" ] && EMULATOR_BIN="$candidate" && break
done

if [ -n "$EMULATOR_BIN" ] && "$EMULATOR_BIN" -list-avds 2>/dev/null | grep -q "^${AVD_NAME}$"; then
  if adb devices 2>/dev/null | grep -q "^emulator-"; then
    echo "  AVD:                    ${AVD_NAME}    booted    OK"
  else
    echo "  AVD:                    ${AVD_NAME}    available (not booted)    OK"
  fi
else
  echo "  AVD:                    ${AVD_NAME}    MISSING — create via Android Studio or 'avdmanager create avd -n ${AVD_NAME} -k \"system-images;android-34;google_apis;arm64-v8a\" -d pixel_7'"
fi

PLAYWRIGHT_DIR="${ACE_PLAYWRIGHT_USER_DATA_DIR:-${HOME}/.ace/playwright-userdata}"
if [ -d "${PLAYWRIGHT_DIR}" ] && find "${PLAYWRIGHT_DIR}" -name 'Cookies' -type f -size +0c 2>/dev/null | grep -q .; then
  echo "  Playwright cookies:     ${PLAYWRIGHT_DIR}    valid    OK"
else
  echo "  Playwright cookies:     MISSING — run /ace:mobile-bootstrap"
fi

# Read ACE_E2E_* and ACE_AVD_NAME from $ENV_FILE via get_env so they aren't
# perpetually MISSING when doctor runs from a shell that didn't load .env.
for v in ACE_E2E_PHONE ACE_E2E_PIN ACE_E2E_BACKUP_CODE ACE_AVD_NAME; do
  val="$(get_env "$v")"
  [ -z "$val" ] && val="${!v:-}"
  if [ -n "$val" ]; then
    echo "  ${v}:    set    OK"
  else
    echo "  ${v}:    MISSING — populate via 1Password + op inject"
  fi
done

echo ""
echo "STATUS: COMPLETE"
