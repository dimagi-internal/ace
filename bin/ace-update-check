#!/usr/bin/env bash
# ace-update-check — periodic version check for the ACE plugin.
#
# Borrowed (with attribution) from gstack's gstack-update-check pattern:
# https://github.com/garrytan/gstack — see references/gstack-research.md.
#
# Output (one line, or nothing):
#   JUST_UPGRADED <old> <new>       — marker found from recent upgrade
#   UPGRADE_AVAILABLE <old> <new>   — remote VERSION differs from local
#   (nothing)                       — up to date, snoozed, disabled, or check skipped
#
# Env overrides (for testing):
#   ACE_DIR         — override auto-detected ACE plugin root
#   ACE_REMOTE_URL  — override remote VERSION URL
#   ACE_STATE_DIR   — override ~/.ace state directory
set -euo pipefail

ACE_DIR="${ACE_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${ACE_STATE_DIR:-$HOME/.ace}"
CACHE_FILE="$STATE_DIR/update-check"
MARKER_FILE="$STATE_DIR/just-upgraded-from"
SNOOZE_FILE="$STATE_DIR/update-snoozed"
DISABLE_FILE="$STATE_DIR/update-check-disabled"
VERSION_FILE="$ACE_DIR/VERSION"
REMOTE_URL="${ACE_REMOTE_URL:-https://raw.githubusercontent.com/dimagi-internal/ace/main/VERSION}"

# ─── Force flag (busts cache + snooze for standalone use) ─────
if [ "${1:-}" = "--force" ]; then
  rm -f "$CACHE_FILE"
  rm -f "$SNOOZE_FILE"
fi

# ─── Step 0: Check if updates are disabled ────────────────────
if [ -f "$DISABLE_FILE" ]; then
  exit 0
fi

# ─── Snooze helper ────────────────────────────────────────────
# check_snooze <remote_version>
#   Returns 0 if snoozed (stay quiet), 1 if not snoozed (output).
#
#   Snooze file format: <version> <level> <epoch>
#   Level durations: 1=24h, 2=48h, 3+=7d
#   New remote version resets snooze.
check_snooze() {
  local remote_ver="$1"
  [ -f "$SNOOZE_FILE" ] || return 1

  local snoozed_ver snoozed_level snoozed_epoch
  snoozed_ver="$(awk '{print $1}' "$SNOOZE_FILE" 2>/dev/null || true)"
  snoozed_level="$(awk '{print $2}' "$SNOOZE_FILE" 2>/dev/null || true)"
  snoozed_epoch="$(awk '{print $3}' "$SNOOZE_FILE" 2>/dev/null || true)"

  # Validate: all fields present and sane
  [ -n "$snoozed_ver" ] && [ -n "$snoozed_level" ] && [ -n "$snoozed_epoch" ] || return 1
  case "$snoozed_level" in *[!0-9]*) return 1 ;; esac
  case "$snoozed_epoch" in *[!0-9]*) return 1 ;; esac

  # New version dropped? Ignore snooze.
  [ "$snoozed_ver" = "$remote_ver" ] || return 1

  # Compute snooze duration
  local duration
  case "$snoozed_level" in
    1) duration=86400 ;;   # 24 hours
    2) duration=172800 ;;  # 48 hours
    *) duration=604800 ;;  # 7 days
  esac

  local now expires
  now="$(date +%s)"
  expires=$(( snoozed_epoch + duration ))
  [ "$now" -lt "$expires" ]
}

# ─── Step 1: Read local version ──────────────────────────────
LOCAL=""
if [ -f "$VERSION_FILE" ]; then
  LOCAL="$(tr -d '[:space:]' < "$VERSION_FILE" 2>/dev/null || true)"
fi
if [ -z "$LOCAL" ]; then
  exit 0  # No VERSION file → skip check
fi

# ─── Step 2: Check "just upgraded" marker ─────────────────────
if [ -f "$MARKER_FILE" ]; then
  OLD="$(tr -d '[:space:]' < "$MARKER_FILE" 2>/dev/null || true)"
  rm -f "$MARKER_FILE"
  rm -f "$SNOOZE_FILE"
  if [ -n "$OLD" ] && [ "$OLD" != "$LOCAL" ]; then
    echo "JUST_UPGRADED $OLD $LOCAL"
    # Don't exit — fall through in case more updates landed since.
  fi
fi

# ─── Step 3: Check cache freshness ───────────────────────────
# UP_TO_DATE:        60 min TTL (detect new releases quickly)
# UPGRADE_AVAILABLE: 720 min TTL (keep nagging, but not spamming)
if [ -f "$CACHE_FILE" ]; then
  CACHED="$(cat "$CACHE_FILE" 2>/dev/null || true)"
  case "$CACHED" in
    UP_TO_DATE*)        CACHE_TTL=60 ;;
    UPGRADE_AVAILABLE*) CACHE_TTL=720 ;;
    *)                  CACHE_TTL=0 ;;
  esac

  STALE=$(find "$CACHE_FILE" -mmin +$CACHE_TTL 2>/dev/null || true)
  if [ -z "$STALE" ] && [ "$CACHE_TTL" -gt 0 ]; then
    case "$CACHED" in
      UP_TO_DATE*)
        CACHED_VER="$(echo "$CACHED" | awk '{print $2}')"
        [ "$CACHED_VER" = "$LOCAL" ] && exit 0
        ;;
      UPGRADE_AVAILABLE*)
        CACHED_OLD="$(echo "$CACHED" | awk '{print $2}')"
        if [ "$CACHED_OLD" = "$LOCAL" ]; then
          CACHED_NEW="$(echo "$CACHED" | awk '{print $3}')"
          if check_snooze "$CACHED_NEW"; then
            exit 0
          fi
          echo "$CACHED"
          exit 0
        fi
        ;;
    esac
  fi
fi

# ─── Step 4: Slow path — fetch remote version ────────────────
mkdir -p "$STATE_DIR"

REMOTE=""
REMOTE="$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null || true)"
REMOTE="$(echo "$REMOTE" | tr -d '[:space:]')"

# Validate: must look like a version number (reject HTML error pages)
if ! echo "$REMOTE" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
  # Invalid or empty response — assume up to date to avoid false alarms
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE"
  exit 0
fi

if [ "$LOCAL" = "$REMOTE" ]; then
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE"
  exit 0
fi

# Versions differ — upgrade available
echo "UPGRADE_AVAILABLE $LOCAL $REMOTE" > "$CACHE_FILE"
if check_snooze "$REMOTE"; then
  exit 0
fi

echo "UPGRADE_AVAILABLE $LOCAL $REMOTE"
