#!/usr/bin/env bash
# ace-labs-walkthrough-login — establish a Connect-Labs UI session for
# walkthrough automation. Headless OAuth via the existing hqOAuthLogin
# infra in mcp/connect/auth/ — no e2e-login bypass on the labs side, so
# we drive the real OAuth click-through:
#
#   1. Ensure a Connect (connect.dimagi.com) session via hqOAuthLogin
#      (uses ACE_HQ_USERNAME/PASSWORD).
#   2. Drive the labs `/labs/login/` "Authorize with Connect" button to
#      land a labs-side session.
#   3. Persist Playwright storageState to ~/.ace/labs-session.json.
#   4. Export labs cookies to a Netscape jar at
#      ${TMPDIR:-/tmp}/ace-labs-walkthrough-$(id -u)/cookies.txt
#      (per-OS-user dir — #774).
#   5. Import labs cookies into the gstack `browse` persistent profile so
#      canopy:walkthrough's headless browser is authenticated.
#
# Companion to ace-web's tools/walkthrough/walkthrough_auth_login.sh,
# which uses /auth/e2e-login/ shared-secret bypass — that endpoint only
# exists on the ace-web mount, NOT on the labs root. This script fills
# the labs gap.
#
# Required env (read from ${CLAUDE_PLUGIN_DATA}/.env):
#   ACE_HQ_USERNAME / ACE_HQ_PASSWORD  CommCareHQ creds for OAuth-via-CCHQ
#
# Optional env:
#   LABS_BASE_URL          default: https://labs.connect.dimagi.com
#   CONNECT_BASE_URL       default: https://connect.dimagi.com
#   ACE_LABS_COOKIE_JAR    default: ${TMPDIR:-/tmp}/ace-labs-walkthrough-$(id -u)/cookies.txt
#   BROWSE_BIN             default: ~/.claude/skills/gstack/browse/dist/browse
#
# Exit status:
#   0 — labs session established; cookies written; browse profile updated
#   2 — required env var missing
#   3 — Playwright login flow failed (Connect or labs side)

set -euo pipefail

SELF_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Source ${CLAUDE_PLUGIN_DATA}/.env into the env (so ACE_HQ_* land here)
ENV_FILE="${CLAUDE_PLUGIN_DATA:-$HOME/.claude/plugins/data/ace-ace}/.env"
if [ -f "$ENV_FILE" ]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
fi

LABS_BASE_URL="${LABS_BASE_URL:-https://labs.connect.dimagi.com}"
CONNECT_BASE_URL="${CONNECT_BASE_URL:-https://connect.dimagi.com}"
# #774 — namespace the temp dir by OS user (`id -u`). A fixed world-located
# /tmp/ace-labs-walkthrough/ created by one account is 0755-owned by that
# account, so a second OS user's run dies with PermissionError on cookies.txt.
COOKIE_JAR="${ACE_LABS_COOKIE_JAR:-${TMPDIR:-/tmp}/ace-labs-walkthrough-$(id -u)/cookies.txt}"
BROWSE_BIN="${BROWSE_BIN:-$HOME/.claude/skills/gstack/browse/dist/browse}"

log() { echo "[ace-labs-walkthrough-login] $*" >&2; }

if [ -z "${ACE_HQ_USERNAME:-}" ] || [ -z "${ACE_HQ_PASSWORD:-}" ]; then
  log "ACE_HQ_USERNAME and/or ACE_HQ_PASSWORD not set."
  log "Inject from 1Password: /ace:setup --force-env (preserves local-only secrets; not a raw op inject)"
  exit 2
fi

# Ensure the cookie dir is writable by THIS uid. If the resolved dir exists
# but isn't writable (e.g. an operator overrode ACE_LABS_COOKIE_JAR back to a
# shared path another OS user owns — #774), fall back to a fresh private
# mktemp dir rather than crashing on the cookies.txt write.
COOKIE_DIR="$(dirname "$COOKIE_JAR")"
if ! mkdir -p "$COOKIE_DIR" 2>/dev/null || [ ! -w "$COOKIE_DIR" ]; then
  FALLBACK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/ace-labs-walkthrough-XXXXXX")"
  log "cookie dir $COOKIE_DIR not writable by uid $(id -u); falling back to $FALLBACK_DIR"
  COOKIE_DIR="$FALLBACK_DIR"
  COOKIE_JAR="$COOKIE_DIR/cookies.txt"
fi

log "labs OAuth click-through via hqOAuthLogin (Connect base: $CONNECT_BASE_URL)"
log "  → labs base: $LABS_BASE_URL"
log "  → state file: ~/.ace/labs-session.json"

# Drive the full Playwright flow. tsx pulls in the existing connect/auth
# helpers; output is JSON so the shell can extract the session-state path.
RESULT_JSON="$(npx --prefix "$SELF_DIR" tsx "$SELF_DIR/bin/labs-walkthrough-login.ts" \
  --connect-base-url "$CONNECT_BASE_URL" \
  --labs-base-url "$LABS_BASE_URL" 2>&1 | tee /dev/stderr | tail -n 1)"

# The TS script's last line is a JSON envelope. Split stderr (which we
# tee'd above) from the result so log lines don't pollute parsing.
case "$RESULT_JSON" in
  '{'*)
    : ok
    ;;
  *)
    log "labs login script did not emit a JSON result on its last line"
    exit 3
    ;;
esac

STATE_PATH="$(echo "$RESULT_JSON" | python3 -c "import json,sys; print(json.load(sys.stdin)['statePath'])")"
log "labs storageState written to $STATE_PATH"

# Extract labs cookies from the storageState JSON, write Netscape jar
# (the format browse cookie-import accepts).
python3 - <<PY
import json, os, sys
from urllib.parse import urlparse

state_path = "$STATE_PATH"
labs_url = "$LABS_BASE_URL"
jar = "$COOKIE_JAR"

with open(state_path) as f:
    state = json.load(f)

labs_host = urlparse(labs_url).hostname

# Filter cookies to labs domain (or any subdomain match).
def _matches(cookie_domain: str, host: str) -> bool:
    cd = cookie_domain.lstrip(".")
    return cd == host or host.endswith("." + cd)

labs_cookies = [c for c in state.get("cookies", []) if _matches(c.get("domain", ""), labs_host)]
if not labs_cookies:
    sys.stderr.write(f"[ace-labs-walkthrough-login] no labs cookies in storageState — login likely failed\n")
    sys.exit(3)

with open(jar, "w") as f:
    f.write("# Netscape HTTP Cookie File\n# generated by ace-labs-walkthrough-login\n\n")
    for c in labs_cookies:
        domain = c["domain"]
        flag = "TRUE" if domain.startswith(".") else "FALSE"
        path = c.get("path", "/")
        secure = "TRUE" if c.get("secure") else "FALSE"
        # Netscape format: each line is tab-delimited: domain, flag, path,
        # secure, expires, name, value. HttpOnly cookies are prefixed with
        # `#HttpOnly_` on the domain column (curl/walkthrough_auth_login
        # convention).
        domain_col = ("#HttpOnly_" + domain) if c.get("httpOnly") else domain
        expires = int(c.get("expires") or 0)
        f.write(f"{domain_col}\t{flag}\t{path}\t{secure}\t{expires}\t{c['name']}\t{c['value']}\n")

print(f"[ace-labs-walkthrough-login] wrote {len(labs_cookies)} labs cookies to {jar}", file=sys.stderr)
PY

# Mirror cookies into the gstack browse profile so canopy:walkthrough's
# headless Chromium is authenticated for labs URLs. Same pattern ace-web's
# walkthrough_auth_login.sh uses.
if [ -x "$BROWSE_BIN" ]; then
  # browse requires an origin-matching page open before accepting cookies.
  "$BROWSE_BIN" goto "$LABS_BASE_URL" >/dev/null 2>&1 || true
  COOKIE_JSON="$(dirname "$COOKIE_JAR")/cookies.json"
  python3 - <<PY > "$COOKIE_JSON"
import json
state_path = "$STATE_PATH"
labs_url = "$LABS_BASE_URL"
from urllib.parse import urlparse

with open(state_path) as f:
    state = json.load(f)

labs_host = urlparse(labs_url).hostname

def _matches(cookie_domain, host):
    cd = cookie_domain.lstrip(".")
    return cd == host or host.endswith("." + cd)

cookies = []
for c in state.get("cookies", []):
    if not _matches(c.get("domain",""), labs_host):
        continue
    cookies.append({
        "name": c["name"],
        "value": c["value"],
        "domain": c["domain"],
        "path": c.get("path", "/"),
        "secure": bool(c.get("secure")),
        "httpOnly": bool(c.get("httpOnly")),
        "sameSite": c.get("sameSite", "Lax"),
        "expires": c.get("expires", -1),
    })
print(json.dumps(cookies))
PY
  if "$BROWSE_BIN" cookie-import "$COOKIE_JSON" >/dev/null 2>&1; then
    log "imported labs cookies into browse profile"
  else
    log "WARN: failed to import labs cookies into browse — try cookie-import manually"
  fi
fi

log "done. canopy:walkthrough can now authenticate against $LABS_BASE_URL"
echo "labs-session-ready"
