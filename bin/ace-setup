#!/usr/bin/env bash
# ace-setup — one-shot installer for the ACE plugin.
#
# Order is "cheap pre-flight checks first, slow state changes after,
# verification last", so the user never waits through npm install just
# to find out 1Password isn't signed in.
#
# Steps:
#   1. Detect plugin root + data dir
#   2. Verify Node/npm
#   3. Verify 1Password CLI is installed and authenticated (FAST FAIL)
#   4. Fetch the Google service-account key from 1Password if missing
#   5. npm install (skip if node_modules + tsx present)
#   6. Inject .env from 1Password (skip if .env covers all .env.tpl keys)
#   7. Download commcare-cli.jar from dimagi/commcare-core's latest
#      tagged release (skip if cached + not --force-install; WARN if gh
#      missing). Gates Phase 3 app-release-smoke Step 4.5.
#   8. Optionally register the SessionStart auto-update hook
#   9. Run bin/ace-doctor and surface remaining issues
#
# Flags:
#   --auto-update      register SessionStart hook for /ace:update
#   --force-install    re-run npm install even if node_modules is present
#   --force-env        re-run `op inject` even if .env covers all keys
#   --skip-env         skip .env injection entirely
#   --skip-doctor      skip the trailing doctor pass
#
# Env overrides:
#   ACE_GWS_KEY_OP_DOC  1Password Document item name for the GWS service-account
#                       key (default: "ACE - Google Service Account")
#   ACE_OP_VAULT        1Password vault that holds ACE secrets (default: "AI-Agents")
#   OP_SERVICE_ACCOUNT_TOKEN  if set, op uses this and skips --account flag
#
# Exit status: 0 on success, 1 on any FAIL the user must fix.
set +e

# ---- arg parsing
AUTO_UPDATE=0
FORCE_INSTALL=0
FORCE_ENV=0
SKIP_ENV=0
SKIP_DOCTOR=0
NO_SHELL_EDIT=0

while [ $# -gt 0 ]; do
  case "$1" in
    --auto-update)   AUTO_UPDATE=1 ;;
    --force-install) FORCE_INSTALL=1 ;;
    --force-env)     FORCE_ENV=1 ;;
    --skip-env)      SKIP_ENV=1 ;;
    --skip-doctor)   SKIP_DOCTOR=1 ;;
    --no-shell-edit) NO_SHELL_EDIT=1 ;;
    -h|--help)
      sed -n '2,31p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) echo "ace-setup: unknown arg: $1" >&2; exit 2 ;;
  esac
  shift
done

# ---- helpers
pass() { printf 'PASS %s\n' "$1"; }
warn() { printf 'WARN %s\n' "$1"; [ -n "${2:-}" ] && printf '  fix: %s\n' "$2"; }
fail() { printf 'FAIL %s\n' "$1"; [ -n "${2:-}" ] && printf '  fix: %s\n' "$2"; }

EXIT_CODE=0
mark_fail() { EXIT_CODE=1; }

# ---- defaults / config
OP_VAULT="${ACE_OP_VAULT:-AI-Agents}"
GWS_DOC_NAME="${ACE_GWS_KEY_OP_DOC:-ACE - Google Service Account}"

# ---- plugin root detection (matches bin/ace-doctor self-mode logic)
SELF_DIR="$(cd "$(dirname "$0")/.." && pwd)"
ROOT=""
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -f "$CLAUDE_PLUGIN_ROOT/.claude-plugin/plugin.json" ]; then
  ROOT="$CLAUDE_PLUGIN_ROOT"
fi
if [ -z "$ROOT" ]; then
  D="$PWD"
  while [ "$D" != "/" ]; do
    if [ -f "$D/.claude-plugin/plugin.json" ] && grep -q '"name": "ace"' "$D/.claude-plugin/plugin.json" 2>/dev/null; then
      ROOT="$D"; break
    fi
    D="$(dirname "$D")"
  done
fi
if [ -z "$ROOT" ]; then ROOT="$SELF_DIR"; fi
if [ -z "$ROOT" ] || [ ! -f "$ROOT/.claude-plugin/plugin.json" ]; then
  fail "plugin_root: could not locate ACE plugin" "run from an ACE checkout, or after /plugin install ace@ace"
  exit 1
fi
echo "INFO plugin_root=$ROOT"

# ---- data dir (per-machine, persistent across plugin updates)
if [ -n "${CLAUDE_PLUGIN_DATA:-}" ]; then
  DATA_DIR="$CLAUDE_PLUGIN_DATA"
else
  DATA_DIR="$HOME/.claude/plugins/data/ace-ace"
fi
mkdir -p "$DATA_DIR"
echo "INFO data_dir=$DATA_DIR"

# =====================================================================
# Phase 1 — Cheap pre-flight checks (fast fail)
# =====================================================================

# ---- Node / npm
if command -v node >/dev/null 2>&1; then
  pass "node: $(node --version)"
else
  fail "node: not on PATH" "install Node.js v18+ (https://nodejs.org)"
  exit 1
fi
if command -v npm >/dev/null 2>&1; then
  pass "npm: $(npm --version)"
else
  fail "npm: not on PATH" "install Node.js v18+ (bundles npm)"
  exit 1
fi

# ---- 1Password CLI installed?
if ! command -v op >/dev/null 2>&1; then
  fail "op: 1Password CLI not installed" \
       "install with: brew install 1password-cli (or https://developer.1password.com/docs/cli/get-started/)"
  exit 1
fi
pass "op: 1Password CLI v$(op --version 2>/dev/null)"

# ---- 1Password authenticated?
# Prefer service-account token if present, else require interactive signin.
AUTH_OK=0
AUTH_MODE=""
OP_ACCOUNT_FLAG=""
if [ -n "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]; then
  if op whoami >/dev/null 2>&1; then
    AUTH_OK=1
    AUTH_MODE="service-account"
  fi
fi
if [ "$AUTH_OK" = "0" ]; then
  if op whoami --account dimagi.1password.com >/dev/null 2>&1; then
    AUTH_OK=1
    AUTH_MODE="dimagi.1password.com (interactive)"
    OP_ACCOUNT_FLAG="--account dimagi.1password.com"
  fi
fi
if [ "$AUTH_OK" = "0" ]; then
  # 1Password's desktop-app CLI integration (biometric unlock) authenticates
  # every `op` invocation via Touch ID and issues NO persistent session token,
  # so `op whoami` reports "account is not signed in" even though `op read` /
  # `op document get` / `op inject` all succeed. Don't trust whoami as the sole
  # gate — fall back to a real READ probe (every setup step downstream is a
  # read anyway). If a vault listing succeeds, auth is live. (Without this,
  # biometric-integration users were hard-blocked by a false negative.)
  if op vault list --account dimagi.1password.com >/dev/null 2>&1; then
    AUTH_OK=1
    AUTH_MODE="dimagi.1password.com (desktop/biometric integration)"
    OP_ACCOUNT_FLAG="--account dimagi.1password.com"
  fi
fi

if [ "$AUTH_OK" = "0" ]; then
  # On macOS, GUI apps inherit env from launchd — not from ~/.zshrc — so
  # OP_SERVICE_ACCOUNT_TOKEN can be defined in shell rc and still be unset
  # for a Claude Code session opened from the dock. Detect that case so the
  # user knows the fix is "move it to ~/.zshenv" instead of "set the var".
  GUI_HINT=""
  if [ "$(uname -s)" = "Darwin" ] && [ -z "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]; then
    SHELL_RC_HIT=""
    for rc in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.zprofile" "$HOME/.bash_profile" "$HOME/.profile"; do
      if [ -f "$rc" ] && grep -qE '^[[:space:]]*(export[[:space:]]+)?OP_SERVICE_ACCOUNT_TOKEN=' "$rc"; then
        SHELL_RC_HIT="$rc"; break
      fi
    done
    if [ -n "$SHELL_RC_HIT" ]; then
      GUI_HINT="
       NOTE: OP_SERVICE_ACCOUNT_TOKEN is defined in $SHELL_RC_HIT but not visible
       to this process. macOS GUI apps inherit env from launchd (not ~/.zshrc).
       Move the export to ~/.zshenv so launchd-spawned zsh sees it too, then
       quit and reopen Claude Code from the dock:
         grep '^[[:space:]]*\(export[[:space:]]\+\)\?OP_SERVICE_ACCOUNT_TOKEN=' $SHELL_RC_HIT >> ~/.zshenv
         # then: Cmd-Q Claude Code, reopen from dock, re-run /ace:setup"
    fi
  fi
  fail "op: not authenticated to 1Password" "type one of these in the chat (the \`!\` prefix runs in this session):
       ! op signin --account dimagi.1password.com   # interactive personal signin
       ! eval \$(op signin --account dimagi.1password.com)   # if you need session env exported
       (or set OP_SERVICE_ACCOUNT_TOKEN=ops_... in your shell rc and reopen the session)
       (Mac alt: open the 1Password.app, Settings → Developer → enable CLI integration)$GUI_HINT
     Then re-run /ace:setup."
  exit 1
fi
pass "op: authenticated as $AUTH_MODE"

# =====================================================================
# Phase 2 — Slow state changes (only run if pre-flight passed)
# =====================================================================

# ---- Google service-account key (canonical = $DATA_DIR/gws-sa-key.json)
CANONICAL_KEY="$DATA_DIR/gws-sa-key.json"
LEGACY_KEY="$ROOT/.gws-sa-key.json"
KEY=""
KEY_LOC=""
if [ -f "$CANONICAL_KEY" ] && [ -r "$CANONICAL_KEY" ]; then
  KEY="$CANONICAL_KEY"; KEY_LOC="canonical"
elif [ -f "$LEGACY_KEY" ] && [ -r "$LEGACY_KEY" ]; then
  KEY="$LEGACY_KEY"; KEY_LOC="legacy"
fi

if [ -z "$KEY" ]; then
  # Try to fetch from 1Password as a Document item.
  echo "INFO gws_key: missing — attempting fetch from 1Password vault $OP_VAULT, document \"$GWS_DOC_NAME\""
  GET_OUT="$(op document get "$GWS_DOC_NAME" --vault "$OP_VAULT" --output "$CANONICAL_KEY" --force $OP_ACCOUNT_FLAG 2>&1)"
  GET_RC=$?
  if [ "$GET_RC" -eq 0 ] && [ -s "$CANONICAL_KEY" ]; then
    # Validate JSON and chmod 600
    CLIENT_EMAIL="$(node -e "try { console.log(JSON.parse(require('fs').readFileSync('$CANONICAL_KEY','utf8')).client_email); } catch(e) { console.log('NOT_JSON'); }" 2>/dev/null)"
    if [ "$CLIENT_EMAIL" = "NOT_JSON" ] || [ -z "$CLIENT_EMAIL" ]; then
      fail "gws_key: fetched document is not valid JSON" "verify \"$GWS_DOC_NAME\" in 1Password is the SA key file, then re-run /ace:setup"
      mark_fail
    else
      chmod 600 "$CANONICAL_KEY" 2>/dev/null
      KEY="$CANONICAL_KEY"; KEY_LOC="canonical"
      pass "gws_key: fetched $CLIENT_EMAIL from 1Password to $CANONICAL_KEY"
    fi
  else
    # Discovery: surface candidate Document items so the user can pick the right one.
    echo "INFO gws_key: \"$GWS_DOC_NAME\" not found in $OP_VAULT. Listing Document items that might be the SA key..."
    CANDIDATES="$(op item list --vault "$OP_VAULT" --categories Document --format json $OP_ACCOUNT_FLAG 2>/dev/null \
                  | node -e "
                    try {
                      const items = JSON.parse(require('fs').readFileSync(0,'utf8'));
                      const re = /(google|gws|service[\\s.]account|sa[\\s._-]?key|gcp|drive)/i;
                      for (const it of items) {
                        if (re.test(it.title || '')) console.log('  - ' + it.title);
                      }
                    } catch(_) {}
                  " 2>/dev/null)"
    fail "gws_key: missing and could not auto-fetch from 1Password" "options:
       (a) set ACE_GWS_KEY_OP_DOC=<exact item name> and re-run /ace:setup
       (b) drop the key manually at $CANONICAL_KEY (mkdir -p \"$DATA_DIR\" && mv key.json \"$CANONICAL_KEY\" && chmod 600 \"$CANONICAL_KEY\")
       (c) ask Jon for the ACE Google service-account JSON
     candidate Document items in vault $OP_VAULT (set ACE_GWS_KEY_OP_DOC to one):
$([ -n "$CANDIDATES" ] && printf '%s\n' "$CANDIDATES" || echo "       (none matched 'google|gws|service account|sa key|gcp|drive')")
     1Password error from the attempted fetch:
$(printf '%s\n' "$GET_OUT" | sed 's/^/       /')"
    mark_fail
  fi
elif [ "$KEY_LOC" = "legacy" ]; then
  CLIENT_EMAIL="$(node -e "try { console.log(JSON.parse(require('fs').readFileSync('$KEY','utf8')).client_email); } catch(e) { console.log('unreadable'); }" 2>/dev/null)"
  warn "gws_key: $CLIENT_EMAIL at LEGACY path $LEGACY_KEY" \
       "migrate so it survives plugin updates: mv \"$LEGACY_KEY\" \"$CANONICAL_KEY\" && chmod 600 \"$CANONICAL_KEY\""
else
  CLIENT_EMAIL="$(node -e "try { console.log(JSON.parse(require('fs').readFileSync('$KEY','utf8')).client_email); } catch(e) { console.log('unreadable'); }" 2>/dev/null)"
  if [ "$CLIENT_EMAIL" = "unreadable" ]; then
    fail "gws_key: $KEY is not valid JSON" "re-drop the service-account key (or unset to re-fetch from 1Password)"
    mark_fail
  else
    pass "gws_key: $CLIENT_EMAIL at $CANONICAL_KEY"
  fi
fi

# ---- npm install (only after pre-flight passed)
cd "$ROOT" || { fail "cd $ROOT failed"; exit 1; }
if [ "$FORCE_INSTALL" = "1" ] || [ ! -d node_modules ] || [ ! -x node_modules/.bin/tsx ]; then
  echo "INFO running npm install (may take 30-60s)..."
  npm install --silent 2>&1 | tail -10
  if [ ! -x node_modules/.bin/tsx ]; then
    fail "deps: npm install completed but tsx still missing" "investigate npm install output above"
    mark_fail
  fi
fi
if [ -x node_modules/.bin/tsx ]; then
  pass "deps: tsx=$(node_modules/.bin/tsx --version 2>&1 | head -1)"
fi

# ---- .env injection from 1Password
ENV_OUT="$DATA_DIR/.env"
ENV_TPL="$ROOT/.env.tpl"

if [ "$SKIP_ENV" = "1" ]; then
  warn "env: skipped (--skip-env)" "re-run without --skip-env to populate $ENV_OUT"
elif [ ! -f "$ENV_TPL" ]; then
  fail "env: .env.tpl not found at $ENV_TPL" "the plugin is corrupt; reinstall with /plugin install ace@ace"
  mark_fail
else
  # Static lint: every op:// reference must have >=3 slash-separated segments
  # (vault/item/field). 1Password requires this and `op inject` failures are
  # cryptic ("invalid secret reference — too few '/'"). Catch malformed refs
  # before touching the network. Comment lines are skipped (not injected).
  # Item/field names can contain spaces, so we read each ref to end-of-line
  # (or the closing `}}` for wrapped refs) and trim trailing whitespace.
  LINT_BAD="$(awk '
    /^[[:space:]]*#/ { next }
    {
      if (match($0, /op:\/\/.+$/)) {
        ref = substr($0, RSTART)
        sub(/}}.*/, "", ref)
        sub(/[[:space:]]+$/, "", ref)
        path = substr(ref, 6)
        n = split(path, _parts, "/")
        if (n < 3) printf "    line %d: %s (got %d segment%s, need >=3 vault/item/field)\n", NR, ref, n, (n==1?"":"s")
      }
    }
  ' "$ENV_TPL")"
  if [ -n "$LINT_BAD" ]; then
    fail "env: malformed op:// references in .env.tpl" "every reference needs vault/item/field — fix and re-run /ace:setup:
$LINT_BAD"
    mark_fail
  else
    pass "env: .env.tpl op:// refs well-formed"
  fi

  # Decide whether to inject. Skip when .env already covers every key in .env.tpl.
  NEEDS_INJECT=0
  if [ "$FORCE_ENV" = "1" ]; then
    NEEDS_INJECT=1
    echo "INFO env: --force-env, re-injecting"
  elif [ ! -f "$ENV_OUT" ]; then
    NEEDS_INJECT=1
    echo "INFO env: $ENV_OUT does not exist, injecting"
  else
    TPL_KEYS="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ENV_TPL" | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
    ENV_KEYS="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ENV_OUT" | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
    DIFF="$(comm -23 <(printf '%s\n' "$TPL_KEYS") <(printf '%s\n' "$ENV_KEYS") | tr '\n' ' ' | sed 's/ *$//')"
    if [ -n "$DIFF" ]; then
      NEEDS_INJECT=1
      echo "INFO env: drift detected (missing keys: $DIFF), re-injecting"
    else
      UNRESOLVED_EXISTING="$(grep -cE '=op://' "$ENV_OUT" 2>/dev/null || echo 0)"
      if [ "$UNRESOLVED_EXISTING" -gt 0 ]; then
        NEEDS_INJECT=1
        echo "INFO env: $UNRESOLVED_EXISTING unresolved op:// refs in $ENV_OUT, re-injecting"
      fi
    fi
  fi

  if [ "$NEEDS_INJECT" = "1" ] && [ -n "$LINT_BAD" ]; then
    echo "INFO env: skipping op inject — fix lint failures above first"
  elif [ "$NEEDS_INJECT" = "1" ]; then
    # Capture local-only secrets — keys present in $ENV_OUT but not in
    # $ENV_TPL — before op inject overwrites the file. These are values
    # the operator added manually for things that aren't 1Password-backed
    # (e.g. ACE_E2E_AUTH_TOKEN, mirrored from ace-web's
    # deploy/aws/task-definition.json or AWS Secrets Manager). Without this
    # preservation, every op inject wipes them and operators have to
    # re-mirror by hand. We only preserve keys NOT in .env.tpl, so a 1P
    # value in .env.tpl always wins over any stale local override.
    LOCAL_SECRETS=""
    LOCAL_SECRET_COUNT=0
    if [ -f "$ENV_OUT" ]; then
      TPL_KEYS_PRE="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ENV_TPL" | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
      ENV_KEYS_PRE="$(grep -E '^[[:space:]]*[A-Z_][A-Z0-9_]*=' "$ENV_OUT" | sed -E 's/^[[:space:]]*([A-Z_][A-Z0-9_]*)=.*/\1/' | sort -u)"
      EXTRA_KEYS="$(comm -23 <(printf '%s\n' "$ENV_KEYS_PRE") <(printf '%s\n' "$TPL_KEYS_PRE"))"
      while IFS= read -r key; do
        [ -z "$key" ] && continue
        line="$(grep -E "^[[:space:]]*${key}=" "$ENV_OUT" | head -1)"
        if [ -n "$line" ]; then
          LOCAL_SECRETS="${LOCAL_SECRETS}${line}
"
          LOCAL_SECRET_COUNT=$((LOCAL_SECRET_COUNT + 1))
        fi
      done <<EOF_KEYS
$EXTRA_KEYS
EOF_KEYS
    fi

    # `op inject` scans the ENTIRE file for op-scheme tokens — it does NOT skip
    # shell comments — so a bare reference inside a `#` line (e.g. an
    # author-contract note) aborts the whole render and writes an empty .env.
    # The lint above already skips comments; mirror that here by neutralizing
    # comment-line op-scheme tokens before injecting, so a comment can never
    # break a real render. Only `#`-prefixed lines are touched; real refs on
    # KEY= lines are passed through verbatim.
    INJECT_TPL="$(mktemp)"
    awk '/^[[:space:]]*#/ { gsub(/op:\/\//, "op-SCHEME-//") } { print }' "$ENV_TPL" > "$INJECT_TPL"
    INJECT_OUT="$(op inject -i "$INJECT_TPL" -o "$ENV_OUT" --force $OP_ACCOUNT_FLAG 2>&1)"
    INJECT_RC=$?
    rm -f "$INJECT_TPL"
    if [ "$INJECT_RC" -ne 0 ]; then
      fail "env: op inject failed (exit $INJECT_RC)" "see error below — usually means your account/SA is missing read on one of the items in vault $OP_VAULT"
      printf '%s\n' "$INJECT_OUT" | sed 's/^/    /'
      mark_fail
    else
      # Re-append preserved local-only secrets after the inject succeeded.
      # Block-marker comment makes the boundary obvious to operators
      # eyeballing .env, and lets a future maintenance script find/refresh
      # this region cleanly.
      if [ "$LOCAL_SECRET_COUNT" -gt 0 ]; then
        {
          printf '\n# --- ACE local-only secrets (preserved across op inject) ---\n'
          printf '# Set by operator, NOT 1Password-backed. Keys here must NOT appear in .env.tpl;\n'
          printf '# bin/ace-setup auto-preserves them on re-inject. Edit values directly in this file.\n'
          printf '%s' "$LOCAL_SECRETS"
        } >> "$ENV_OUT"
        pass "env: op inject wrote $ENV_OUT (preserved $LOCAL_SECRET_COUNT local-only secret(s))"
      else
        pass "env: op inject wrote $ENV_OUT"
      fi
    fi
  else
    pass "env: $ENV_OUT already has every .env.tpl key (use --force-env to refresh)"
  fi

  # Verify no unresolved op:// references survived. For each unresolved ref,
  # run `op read` to surface the specific cause (missing item vs missing
  # field vs no-read-permission) so the user can fix the right thing rather
  # than guessing from a generic "grant access" message.
  if [ -f "$ENV_OUT" ]; then
    UNRESOLVED="$(grep -nE '=op://' "$ENV_OUT" 2>/dev/null)"
    if [ -n "$UNRESOLVED" ]; then
      DIAG=""
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        # line format from grep -n: "<lineno>:<KEY>=<op-ref>"
        ref="${line#*=}"
        ref="${ref%\"}"; ref="${ref#\"}"
        err="$(op read "$ref" $OP_ACCOUNT_FLAG 2>&1 >/dev/null)"
        [ -z "$err" ] && err="(op read succeeded on retry — re-run /ace:setup with --force-env)"
        DIAG="${DIAG}    ${line}
      → ${err}
"
      done <<UNRESOLVED_EOF
$UNRESOLVED
UNRESOLVED_EOF
      fail "env: unresolved 1Password references in $ENV_OUT" \
           "per-ref diagnostic below — fix each cause and re-run with --force-env:
$DIAG"
      mark_fail
    else
      pass "env: all 1Password references resolved"
    fi
  fi
fi

# ---- Nova PAT wiring via ~/.ace/env.sh + shell rc auto-append
#
# Nova plugin v1.1.0 reads NOVA_API_KEY from the Claude Code process's
# shell env via a headersHelper in its .mcp.json. ACE stores
# NOVA_API_KEY in ${CLAUDE_PLUGIN_DATA}/.env (loaded only into ACE's own
# MCP subprocesses, not the parent shell), so we write a sourceable
# shim at ~/.ace/env.sh and append a marker-fenced source line to the
# operator's shell rc once per machine. See
# `playbook/integrations/nova-integration.md` and
# voidcraft-labs/nova-plugin#11 / #13 / #16.
#
# Marker-fenced shell-rc edits are the standard pattern (conda init,
# nvm, rustup, fnm, etc.). Idempotent (marker grep), reversible (delete
# the block), and operator-triggered (only runs via /ace:setup).
#
# Also removes any stale user-scope `nova:` MCP entry left over from the
# pre-1.1.0 override workaround — that path is obsolete and shadows the
# plugin's PAT-aware MCP entry under Claude Code's URL-dedup.
if [ -f "$ENV_OUT" ]; then
  NOVA_KEY="$(grep -E '^NOVA_API_KEY=' "$ENV_OUT" | head -1 | sed -E 's/^NOVA_API_KEY=//' | sed -E 's/^"(.*)"$/\1/')"
else
  NOVA_KEY=""
fi
# Always clean up any pre-1.1.0 user-scope override (idempotent; the
# entry may not exist). Required even when NOVA_API_KEY is missing —
# a stale override with a revoked key 401s every Nova call.
if command -v claude >/dev/null 2>&1; then
  claude mcp remove nova --scope user >/dev/null 2>&1 || true
fi
if [ -z "$NOVA_KEY" ] || [ "${NOVA_KEY#op://}" != "$NOVA_KEY" ]; then
  warn "nova_env: NOVA_API_KEY not resolved in $ENV_OUT" \
       "mint a key at https://commcare.app/settings as the ACE Gmail identity, save to 1Password item \"ACE - Nova\" field \`api_key\`, then re-run /ace:setup --force-env."
else
  ACE_ENV_DIR="$HOME/.ace"
  ACE_ENV_FILE="$ACE_ENV_DIR/env.sh"
  mkdir -p "$ACE_ENV_DIR"
  # Atomic write: temp file + mv so a concurrent shell sourcing env.sh
  # never sees a half-written file.
  ACE_ENV_TMP="$(mktemp "${ACE_ENV_FILE}.XXXXXX")"
  cat > "$ACE_ENV_TMP" <<EOF
# Managed by bin/ace-setup — do not edit by hand.
# Sourced from your shell rc so Nova plugin v1.1.0's headersHelper can
# read NOVA_API_KEY from the shell env. Re-run /ace:setup after
# rotating the key in 1Password.
export NOVA_API_KEY="$NOVA_KEY"
EOF
  chmod 600 "$ACE_ENV_TMP"
  mv "$ACE_ENV_TMP" "$ACE_ENV_FILE"
  pass "nova_env: wrote $ACE_ENV_FILE"

  # ---- Auto-append marker-fenced source line to shell rc
  #
  # Picks the right rc file per platform/shell:
  #   - macOS + zsh  → ~/.zshenv  (launchd-spawned GUI Claude Code reads this,
  #                                ~/.zshrc is interactive-only)
  #   - macOS + bash → ~/.bash_profile  (Mac's standard login shell rc)
  #   - Linux + zsh  → ~/.zshrc
  #   - Linux + bash → ~/.bashrc
  #   - other shells → skip with a printed instruction
  #
  # Marker block is idempotent — re-runs find the marker and skip.
  if [ "$NO_SHELL_EDIT" = "1" ]; then
    info_shell_rc_skip_reason="--no-shell-edit passed"
  fi

  RC_FILE=""
  RC_REASON=""
  OS_NAME="$(uname -s 2>/dev/null)"
  SHELL_NAME="$(basename "${SHELL:-/bin/sh}")"
  case "$OS_NAME:$SHELL_NAME" in
    Darwin:zsh)  RC_FILE="$HOME/.zshenv"; RC_REASON="macOS + zsh (launchd-spawned Claude Code reads .zshenv)" ;;
    Darwin:bash) RC_FILE="$HOME/.bash_profile"; RC_REASON="macOS + bash" ;;
    Linux:zsh)   RC_FILE="$HOME/.zshrc";  RC_REASON="Linux + zsh" ;;
    Linux:bash)  RC_FILE="$HOME/.bashrc"; RC_REASON="Linux + bash" ;;
    *)           RC_FILE=""; RC_REASON="unsupported: OS=$OS_NAME SHELL=$SHELL_NAME" ;;
  esac

  MARKER_OPEN="# >>> ACE managed >>>"
  MARKER_CLOSE="# <<< ACE managed <<<"

  if [ "$NO_SHELL_EDIT" = "1" ]; then
    warn "nova_shell_rc: skipped — --no-shell-edit passed" \
         "add manually:  echo 'source ~/.ace/env.sh' >> $RC_FILE  # then restart Claude Code"
  elif [ -z "$RC_FILE" ]; then
    warn "nova_shell_rc: cannot auto-append (${RC_REASON})" \
         "manually add 'source ~/.ace/env.sh' to your shell's startup file, then restart Claude Code"
  elif [ -f "$RC_FILE" ] && grep -qF "$MARKER_OPEN" "$RC_FILE" 2>/dev/null; then
    pass "nova_shell_rc: $RC_FILE already sources ~/.ace/env.sh (marker block present)"
  else
    # Create the file if it doesn't exist (touch is idempotent).
    touch "$RC_FILE"
    # Append marker-fenced block. Leading newline keeps the block visually
    # separated even if the rc file doesn't end in a newline.
    {
      printf '\n%s\n' "$MARKER_OPEN"
      printf '%s\n' "# Sources ACE's NOVA_API_KEY (and any future env exports) so"
      printf '%s\n' "# Claude Code plugins (Nova v1.1.0+) can read them. Managed by"
      printf '%s\n' "# /ace:setup; remove this block to opt out."
      printf '%s\n' '[ -f "$HOME/.ace/env.sh" ] && source "$HOME/.ace/env.sh"'
      printf '%s\n' "$MARKER_CLOSE"
    } >> "$RC_FILE"
    pass "nova_shell_rc: appended marker block to $RC_FILE ($RC_REASON) — restart Claude Code to pick up NOVA_API_KEY"
  fi
fi

# ---- commcare-cli.jar (Phase 3 install-gate dependency)
#
# `app-release-smoke` Step 4.5 wraps Dimagi's `commcare-cli.jar validate`
# subcommand to catch runtime-install defects (e.g. a deliver_unit
# entity_id bound to a #case/<calculated-field> on a case-create form
# — install-time XPath bind reads null and CommCare rejects the CCZ
# with "A part of your application is invalid"). The jar runs the same
# `ResourceTable.initializeResources` install path the Android device
# runs, so it catches defects every static Phase 3 gate misses.
#
# Dimagi ships `commcare-cli.jar` as a release asset on every CommCare
# release (since `commcare_2.61.5` at least, ~10MB). We fetch the
# **latest tagged release** (including drafts — picks up `commcare_2.63.0`
# today) via `gh release download`, which handles the draft→stable URL
# transition transparently. Cached at `$DATA_DIR/commcare-cli.jar`; sidecar
# `.version` records which release the bytes came from so doctor can
# detect drift.
#
# Skips silently when:
#   - The jar is already cached AND `--force-install` is not set
#   - `gh` is not installed (we surface a WARN with the manual remediation)
# Skips noisily (WARN) when the download fails — `app-release-smoke`
# treats `cli-validator-unavailable` as `[WARN]` (structural Phase 3
# gates still authoritative), so a download miss doesn't break setup.
CCLI_JAR_PATH="$DATA_DIR/commcare-cli.jar"
CCLI_VERSION_PATH="$DATA_DIR/commcare-cli.jar.version"
if [ -f "$CCLI_JAR_PATH" ] && [ "$FORCE_INSTALL" = "0" ]; then
  CCLI_SIZE="$(stat -f %z "$CCLI_JAR_PATH" 2>/dev/null || stat -c %s "$CCLI_JAR_PATH" 2>/dev/null || echo 0)"
  CCLI_CACHED_VER="$(cat "$CCLI_VERSION_PATH" 2>/dev/null || echo unknown)"
  pass "commcare_cli: $CCLI_JAR_PATH present (${CCLI_SIZE} bytes, version=${CCLI_CACHED_VER}) — re-run with --force-install to refresh"
elif ! command -v gh >/dev/null 2>&1; then
  warn "commcare_cli: gh CLI not installed — skipping auto-download of commcare-cli.jar" "install gh (\`brew install gh && gh auth login\`) and re-run /ace:setup, or manually download from https://github.com/dimagi/commcare-core/releases/latest and place at $CCLI_JAR_PATH"
else
  CCLI_TAG="$(gh release list --repo dimagi/commcare-core --limit 1 --json tagName -q '.[0].tagName' 2>/dev/null)"
  if [ -z "$CCLI_TAG" ]; then
    warn "commcare_cli: couldn't list dimagi/commcare-core releases via gh" "check \`gh auth status\` + network; without this, Phase 3 app-release-smoke can't catch runtime-install defects (it falls through to structural-only gates, which is a [WARN] not a [BLOCKER])"
  else
    echo "  fetching commcare-cli.jar from ${CCLI_TAG} (this can take ~15s for the 10MB asset)..."
    # `gh release download` resolves draft asset URLs transparently via
    # the API, so it works for `commcare_2.63.0` (currently draft) the
    # same as for stable releases. --clobber lets --force-install repair
    # corrupt caches.
    if gh release download "$CCLI_TAG" --repo dimagi/commcare-core --pattern 'commcare-cli.jar' --output "$CCLI_JAR_PATH" --clobber 2>&1 | tail -5; then
      CCLI_SIZE="$(stat -f %z "$CCLI_JAR_PATH" 2>/dev/null || stat -c %s "$CCLI_JAR_PATH" 2>/dev/null || echo 0)"
      if [ "$CCLI_SIZE" -lt 1000000 ]; then
        warn "commcare_cli: downloaded jar is suspiciously small (${CCLI_SIZE} bytes)" "expected ~10MB; check network or rerun /ace:setup --force-install"
        rm -f "$CCLI_JAR_PATH" "$CCLI_VERSION_PATH"
      else
        echo "$CCLI_TAG" > "$CCLI_VERSION_PATH"
        pass "commcare_cli: downloaded ${CCLI_TAG} → $CCLI_JAR_PATH (${CCLI_SIZE} bytes)"
      fi
    else
      warn "commcare_cli: download failed for ${CCLI_TAG}" "manually: gh release download ${CCLI_TAG} --repo dimagi/commcare-core --pattern 'commcare-cli.jar' --output $CCLI_JAR_PATH"
    fi
  fi
fi

# ---- GOG CLI (Google services for the ACE Gmail identity)
# email-communicator (Phase 8 LLO invites, training emails) and any Google
# user-identity ops go through the `gog` CLI authenticated as ACE_GMAIL_ACCOUNT.
# Authorize the FULL practical service set in ONE consent so a single stored
# refresh token covers everything ACE might need. GOG auth is PER-MACHINE and
# the login is an interactive browser OAuth flow, so we install the binary here
# but PRINT the exact login command rather than block setup on it (same model
# as /ace:ocs-login and /ace:connect-login). /ace:doctor's gog_auth probe then
# live-checks scope coverage.
GOG_SERVICES="gmail,calendar,drive,docs,slides,sheets,forms"
GMAIL_ACCT_VAL="$(grep -E '^ACE_GMAIL_ACCOUNT=' "$ENV_OUT" 2>/dev/null | head -1 | cut -d= -f2- | sed -e 's/^[[:space:]"'\'']*//' -e 's/[[:space:]"'\'']*$//')"
GMAIL_CLIENT_VAL="$(grep -E '^ACE_GMAIL_CLIENT=' "$ENV_OUT" 2>/dev/null | head -1 | cut -d= -f2- | sed -e 's/^[[:space:]"'\'']*//' -e 's/[[:space:]"'\'']*$//')"
if ! command -v gog >/dev/null 2>&1 && command -v brew >/dev/null 2>&1; then
  echo "INFO gog: installing GOG CLI (brew install steipete/tap/gogcli)..."
  brew install steipete/tap/gogcli 2>&1 | tail -3
fi
if ! command -v gog >/dev/null 2>&1; then
  warn "gog: GOG CLI not installed (brew unavailable or install failed)" "install manually: brew install steipete/tap/gogcli — then authorize: gog login ${GMAIL_ACCT_VAL:-<ACE_GMAIL_ACCOUNT>} --client ${GMAIL_CLIENT_VAL:-<ACE_GMAIL_CLIENT>} --services $GOG_SERVICES --force-consent"
elif [ -z "$GMAIL_ACCT_VAL" ] || [ -z "$GMAIL_CLIENT_VAL" ]; then
  warn "gog: ACE_GMAIL_ACCOUNT / ACE_GMAIL_CLIENT not found in $ENV_OUT" "re-run /ace:setup --force-env to inject them, then authorize gog"
else
  GOG_LOGIN_CMD="gog login $GMAIL_ACCT_VAL --client $GMAIL_CLIENT_VAL --services $GOG_SERVICES --force-consent"
  if gog auth status --account "$GMAIL_ACCT_VAL" --client "$GMAIL_CLIENT_VAL" --json 2>/dev/null | grep -q '"credentials_exists": true'; then
    pass "gog: CLI installed + credentials present for $GMAIL_ACCT_VAL (client=$GMAIL_CLIENT_VAL). If Google ops 403, re-authorize the full scope set: $GOG_LOGIN_CMD"
  else
    warn "gog: CLI installed but NOT authorized for $GMAIL_ACCT_VAL — email + Google ops will fail" "run once (interactive browser OAuth): $GOG_LOGIN_CMD"
  fi
fi

# ---- Auto-update hook (opt-in)
if [ "$AUTO_UPDATE" = "1" ]; then
  HOOK_SCRIPT="$ROOT/bin/ace-update-check"
  if [ ! -x "$HOOK_SCRIPT" ]; then
    warn "auto_update: $HOOK_SCRIPT not executable" "chmod +x $HOOK_SCRIPT"
  else
    SETTINGS="$HOME/.claude/settings.json"
    mkdir -p "$(dirname "$SETTINGS")"
    [ -f "$SETTINGS" ] || echo "{}" > "$SETTINGS"
    HOOK_RESULT="$(python3 - "$SETTINGS" "$HOOK_SCRIPT" <<'PY' 2>&1
import json, sys
path, hook_cmd = sys.argv[1], sys.argv[2]
try:
    with open(path) as f:
        data = json.load(f)
except Exception as e:
    print(f"ERROR: could not parse {path}: {e}")
    sys.exit(1)
hooks = data.setdefault("hooks", {})
session_start = hooks.setdefault("SessionStart", [])
session_start = [h for h in session_start if "ace-update-check" not in json.dumps(h)]
session_start.append({
    "matcher": "*",
    "hooks": [{"type": "command", "command": hook_cmd, "async": True}],
})
hooks["SessionStart"] = session_start
with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
print("OK")
PY
)"
    if [ "$HOOK_RESULT" = "OK" ]; then
      pass "auto_update: SessionStart hook registered ($HOOK_SCRIPT)"
    else
      warn "auto_update: failed to register hook" "$HOOK_RESULT"
    fi
  fi
fi

# =====================================================================
# Phase 3 — Verification (run doctor)
# =====================================================================
if [ "$SKIP_DOCTOR" = "0" ]; then
  echo ""
  echo "===== /ace:doctor ====="
  if [ -x "$ROOT/bin/ace-doctor" ]; then
    "$ROOT/bin/ace-doctor"
  else
    warn "doctor: $ROOT/bin/ace-doctor not executable, skipping" "chmod +x $ROOT/bin/ace-doctor"
  fi
fi

echo ""
echo "STATUS: COMPLETE"
exit $EXIT_CODE
