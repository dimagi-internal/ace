#!/usr/bin/env python3
"""Mark Gmail threads read (remove the UNREAD label) as ace@.

Adapted from echo's bin/echo_mark_read.py. gog has no mark-read command, so this
uses the Gmail API directly with ACE's own OAuth (client creds from gogcli + refresh
token from the macOS keychain, or the ACE_GOOGLE_REFRESH_TOKEN override). Reading a
message via the API does NOT clear its unread flag — inbox-triage calls this after it
has fully handled (or dismissed) a thread, so a turn only lights up on genuinely new
mail. Read-only-adjacent (mutates only the UNREAD label on ACE's own mailbox); not
approval-gated.

STDLIB ONLY (urllib, not requests) — runs from the installed plugin cache.

Usage: bin/ace-mark-read <threadId> [<threadId> ...]
"""
import json
import os
import subprocess
import sys
import urllib.parse
import urllib.request

GOGCLI = os.path.expanduser("~/Library/Application Support/gogcli")
CLIENT = os.environ.get("ACE_GMAIL_CLIENT", "ace")
ACCOUNT = os.environ.get("ACE_GMAIL_ACCOUNT", "ace@dimagi-ai.com")


def access_token():
    creds = json.load(open(os.path.join(GOGCLI, f"credentials-{CLIENT}.json")))
    refresh = os.environ.get("ACE_GOOGLE_REFRESH_TOKEN")
    if not refresh:
        raw = subprocess.run(
            ["security", "find-generic-password", "-s", "gogcli", "-a",
             f"token:{CLIENT}:{ACCOUNT}", "-w"],
            capture_output=True, text=True).stdout.strip()
        refresh = json.loads(raw)["refresh_token"]
    body = urllib.parse.urlencode({
        "client_id": creds["client_id"], "client_secret": creds["client_secret"],
        "refresh_token": refresh, "grant_type": "refresh_token"}).encode()
    with urllib.request.urlopen("https://oauth2.googleapis.com/token", body) as r:
        return json.load(r)["access_token"]


def main():
    ids = sys.argv[1:]
    if not ids:
        print("usage: ace-mark-read <threadId> [...]")
        sys.exit(1)
    tok = access_token()
    for th in ids:
        req = urllib.request.Request(
            f"https://gmail.googleapis.com/gmail/v1/users/me/threads/{th}/modify",
            data=json.dumps({"removeLabelIds": ["UNREAD"]}).encode(),
            headers={"Authorization": f"Bearer {tok}",
                     "Content-Type": "application/json"},
            method="POST")
        try:
            with urllib.request.urlopen(req):
                print(th, "-> read")
        except Exception as e:  # noqa: BLE001 — report per-thread, keep going
            print(th, "-> ERROR", str(e)[:120])


if __name__ == "__main__":
    main()
