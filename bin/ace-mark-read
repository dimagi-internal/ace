#!/usr/bin/env python3
"""Mark Gmail threads read (remove the UNREAD label) as ace@ — shim over the canopy engine.

`canopy email mark-read` (engine ≥ 0.2.255) shells `gog gmail thread modify --remove
UNREAD` per thread via gog's own token bucket — NEVER the macOS Keychain, which blocks
forever on a GUI prompt in non-interactive agent shells (jjackson/ace#827). Reading a
message via the API does not clear its unread flag, which is why this tool exists;
inbox-triage calls it after a thread is fully handled or dismissed. Identity comes from
THIS repo's config/agent.json via --repo.

Usage: bin/ace-mark-read <threadId> [<threadId> ...]
NOTE (zsh): unquoted `$IDS` does NOT word-split in zsh — pipe ids through
xargs instead: `... | xargs bin/ace-mark-read`.
"""
import os
import sys

REPO = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
try:
    os.execvp("canopy", ["canopy", "email", "mark-read", "--repo", REPO, *sys.argv[1:]])
except FileNotFoundError:
    sys.exit(
        "canopy CLI not on PATH — the shared email engine lives there (canopy ≥ 0.2.255).\n"
        "Install it (`uv tool install canopy` from the canopy checkout). See /canopy:setup."
    )
